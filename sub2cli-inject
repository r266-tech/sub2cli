def _parse_pid_lines(text: str) -> list[int]:
    pids: list[int] = []
    for line in text.splitlines():
        value = line.strip()
        if not value:
            continue
        try:
            pids.append(int(value))
        except ValueError:
            continue
    return pids


def codex_main_pids() -> list[int]:
    proc = subprocess.run(["pgrep", "-x", "Codex"], capture_output=True, text=True)
    return _parse_pid_lines(proc.stdout)


def codex_app_main_pids() -> list[int]:
    """Find the visible Codex.app main process even when pgrep -x misses it."""
    markers = {
        str(CODEX_APP_BUNDLE / "Contents" / "MacOS" / "Codex"),
        str((CODEX_APP_BUNDLE / "Contents" / "MacOS" / "Codex").resolve(strict=False)),
    }
    proc = subprocess.run(["ps", "-axww", "-o", "pid=,command="], capture_output=True, text=True)
    pids: set[int] = set()
    for line in proc.stdout.splitlines():
        stripped = line.strip()
        if not stripped:
            continue
        parts = stripped.split(maxsplit=1)
        if len(parts) != 2:
            continue
        raw_pid, command = parts
        if not any(marker in command for marker in markers):
            continue
        try:
            pids.add(int(raw_pid))
        except ValueError:
            continue
    return sorted(pid for pid in pids if pid != os.getpid())


def codex_bundle_pids() -> list[int]:
    """Return target Codex.app process ids (main + bundle helpers).

    Match on argv0 being *inside* the bundle, not a bare substring anywhere in
    the command line. This kills the app's own executables (main + Helper procs
    launched from Contents/) but never an unrelated process that merely mentions
    the bundle path in its arguments, e.g. `tail -f …/Contents/MacOS/Codex.log`
    or an editor/build command operating on a file in the bundle.
    """
    pids: set[int] = set(codex_main_pids())
    prefixes = {
        str(CODEX_APP_BUNDLE / "Contents") + os.sep,
        str((CODEX_APP_BUNDLE / "Contents").resolve(strict=False)) + os.sep,
    }
    proc = subprocess.run(["ps", "-axww", "-o", "pid=,command="], capture_output=True, text=True)
    for line in proc.stdout.splitlines():
        stripped = line.strip()
        if not stripped:
            continue
        parts = stripped.split(maxsplit=1)
        if len(parts) != 2:
            continue
        raw_pid, command = parts
        argv0 = command.split()[0] if command.split() else ""
        if not any(argv0.startswith(prefix) for prefix in prefixes):
            continue
        try:
            pids.add(int(raw_pid))
        except ValueError:
            continue
    return sorted(pid for pid in pids if pid != os.getpid())


def codex_running() -> bool:
    return bool(codex_main_pids() or codex_app_main_pids())


def wait_codex_exit(timeout: float) -> bool:
    deadline = time.time() + timeout
    while time.time() < deadline:
        if not codex_running():
            return True
        time.sleep(0.25)
    return not codex_running()


def signal_pids(pids: list[int], sig: signal.Signals) -> None:
    for pid in sorted(set(pids)):
        if pid == os.getpid():
            continue
        try:
            os.kill(pid, sig)
        except ProcessLookupError:
            pass
        except PermissionError:
            pass


def pid_alive(pid: int) -> bool:
    try:
        os.kill(pid, 0)
        return True
    except ProcessLookupError:
        return False
    except PermissionError:
        return True


def codex_cli_app_server_control_pids() -> list[int]:
    """Find the persistent CLI app-server that owns app-server-control.sock.

    Codex App has its own stdio app-server processes. Those should not be
    touched here; the control socket is used by Terminal/SSH Codex sessions and
    can cache the pre-switch auth mode until restarted.
    """
    pids: set[int] = set()
    if not CODEX_APP_SERVER_CONTROL_SOCKET.exists():
        return []
    try:
        proc = subprocess.run(
            ["lsof", "-t", "-nP", str(CODEX_APP_SERVER_CONTROL_SOCKET)],
            capture_output=True,
            text=True,
            timeout=2,
        )
        pids.update(_parse_pid_lines(proc.stdout))
    except (OSError, subprocess.TimeoutExpired):
        pass
    if pids:
        return sorted(pid for pid in pids if pid != os.getpid())

    socket_ref = str(CODEX_APP_SERVER_CONTROL_SOCKET)
    proc = subprocess.run(["ps", "-axww", "-o", "pid=,command="], capture_output=True, text=True)
    for line in proc.stdout.splitlines():
        stripped = line.strip()
        if not stripped:
            continue
        parts = stripped.split(maxsplit=1)
        if len(parts) != 2:
            continue
        raw_pid, command = parts
        if " app-server " not in f" {command} ":
            continue
        if "--listen unix://" not in command:
            continue
        if socket_ref not in command:
            continue
        if "app-server-broker" in command:
            continue
        try:
            pids.add(int(raw_pid))
        except ValueError:
            continue
    return sorted(pid for pid in pids if pid != os.getpid())


def wait_cli_app_server_exit(pids: list[int], timeout: float) -> bool:
    deadline = time.time() + timeout
    targets = set(pids)
    while time.time() < deadline:
        holders = set(codex_cli_app_server_control_pids())
        alive = {pid for pid in targets if pid_alive(pid)}
        if not holders and not alive:
            return True
        time.sleep(0.2)
    holders = set(codex_cli_app_server_control_pids())
    alive = {pid for pid in targets if pid_alive(pid)}
    return not holders and not alive


def stop_codex_cli_app_server(timeout: float = 4.0) -> bool:
    pids = codex_cli_app_server_control_pids()
    if not pids:
        if CODEX_APP_SERVER_CONTROL_SOCKET.exists():
            try:
                CODEX_APP_SERVER_CONTROL_SOCKET.unlink()
            except OSError:
                pass
        return False
    signal_pids(pids, signal.SIGTERM)
    stopped = wait_cli_app_server_exit(pids, timeout)
    if not stopped:
        signal_pids(pids, signal.SIGKILL)
        stopped = wait_cli_app_server_exit(pids, 2.0)
    if stopped and CODEX_APP_SERVER_CONTROL_SOCKET.exists():
        try:
            CODEX_APP_SERVER_CONTROL_SOCKET.unlink()
        except OSError:
            pass
    return stopped


def quit_codex(timeout: float = 8.0) -> bool:
    if not codex_running():
        return False
    try:
        subprocess.run(
            ["osascript", "-e", 'tell application id "com.openai.codex" to quit'],
            check=False,
            timeout=min(timeout, 4.0),
            capture_output=True,
            text=True,
        )
    except subprocess.TimeoutExpired:
        pass
    if wait_codex_exit(timeout):
        return True
    if FORCE_QUIT_CODEX:
        print("  Codex.app 退出超时，正在强制结束后继续…", file=sys.stderr)
        signal_pids(codex_bundle_pids(), signal.SIGTERM)
        if wait_codex_exit(3.0):
            return True
        signal_pids(codex_bundle_pids(), signal.SIGKILL)
        if wait_codex_exit(3.0):
            return True
    fail("Codex.app 退出超时。请手动退出 Codex App 后重试。")
    return True


def launch_codex() -> bool:
    command = ["open", str(CODEX_APP_BUNDLE)] if CODEX_APP_BUNDLE.exists() else ["open", "-a", "Codex"]
    subprocess.Popen(command, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, start_new_session=True)
    return True


def find_codex_cli() -> str | None:
    candidates: list[str] = []
    path_hit = shutil.which("codex")
    if path_hit:
        candidates.append(path_hit)
    candidates.extend(os.path.expanduser(p) for p in CODEX_CLI_FALLBACKS)
    for pattern in CODEX_CLI_FALLBACK_GLOBS:
        candidates.extend(sorted(glob.glob(os.path.expanduser(pattern))))
    candidates.append(str(CODEX_APP_BUNDLED_CLI))

    seen: set[str] = set()
    for candidate in candidates:
        real = os.path.realpath(candidate)
        if real in seen:
            continue
        seen.add(real)
        if os.path.isfile(candidate) and os.access(candidate, os.X_OK):
            return candidate
    return None


def decode_auth_email(auth_file: Path) -> str | None:
    try:
        data = json.loads(auth_file.read_text())
        token = data.get("tokens", {}).get("id_token", "")
        if token.count(".") < 2:
            return None
        payload = token.split(".")[1]
        payload += "=" * (-len(payload) % 4)
        return json.loads(base64.urlsafe_b64decode(payload)).get("email")
    except Exception:
        return None


def mask_auth_error(text: str) -> str:
    text = str(text or "")
    text = re.sub(r"sk-[A-Za-z0-9._-]{12,}", lambda m: m.group(0)[:8] + "..." + m.group(0)[-4:], text)
    return re.sub(
        r"(?i)(access|refresh|id)_token[^,}\n]*",
        lambda m: f"{m.group(1)}_token:<redacted>",
        text,
    )


def read_available_pipe_text(pipe, limit: int = 4000) -> str:
    try:
        fd = pipe.fileno()
        old_flags = fcntl.fcntl(fd, fcntl.F_GETFL)
        fcntl.fcntl(fd, fcntl.F_SETFL, old_flags | os.O_NONBLOCK)
    except Exception:
        return ""
    chunks: list[bytes] = []
    total = 0
    try:
        while total < limit:
            try:
                data = os.read(fd, min(4096, limit - total))
            except BlockingIOError:
                break
            if not data:
                break
            chunks.append(data)
            total += len(data)
    except Exception:
        return b"".join(chunks).decode(errors="replace")
    finally:
        try:
            fcntl.fcntl(fd, fcntl.F_SETFL, old_flags)
        except Exception:
            pass
    return b"".join(chunks).decode(errors="replace")


def refresh_oauth_auth_file(auth_file: Path) -> tuple[bool, str]:
    """Validate an OAuth auth.json using Codex CLI and persist refreshed tokens.

    Official slots can look usable to Codex App because the Electron profile is
    still logged in, while the CLI auth JSON contains a one-time refresh token
    that has already been consumed. Refresh before switching so CLI and App do
    not diverge.
    """
    if not auth_file.exists():
        return False, f"auth file not found: {auth_file}"
    codex_cli = find_codex_cli()
    if not codex_cli:
        return False, "找不到 codex CLI，无法校验官方账号登录态"
    try:
        with tempfile.TemporaryDirectory(prefix="sub2cli-auth-refresh.") as tmp:
            tmp_home = Path(tmp)
            shutil.copy2(auth_file, tmp_home / "auth.json")
            env = os.environ.copy()
            env["CODEX_HOME"] = str(tmp_home)
            env.setdefault("TERM", "xterm-256color")
            proc = subprocess.Popen(
                [codex_cli, "-s", "read-only", "-a", "untrusted", "app-server"],
                stdin=subprocess.PIPE,
                stdout=subprocess.PIPE,
                stderr=subprocess.PIPE,
                text=True,
                bufsize=1,
                env=env,
            )
            requests = [
                {"id": 1, "method": "initialize", "params": {"clientInfo": {"name": "sub2cli", "title": "sub2cli", "version": APP_VERSION}}},
                {"method": "initialized"},
                {"id": 2, "method": "account/read", "params": {"refreshToken": True}},
            ]
            assert proc.stdin is not None
            for msg in requests:
                proc.stdin.write(json.dumps(msg) + "\n")
                proc.stdin.flush()
            response = None
            deadline = time.time() + CODEX_AUTH_REFRESH_TIMEOUT
            assert proc.stdout is not None
            while time.time() < deadline and response is None:
                ready, _, _ = select.select([proc.stdout], [], [], 0.2)
                if not ready:
                    continue
                line = proc.stdout.readline()
                if not line:
                    break
                try:
                    payload = json.loads(line)
                except json.JSONDecodeError:
                    continue
                if payload.get("id") == 2:
                    response = payload
            stderr = read_available_pipe_text(proc.stderr) if proc.stderr is not None else ""
            if response is None:
                try:
                    proc.terminate()
                    proc.wait(timeout=2)
                except Exception:
                    try:
                        proc.kill()
                    except Exception:
                        pass
                return False, "Codex CLI 校验官方账号超时"
            if response.get("error"):
                try:
                    proc.terminate()
                    proc.wait(timeout=2)
                except Exception:
                    try:
                        proc.kill()
                    except Exception:
                        pass
                return False, mask_auth_error(json.dumps(response.get("error"), ensure_ascii=False))
            result = response.get("result") or {}
            account = result.get("account") or {}
            refreshed_auth = tmp_home / "auth.json"
            if not account.get("email"):
                detail = (
                    mask_auth_error(stderr.strip())
                    if stderr
                    else "Codex CLI 未返回有效官方账号，refresh token 可能已失效"
                )
                try:
                    proc.terminate()
                    proc.wait(timeout=2)
                except Exception:
                    try:
                        proc.kill()
                    except Exception:
                        pass
                return False, detail
            try:
                proc.stdin.close()
            except Exception:
                pass
            try:
                proc.wait(timeout=5)
            except Exception:
                try:
                    proc.terminate()
                    proc.wait(timeout=2)
                except Exception:
                    try:
                        proc.kill()
                    except Exception:
                        pass
            tmp_out = auth_file.with_name(f"{auth_file.name}.{os.getpid()}.{time.time_ns()}.tmp")
            tmp_out.write_bytes(refreshed_auth.read_bytes())
            os.chmod(tmp_out, 0o600)
            os.replace(tmp_out, auth_file)
            return True, ""
    except FileNotFoundError:
        return False, "找不到 codex CLI，无法校验官方账号登录态"
    except Exception as exc:
        return False, f"{type(exc).__name__}: {mask_auth_error(str(exc))}"


def _migrate_legacy_auth_symlink(*, quiet: bool = False) -> bool:
    """If AUTH_JSON is a legacy symlink (v0.2.0 layout), break it into a real
    file in place. Idempotent — safe to call from any cmd_init entry path,
    including upgrade users who already have populated slots.

    Returns True iff a migration was performed.
    """
    if not AUTH_JSON.is_symlink():
        return False
    legacy_target = Path(os.readlink(AUTH_JSON)).expanduser()
    if not legacy_target.is_absolute():
        legacy_target = (AUTH_JSON.parent / legacy_target).resolve(strict=False)
    if legacy_target.exists():
        try:
            content = legacy_target.read_bytes()
        except OSError:
            content = b""
        AUTH_JSON.unlink()
        if content:
            AUTH_JSON.write_bytes(content)
            os.chmod(AUTH_JSON, 0o600)
        if not quiet:
            print(f"  ↳ migrated legacy auth.json symlink → real file ({len(content)} bytes)")
    else:
        AUTH_JSON.unlink()
        if not quiet:
            print(f"  ↳ removed dangling legacy auth.json symlink ({legacy_target} missing)")
    return True


def cmd_init(slot: str = "local", display: str | None = None, *, quiet: bool = False) -> int:
    if Sub2cliLock._depth == 0:
        try:
            with Sub2cliLock():
                return cmd_init(slot=slot, display=display, quiet=quiet)
        except LockBusy as exc:
            fail(str(exc), code=4)
    slot = validate_slot(slot)
    data = load_slots(required=False)

    # Idempotent legacy migration: run BEFORE the early-return so upgrade
    # users (v0.2.0 layout: slots already populated, auth.json still a symlink)
    # get their symlink broken into a real file. Without this, codex's next
    # token-refresh atomic-write would replace the symlink anyway — but later
    # switches would race the symlink check against codex's writes.
    legacy_migrated = _migrate_legacy_auth_symlink(quiet=quiet)

    # Already initialized if slots are configured and APP_PROFILE is a symlink.
    # AUTH_JSON is now intentionally a real file (no longer symlinked).
    if data.get("current") and data.get("slots") and APP_PROFILE.is_symlink():
        if not quiet:
            print(f"already initialized: current={data['current']}")
            print(f"slots file: {SLOTS_FILE}")
        return 0

    quit_codex()
    CODEX_HOME.mkdir(parents=True, exist_ok=True)
    APP_SUPPORT.mkdir(parents=True, exist_ok=True)

    auth_slot = CODEX_HOME / f"auth.{slot}.json"
    profile_slot = APP_SUPPORT / f"Codex.{slot}"

    if AUTH_JSON.exists():
        # Real file already (typical post-codex-refresh state). Preserve content
        # into auth_slot if absent, then leave AUTH_JSON in place.
        if not auth_slot.exists():
            auth_slot.parent.mkdir(parents=True, exist_ok=True)
            auth_slot.write_bytes(AUTH_JSON.read_bytes())
            os.chmod(auth_slot, 0o600)
        elif auth_slot.read_bytes() != AUTH_JSON.read_bytes():
            # Existing auth_slot differs — keep the newer (AUTH_JSON) so live
            # tokens are preserved. Back up the old slot file.
            bak = auth_slot.with_suffix(auth_slot.suffix + f".pre-init-{int(time.time())}.bak")
            bak.write_bytes(auth_slot.read_bytes())
            os.chmod(bak, 0o600)
            auth_slot.write_bytes(AUTH_JSON.read_bytes())
            os.chmod(auth_slot, 0o600)

    if APP_PROFILE.is_symlink():
        profile_slot = Path(os.readlink(APP_PROFILE)).expanduser()
    elif APP_PROFILE.exists():
        if profile_slot.exists():
            fail(f"{profile_slot} already exists; refusing to overwrite it")
        APP_PROFILE.rename(profile_slot)
    else:
        profile_slot.mkdir(parents=True, exist_ok=True)

    atomic_symlink(APP_PROFILE, profile_slot)

    email = decode_auth_email(auth_slot) if auth_slot.exists() else None
    display_name = display or (f"Codex - {email}" if email else f"Codex - {slot}")
    data["slots"][slot] = {
        "display_name": display_name,
        "mode": "oauth",
        "auth_file": str(auth_slot),
        "app_profile_dir": str(profile_slot),
    }
    data["current"] = slot
    data["app_history_slot"] = slot
    save_slots(data)

    if not quiet:
        print(f"initialized: {slot}")
        print(f"  auth:    {auth_slot}")
        print(f"  profile: {profile_slot}")
        print(f"  slots:   {SLOTS_FILE}")
    return 0


def ensure_initialized() -> None:
    if not SLOTS_FILE.exists():
        cmd_init(quiet=True)


def probe_relay(base_url: str, api_key: str, timeout: float = 12.0) -> tuple[bool, str]:
    req = urlrequest.Request(
        models_endpoint(base_url),
        headers={
            "Authorization": f"Bearer {api_key}",
            "Accept": "application/json",
            "User-Agent": f"sub2cli/{APP_VERSION}",
        },
    )
    try:
        with fresh_urlopen(req, timeout=timeout) as resp:
            body = resp.read(8192)
        parsed = json.loads(body)
        if isinstance(parsed, dict) and isinstance(parsed.get("data"), list):
            return True, f"/v1/models 可访问（{len(parsed['data'])} 个模型）"
        return False, "中转有响应，但返回格式不像 OpenAI 兼容接口"
    except urlerror.HTTPError as exc:
        if exc.code == 401:
            return False, "401 Unauthorized - API key 不正确"
        if exc.code == 403:
            return False, "403 Forbidden - key 权限不足，或中转拒绝当前网络"
        if exc.code == 404:
            return False, "404 Not Found - base URL 可能不对，通常使用站点根或 /v1 API base"
        return False, f"HTTP {exc.code} {exc.reason}"
    except urlerror.URLError as exc:
        return False, f"无法访问中转：{exc.reason}"
    except TimeoutError:
        return False, f"{timeout:.0f}s 后超时"
    except Exception as exc:
        return False, f"{type(exc).__name__}: {exc}"


def models_endpoint(base_url: str) -> str:
    cleaned = base_url.strip().rstrip("/")
    if not cleaned:
        return ""
    if cleaned.endswith("/models"):
        return cleaned
    if cleaned.endswith("/v1"):
        return f"{cleaned}/models"
    return f"{cleaned}/v1/models"


def responses_endpoint(base_url: str) -> str:
    cleaned = base_url.strip().rstrip("/")
    if not cleaned:
        return ""
    lowered = cleaned.lower()
    if lowered.endswith("/responses"):
        return cleaned
    if lowered.endswith("/v1"):
        return f"{cleaned}/responses"
    return f"{cleaned}/v1/responses"


def fetch_relay_models(base_url: str, api_key: str, timeout: float = 12.0) -> tuple[list[str], str | None]:
    endpoint = models_endpoint(base_url)
    if not endpoint:
        return [], "missing base_url"
    req = urlrequest.Request(
        endpoint,
        headers={
            "Authorization": f"Bearer {api_key}",
            "Accept": "application/json",
            "User-Agent": "sub2cli/0.1",
        },
    )
    try:
        with fresh_urlopen(req, timeout=timeout) as resp:
            payload = json.loads(resp.read(2 * 1024 * 1024))
    except urlerror.HTTPError as exc:
        return [], f"HTTP {exc.code} {exc.reason}"
    except urlerror.URLError as exc:
        return [], f"network error: {exc.reason}"
    except TimeoutError:
        return [], f"{timeout:.0f}s timeout"
    except Exception as exc:
        return [], f"{type(exc).__name__}: {exc}"
    return parse_models_payload(payload), None


def parse_models_payload(payload: object) -> list[str]:
    values: list[str] = []

    def walk(value: object) -> None:
        if isinstance(value, str):
            if value.strip():
                values.append(value.strip())
            return
        if isinstance(value, list):
            for item in value:
                walk(item)
            return
        if isinstance(value, dict):
            for key in ("id", "model", "name"):
                raw = value.get(key)
                if isinstance(raw, str) and raw.strip():
                    values.append(raw.strip())
                    return
            for key in ("data", "models", "items"):
                nested = value.get(key)
                if isinstance(nested, (list, dict)):
                    walk(nested)
                    return

    walk(payload)
    seen: set[str] = set()
    result: list[str] = []
    for value in values:
        if value not in seen:
            result.append(value)
            seen.add(value)
    return result


def model_is_image(model: str) -> bool:
    return bool(re.search(r"(^|[-_/])image($|[-_/])|(^|[-_/])imagen($|[-_/])", model or "", re.I))


MODEL_NON_TEXT_HINTS_RE = re.compile(
    r"(image|imagen|audio|embedding|moderation|tts|whisper|dall[-_]?e|transcribe|realtime)",
    re.I,
)
MODEL_SMALL_HINTS_RE = re.compile(r"(^|[-_/])(mini|nano|small|lite|spark)($|[-_/])", re.I)


def model_version_key(model: str) -> tuple:
    nums = [int(n) for n in re.findall(r"\d+", model or "")]
    padded = nums[:5] + [0] * max(0, 5 - len(nums))
    text = (model or "").lower()
    small_penalty = 1 if MODEL_SMALL_HINTS_RE.search(text) else 0
    non_text_penalty = 1 if MODEL_NON_TEXT_HINTS_RE.search(text) else 0
    codex_bonus = 1 if re.search(r"(^|[-_/])(codex|code)($|[-_/])", text) else 0
    return (-non_text_penalty, *padded, -small_penalty, codex_bonus, -len(text), text)


def best_default_model(models: list[str], fallback: str = DEFAULT_MODEL) -> str:
    usable = [model for model in models if isinstance(model, str) and model.strip()]
    if not usable:
        return fallback
    return sorted(usable, key=model_version_key, reverse=True)[0]


def merge_model_lists(*lists: list[str] | None) -> list[str]:
    result: list[str] = []
    seen: set[str] = set()
    for items in lists:
        for item in items or []:
            model = str(item or "").strip()
            if model and model not in seen:
                result.append(model)
                seen.add(model)
    return result


def chat_completions_endpoint(base_url: str) -> str:
    cleaned = base_url.strip().rstrip("/")
    if not cleaned:
        return ""
    lowered = cleaned.lower()
    if lowered.endswith("/chat/completions"):
        return cleaned
    if lowered.endswith("/v1"):
        return f"{cleaned}/chat/completions"
    return f"{cleaned}/v1/chat/completions"


def _response_id_from_chat(chat_id: str | None) -> str:
    chat_id = (chat_id or "sub2cli_compat").strip() or "sub2cli_compat"
    return chat_id if chat_id.startswith("resp_") else f"resp_{chat_id}"


def _message_content_text(content: object) -> str:
    if isinstance(content, str):
        return content
    parts: list[str] = []
    if isinstance(content, list):
        for item in content:
            if isinstance(item, str):
                parts.append(item)
            elif isinstance(item, dict):
                raw = item.get("text") or item.get("content") or item.get("input")
                if isinstance(raw, str):
                    parts.append(raw)
    elif isinstance(content, dict):
        raw = content.get("text") or content.get("content") or content.get("input")
        if isinstance(raw, str):
            parts.append(raw)
    return "\n".join(part for part in parts if part)


def _append_responses_input(value: object, messages: list[dict]) -> None:
    if isinstance(value, str):
        messages.append({"role": "user", "content": value})
        return
    if not isinstance(value, list):
        return
    for item in value:
        if not isinstance(item, dict):
            continue
        item_type = str(item.get("type") or "")
        if item_type == "function_call_output":
            call_id = str(item.get("call_id") or item.get("id") or "").strip()
            output = item.get("output")
            messages.append({
                "role": "tool",
                "tool_call_id": call_id or "call_compat",
                "content": output if isinstance(output, str) else json.dumps(output, ensure_ascii=False),
            })
            continue
        if item_type == "function_call":
            call_id = str(item.get("call_id") or item.get("id") or "").strip() or "call_compat"
            name = str(item.get("name") or "").strip() or "tool"
            arguments = item.get("arguments")
            if not isinstance(arguments, str):
                arguments = json.dumps(arguments if arguments is not None else {}, ensure_ascii=False)
            messages.append({
                "role": "assistant",
                "content": None,
                "tool_calls": [{
                    "id": call_id,
                    "type": "function",
                    "function": {"name": name, "arguments": arguments},
                }],
            })
            continue
        role = str(item.get("role") or "user").strip() or "user"
        if role == "developer":
            role = "system"
        if role not in {"system", "user", "assistant", "tool"}:
            role = "user"
        text = _message_content_text(item.get("content"))
        if text:
            messages.append({"role": role, "content": text})


def responses_to_chat_request(body: dict) -> dict:
    result: dict = {}
    if body.get("model") is not None:
        result["model"] = body.get("model")
    messages: list[dict] = []
    instructions = _message_content_text(body.get("instructions"))
    if instructions:
        messages.append({"role": "system", "content": instructions})
    _append_responses_input(body.get("input"), messages)
    if not messages:
        messages.append({"role": "user", "content": ""})
    result["messages"] = messages
    if body.get("max_output_tokens") is not None:
        result["max_tokens"] = body.get("max_output_tokens")
    for key in ("max_tokens", "temperature", "top_p", "stream"):
        if body.get(key) is not None:
            result[key] = body.get(key)
    if result.get("stream"):
        result["stream_options"] = {"include_usage": True}

    tools: list[dict] = []
    for tool in body.get("tools") or []:
        if not isinstance(tool, dict):
            continue
        name = str(tool.get("name") or tool.get("function", {}).get("name") or "").strip()
        if not name:
            continue
        params = tool.get("parameters") or tool.get("input_schema") or tool.get("schema") or {}
        if not isinstance(params, dict):
            params = {}
        params.setdefault("type", "object")
        params.setdefault("properties", {})
        fn = {
            "name": name,
            "description": str(tool.get("description") or ""),
            "parameters": params,
        }
        tools.append({"type": "function", "function": fn})
    if tools:
        result["tools"] = tools
        if body.get("parallel_tool_calls") is not None:
            result["parallel_tool_calls"] = body.get("parallel_tool_calls")
    return result


def _usage_to_responses(usage: object) -> dict:
    usage = usage if isinstance(usage, dict) else {}
    prompt = int(usage.get("prompt_tokens") or usage.get("input_tokens") or 0)
    completion = int(usage.get("completion_tokens") or usage.get("output_tokens") or 0)
    total = int(usage.get("total_tokens") or (prompt + completion))
    details = usage.get("completion_tokens_details") if isinstance(usage.get("completion_tokens_details"), dict) else {}
    return {
        "input_tokens": prompt,
        "output_tokens": completion,
        "total_tokens": total,
        "output_tokens_details": {
            "reasoning_tokens": int(details.get("reasoning_tokens") or 0),
        },
    }


def chat_completion_to_response(body: dict) -> dict:
    choices = body.get("choices") if isinstance(body.get("choices"), list) else []
    first = choices[0] if choices and isinstance(choices[0], dict) else {}
    msg = first.get("message") if isinstance(first.get("message"), dict) else {}
    chat_id = str(body.get("id") or "chatcmpl_sub2cli")
    response_id = _response_id_from_chat(chat_id)
    model = str(body.get("model") or msg.get("model") or "")
    output: list[dict] = []
    reasoning = msg.get("reasoning_content")
    if isinstance(reasoning, str) and reasoning:
        output.append({
            "id": f"rs_{chat_id}",
            "type": "reasoning",
            "summary": [{"type": "summary_text", "text": reasoning}],
            "reasoning_content": reasoning,
        })
    content = msg.get("content")
    if isinstance(content, list):
        content = _message_content_text(content)
    if isinstance(content, str) and content:
        output.append({
            "id": f"msg_{chat_id}",
            "type": "message",
            "status": "completed",
            "role": "assistant",
            "content": [{"type": "output_text", "text": content, "annotations": []}],
        })
    for idx, call in enumerate(msg.get("tool_calls") or []):
        if not isinstance(call, dict):
            continue
        fn = call.get("function") if isinstance(call.get("function"), dict) else {}
        output.append({
            "id": f"fc_{idx}_{chat_id}",
            "type": "function_call",
            "status": "completed",
            "call_id": str(call.get("id") or f"call_{idx}"),
            "name": str(fn.get("name") or "tool"),
            "arguments": fn.get("arguments") if isinstance(fn.get("arguments"), str) else "{}",
        })
    return {
        "id": response_id,
        "object": "response",
        "created_at": int(body.get("created") or time.time()),
        "status": "completed",
        "model": model,
        "output": output,
        "usage": _usage_to_responses(body.get("usage")),
    }


def _sse(event: str, data: object) -> str:
    return f"event: {event}\ndata: {json.dumps(data, ensure_ascii=False, separators=(',', ':'))}\n\n"


def response_json_to_sse(response: dict) -> bytes:
    chunks: list[str] = []
    chunks.append(_sse("response.created", {"response": {k: v for k, v in response.items() if k != "output"}}))
    chunks.append(_sse("response.in_progress", {"response": {**response, "status": "in_progress", "output": []}}))
    for output_index, item in enumerate(response.get("output") or []):
        chunks.append(_sse("response.output_item.added", {"output_index": output_index, "item": item}))
        if item.get("type") == "message":
            content = (item.get("content") or [{}])[0]
            text = str(content.get("text") or "")
            chunks.append(_sse("response.content_part.added", {
                "item_id": item.get("id"), "output_index": output_index, "content_index": 0,
                "part": {"type": "output_text", "text": "", "annotations": []},
            }))
            if text:
                chunks.append(_sse("response.output_text.delta", {
                    "item_id": item.get("id"), "output_index": output_index, "content_index": 0,
                    "delta": text,
                }))
            chunks.append(_sse("response.output_text.done", {
                "item_id": item.get("id"), "output_index": output_index, "content_index": 0,
                "text": text,
            }))
            chunks.append(_sse("response.content_part.done", {
                "item_id": item.get("id"), "output_index": output_index, "content_index": 0,
                "part": {"type": "output_text", "text": text, "annotations": []},
            }))
        elif item.get("type") == "function_call":
            args = str(item.get("arguments") or "")
            if args:
                chunks.append(_sse("response.function_call_arguments.delta", {
                    "item_id": item.get("id"), "output_index": output_index, "delta": args,
                }))
            chunks.append(_sse("response.function_call_arguments.done", {
                "item_id": item.get("id"), "output_index": output_index, "arguments": args,
            }))
        chunks.append(_sse("response.output_item.done", {"output_index": output_index, "item": item}))
    chunks.append(_sse("response.completed", {"response": response}))
    chunks.append("data: [DONE]\n\n")
    return "".join(chunks).encode("utf-8")


def chat_sse_to_response_json(raw: bytes) -> dict:
    content = ""
    reasoning = ""
    chat_id = "chatcmpl_sub2cli"
    model = ""
    created = int(time.time())
    usage: dict = {}
    tools: dict[int, dict] = {}
    for raw_line in raw.decode("utf-8", errors="replace").splitlines():
        line = raw_line.strip()
        if not line.startswith("data:"):
            continue
        data = line[5:].strip()
        if not data or data == "[DONE]":
            continue
        try:
            payload = json.loads(data)
        except ValueError:
            continue
        if isinstance(payload.get("error"), dict):
            raise RuntimeError(payload["error"].get("message") or json.dumps(payload["error"], ensure_ascii=False))
        chat_id = str(payload.get("id") or chat_id)
        model = str(payload.get("model") or model)
        created = int(payload.get("created") or created)
        if isinstance(payload.get("usage"), dict):
            usage = payload["usage"]
        choices = payload.get("choices") if isinstance(payload.get("choices"), list) else []
        for choice in choices:
            if not isinstance(choice, dict):
                continue
            delta = choice.get("delta") if isinstance(choice.get("delta"), dict) else {}
            if isinstance(delta.get("content"), str):
                content += delta["content"]
            if isinstance(delta.get("reasoning_content"), str):
                reasoning += delta["reasoning_content"]
            for tc in delta.get("tool_calls") or []:
                if not isinstance(tc, dict):
                    continue
                idx = int(tc.get("index") or 0)
                state = tools.setdefault(idx, {"id": "", "name": "", "arguments": ""})
                if tc.get("id"):
                    state["id"] = str(tc.get("id"))
                fn = tc.get("function") if isinstance(tc.get("function"), dict) else {}
                if fn.get("name"):
                    state["name"] = str(fn.get("name"))
                if isinstance(fn.get("arguments"), str):
                    state["arguments"] += fn["arguments"]
    message: dict = {"role": "assistant", "content": content}
    if reasoning:
        message["reasoning_content"] = reasoning
    if tools:
        message["tool_calls"] = [
            {
                "id": tool.get("id") or f"call_{idx}",
                "type": "function",
                "function": {"name": tool.get("name") or "tool", "arguments": tool.get("arguments") or "{}"},
            }
            for idx, tool in sorted(tools.items())
        ]
    return chat_completion_to_response({
        "id": chat_id,
        "created": created,
        "model": model,
        "choices": [{"message": message, "finish_reason": "tool_calls" if tools else "stop"}],
        "usage": usage,
    })


def _active_proxy_slot() -> dict:
    data = load_slots(required=False)
    slot = data.get("current")
    cfg = (data.get("slots") or {}).get(slot) or {}
    protocol = str(cfg.get("protocol") or "responses")
    if cfg.get("mode") != "relay" or protocol not in {"chat", "pool"}:
        raise RuntimeError("当前渠道不是本地代理 API")
    if protocol == "chat" and (
        not str(cfg.get("base_url") or "").strip()
        or not str(cfg.get("api_key") or "").strip()
    ):
        raise RuntimeError("chat-completions 自定义 API 缺少 base_url 或 api_key")
    if protocol == "pool" and not pool_routes(cfg):
        raise RuntimeError("route pool 没有可用 routes")
    return cfg


def proxy_log(message: str) -> None:
    try:
        PROTOCOL_PROXY_LOG.parent.mkdir(parents=True, exist_ok=True)
        with PROTOCOL_PROXY_LOG.open("a", encoding="utf-8") as fh:
            fh.write("[%s] %s\n" % (time.strftime("%Y-%m-%d %H:%M:%S"), message))
    except OSError:
        pass


def pool_routes(cfg: dict) -> list[dict]:
    routes = cfg.get("routes")
    if not isinstance(routes, list):
        return []
    return sorted(
        [r for r in routes if isinstance(r, dict) and not r.get("disabled")],
        key=lambda r: (int(r.get("priority", 1000)), int(r.get("_order", 0)), str(r.get("id") or "")),
    )


def pool_policy(cfg: dict) -> dict:
    raw = cfg.get("policy") if isinstance(cfg.get("policy"), dict) else {}

    def _int(name: str, default: int, minimum: int = 0) -> int:
        try:
            value = int(raw.get(name, default))
        except (TypeError, ValueError):
            value = default
        return max(minimum, value)

    cooldown_raw = raw.get("cooldown_seconds", [60, 120, 300])
    cooldowns: list[int] = []
    cooldown_items = cooldown_raw if isinstance(cooldown_raw, list) else [cooldown_raw]
    for item in cooldown_items:
        try:
            cooldowns.append(max(1, int(item)))
        except (TypeError, ValueError):
            continue
    if not cooldowns:
        cooldowns = [60, 120, 300]
    return {
        "preempt_higher_priority": bool(raw.get("preempt_higher_priority", True)),
        "fail_consecutive": _int("fail_consecutive", 2, 1),
        "recovery_successes": _int("recovery_successes", 2, 1),
        "min_dwell_seconds": _int("min_dwell_seconds", 60, 0),
        "probe_interval_seconds": _int("probe_interval_seconds", 90, 5),
        "current_probe_interval_seconds": _int("current_probe_interval_seconds", 0, 0),
        "rate_limit_cooldown_seconds": _int("rate_limit_cooldown_seconds", 120, 1),
        "request_timeout_seconds": _int("request_timeout_seconds", 600, 10),
        "cooldown_seconds": cooldowns,
    }


def single_route_from_slot(cfg: dict) -> dict:
    return {
        "id": "current",
        "label": cfg.get("display_name") or "current",
        "priority": 10,
        "base_url": str(cfg.get("base_url") or "").strip().rstrip("/"),
        "api_key": str(cfg.get("api_key") or ""),
        "protocol": "chat",
        "model": cfg.get("model"),
        "_order": 0,
    }


def route_id(route: dict) -> str:
    return str(route.get("id") or route.get("label") or route.get("base_url") or "route")


def route_label(route: dict) -> str:
    return str(route.get("label") or route.get("name") or route_id(route))


def route_protocol(route: dict) -> str:
    return "chat" if route.get("protocol") == "chat" else "responses"


def route_headers(route: dict, *, accept: str = "application/json", content_type: str | None = None) -> dict:
    headers = {
        "Authorization": f"Bearer {route.get('api_key')}",
        "Accept": accept,
        "User-Agent": f"sub2cli-responses-proxy/{APP_VERSION}",
    }
    if content_type:
        headers["Content-Type"] = content_type
    return headers


def retry_after_seconds(headers: object) -> int | None:
    raw = None
    try:
        raw = headers.get("Retry-After")
    except AttributeError:
        return None
    if not raw:
        return None
    try:
        return max(1, int(float(raw)))
    except ValueError:
        return None


def http_error_detail(status: int, reason: str, body: bytes = b"") -> str:
    message = ""
    try:
        payload = json.loads((body or b"").decode("utf-8"))
    except (UnicodeDecodeError, ValueError):
        payload = None
    info = payload_error_info(payload) if payload is not None else None
    if info:
        message = info[0]
    elif body:
        message = body[:512].decode("utf-8", errors="replace").strip()
    base = f"HTTP {status} {reason}".strip()
    return f"{base}: {message}"[:300] if message else base


def route_source_type(route: dict | None) -> str:
    if not isinstance(route, dict):
        return ""
    return str(route.get("source_type") or "").strip().lower()


def relay_route_error_kind(route: dict | None) -> str:
    return "client_error" if route_source_type(route) == "relay" else "retryable"


def classify_upstream_status(
    status: int,
    body: bytes = b"",
    content_type: str = "application/json",
    *,
    route: dict | None = None,
) -> str:
    if detect_openai_transient_success_error(body, content_type):
        return "openai_retryable"
    if status == 429 or detect_upstream_rate_limit_error(body, content_type):
        return "rate_limit"
    if route_source_type(route) == "relay":
        return "client_error"
    if status in (401, 403):
        return "blocked"
    if status in (408, 409, 425) or status >= 500:
        return "retryable"
    if status == 400 and re.search(rb"model|unsupported|not\s+found", body[:4096], re.I):
        return "retryable"
    return "client_error"


OPENAI_TRANSIENT_BODY_RE = re.compile(
    r"("
    r"selected model is at capacity|"
    r"\bmodel\b.{0,80}\bat capacity\b|"
    r"\bat capacity\b.{0,80}\bmodel\b|"
    r"\bmodel\b.{0,80}\b(overloaded|busy|temporar(?:ily)? unavailable|unavailable)\b|"
    r"\b(overloaded|busy|temporar(?:ily)? unavailable)\b.{0,80}\bmodel\b|"
    r"please try a different model"
    r")",
    re.I,
)
OPENAI_TRANSIENT_CODE_RE = re.compile(
    r"(model_at_capacity|model_capacity|model_overloaded|model_unavailable)",
    re.I,
)
UPSTREAM_RATE_LIMIT_BODY_RE = re.compile(
    r"("
    r"\b429\b.{0,120}\b(too many requests|rate[\s_-]*limit(?:ed)?)\b|"
    r"\b(too many requests|rate[\s_-]*limit(?:ed)?)\b.{0,120}\b429\b|"
    r"\blast status\s*:\s*429\b"
    r")",
    re.I,
)


def is_openai_transient_success_error(message: str, *, error_type: str = "", error_code: str = "") -> bool:
    combined = " ".join(part for part in (message, error_type, error_code) if part)
    return bool(OPENAI_TRANSIENT_BODY_RE.search(combined) or OPENAI_TRANSIENT_CODE_RE.search(combined))


def is_upstream_rate_limit_error(message: str, *, error_type: str = "", error_code: str = "") -> bool:
    combined = " ".join(part for part in (message, error_type, error_code) if part)
    return bool(UPSTREAM_RATE_LIMIT_BODY_RE.search(combined))


def payload_error_info(payload: object) -> tuple[str, str, str] | None:
    if not isinstance(payload, dict):
        return None
    error = payload.get("error")
    if isinstance(error, dict):
        message = str(error.get("message") or error.get("detail") or error.get("code") or error.get("type") or "").strip()
        error_type = str(error.get("type") or "").strip()
        error_code = str(error.get("code") or "").strip()
        if message or error_type or error_code:
            return message or error_type or error_code, error_type, error_code
    elif isinstance(error, str) and error.strip():
        return error.strip(), "", ""

    response = payload.get("response")
    if isinstance(response, dict):
        nested = payload_error_info(response)
        if nested:
            return nested

    status = str(payload.get("status") or "").lower()
    if status in {"failed", "cancelled", "canceled"}:
        for key in ("message", "detail", "reason"):
            raw = payload.get(key)
            if isinstance(raw, str) and raw.strip():
                return raw.strip(), str(payload.get("type") or ""), str(payload.get("code") or "")

    return None


def iter_sse_json_payloads(raw: bytes):
    data_lines: list[str] = []
    for raw_line in raw.decode("utf-8", errors="replace").splitlines():
        line = raw_line.rstrip("\r")
        if not line:
            if data_lines:
                data = "\n".join(data_lines).strip()
                data_lines = []
                if data and data != "[DONE]":
                    try:
                        yield json.loads(data)
                    except ValueError:
                        pass
            continue
        if line.startswith("data:"):
            data_lines.append(line[5:].strip())
    if data_lines:
        data = "\n".join(data_lines).strip()
        if data and data != "[DONE]":
            try:
                yield json.loads(data)
            except ValueError:
                pass


def success_payloads(raw: bytes, content_type: str) -> list[object]:
    lowered_type = (content_type or "").lower()
    payloads: list[object] = []
    if "text/event-stream" in lowered_type:
        payloads.extend(iter_sse_json_payloads(raw))
    else:
        try:
            payloads.append(json.loads(raw.decode("utf-8")))
        except (UnicodeDecodeError, ValueError):
            payloads = []
    return payloads


def iter_success_error_info(raw: bytes, content_type: str):
    payloads = success_payloads(raw, content_type)
    for payload in payloads:
        info = payload_error_info(payload)
        if info:
            yield info


def detect_openai_transient_success_error(raw: bytes, content_type: str) -> str | None:
    payloads = success_payloads(raw, content_type)
    for payload in payloads:
        info = payload_error_info(payload)
        if not info:
            continue
        message, error_type, error_code = info
        if is_openai_transient_success_error(message, error_type=error_type, error_code=error_code):
            return message

    if not payloads and raw:
        text = raw[:8192].decode("utf-8", errors="replace").strip()
        if text and is_openai_transient_success_error(text):
            return text[:240]
    return None


def detect_upstream_rate_limit_error(raw: bytes, content_type: str) -> str | None:
    payloads = success_payloads(raw, content_type)
    for payload in payloads:
        info = payload_error_info(payload)
        if not info:
            continue
        message, error_type, error_code = info
        if is_upstream_rate_limit_error(message, error_type=error_type, error_code=error_code):
            return message or error_code or error_type

    if not payloads and raw:
        text = raw[:8192].decode("utf-8", errors="replace").strip()
        if text and is_upstream_rate_limit_error(text):
            return text[:240]
    return None


def detect_relay_success_error(raw: bytes, content_type: str) -> str | None:
    for message, _error_type, _error_code in iter_success_error_info(raw, content_type):
        return message
    return None


def raise_for_upstream_success_error(route: dict, raw: bytes, content_type: str) -> None:
    message = detect_openai_transient_success_error(raw, content_type)
    if message:
        detail = f"upstream 200 openai transient: {message}"[:300]
        raise UpstreamRouteError(
            route=route,
            status=502,
            body=raw[:1024 * 1024],
            content_type=content_type or "application/json",
            kind="openai_retryable",
            detail=detail,
        )
    if route_source_type(route) == "relay":
        message = detect_upstream_rate_limit_error(raw, content_type)
        if message:
            detail = f"relay returned rate limit payload: {message}"[:300]
            raise UpstreamRouteError(
                route=route,
                status=429,
                body=raw[:1024 * 1024],
                content_type=content_type or "application/json",
                kind="rate_limit",
                detail=detail,
            )
        message = detect_relay_success_error(raw, content_type)
        if message:
            detail = f"relay returned error payload: {message}"[:300]
            raise UpstreamRouteError(
                route=route,
                status=502,
                body=raw[:1024 * 1024],
                content_type=content_type or "application/json",
                kind="client_error",
                detail=detail,
            )


class UpstreamRouteError(Exception):
    def __init__(
        self,
        *,
        route: dict,
        status: int | None,
        body: bytes,
        content_type: str,
        kind: str,
        detail: str,
        retry_after: int | None = None,
    ) -> None:
        super().__init__(detail)
        self.route = route
        self.status = status
        self.body = body
        self.content_type = content_type or "application/json"
        self.kind = kind
        self.detail = detail
        self.retry_after = retry_after


class RoutePoolRuntime:
    def __init__(self) -> None:
        self._lock = threading.RLock()
        self._states: dict[str, dict] = {}
        self._current_route_id: str | None = None
        self._current_since = 0.0
        self._monitor_started = False

    def _state(self, rid: str) -> dict:
        return self._states.setdefault(rid, {
            "failures": 0,
            "open_until": 0.0,
            "blocked": False,
            "last_error": "",
            "last_status": None,
            "last_success": 0.0,
            "last_probe": 0.0,
            "probe_successes": 0,
        })

    def _sync(self, routes: list[dict]) -> None:
        valid = {route_id(route) for route in routes}
        for rid in list(self._states):
            if rid not in valid:
                self._states.pop(rid, None)
        if self._current_route_id and self._current_route_id not in valid:
            self._current_route_id = None
            self._current_since = 0.0

    def _usable(self, route: dict, now: float) -> bool:
        state = self._state(route_id(route))
        return not state.get("blocked") and float(state.get("open_until") or 0.0) <= now

    def _activate(self, route: dict, now: float) -> dict:
        rid = route_id(route)
        if self._current_route_id != rid:
            old = self._current_route_id or "(none)"
            self._current_route_id = rid
            self._current_since = now
            proxy_log(f"pool route active {old} -> {rid} ({route_label(route)})")
        return route

    def choose(self, cfg: dict, *, exclude_ids: set[str] | None = None) -> tuple[dict | None, str | None]:
        routes = pool_routes(cfg)
        policy = pool_policy(cfg)
        exclude_ids = exclude_ids or set()
        now = time.monotonic()
        with self._lock:
            self._sync(routes)
            by_id = {route_id(route): route for route in routes}
            usable = [
                route for route in routes
                if route_id(route) not in exclude_ids and self._usable(route, now)
            ]
            if not usable:
                return None, "no usable route"
            current = by_id.get(self._current_route_id or "")
            if current and route_id(current) not in exclude_ids and self._usable(current, now):
                better = [
                    route for route in usable
                    if (int(route.get("priority", 1000)), int(route.get("_order", 0)))
                    < (int(current.get("priority", 1000)), int(current.get("_order", 0)))
                ]
                dwell_ok = (now - self._current_since) >= int(policy["min_dwell_seconds"])
                if better and policy["preempt_higher_priority"] and dwell_ok:
                    return self._activate(better[0], now), None
                return current, None
            return self._activate(usable[0], now), None

    def record_success(self, route: dict, *, probe: bool = False) -> None:
        now = time.monotonic()
        policy = {"recovery_successes": 1}
        rid = route_id(route)
        with self._lock:
            state = self._state(rid)
            if probe:
                state["probe_successes"] = int(state.get("probe_successes") or 0) + 1
                # The caller handles the exact threshold because it knows cfg policy.
            else:
                state["probe_successes"] = int(policy["recovery_successes"])
            state["failures"] = 0
            state["last_error"] = ""
            state["last_status"] = 200
            state["last_success"] = now
            state["blocked"] = False
            state["open_until"] = 0.0

    def record_probe_success(self, route: dict, cfg: dict) -> None:
        now = time.monotonic()
        policy = pool_policy(cfg)
        rid = route_id(route)
        with self._lock:
            state = self._state(rid)
            successes = int(state.get("probe_successes") or 0) + 1
            threshold = int(policy["recovery_successes"])
            was_closed = bool(state.get("blocked")) or float(state.get("open_until") or 0.0) > now
            state["probe_successes"] = successes
            state["last_status"] = 200
            state["last_success"] = now
            state["last_error"] = ""
            proxy_log(f"pool route probe ok {rid} successes={successes}/{threshold}")
            if successes >= threshold:
                state["failures"] = 0
                state["blocked"] = False
                state["open_until"] = 0.0
                if was_closed:
                    proxy_log(f"pool route recovered {rid} ({route_label(route)})")

    def record_failure(
        self,
        route: dict,
        cfg: dict,
        *,
        kind: str,
        status: int | None = None,
        detail: str = "",
        retry_after: int | None = None,
    ) -> None:
        now = time.monotonic()
        policy = pool_policy(cfg)
        rid = route_id(route)
        with self._lock:
            state = self._state(rid)
            state["probe_successes"] = 0
            state["last_error"] = detail
            state["last_status"] = status
            if kind == "client_error":
                return
            if kind == "openai_retryable":
                proxy_log(f"pool route openai retryable {rid} status={status} detail={detail[:160]}")
                return
            if kind == "blocked":
                state["blocked"] = True
                state["open_until"] = now + 24 * 60 * 60
            elif kind == "rate_limit":
                cooldown = retry_after or int(policy["rate_limit_cooldown_seconds"])
                state["open_until"] = now + cooldown
            else:
                state["failures"] = int(state.get("failures") or 0) + 1
                if int(state["failures"]) >= int(policy["fail_consecutive"]):
                    cooldowns = policy["cooldown_seconds"]
                    idx = min(len(cooldowns) - 1, max(0, int(state["failures"]) - int(policy["fail_consecutive"])))
                    state["open_until"] = now + int(cooldowns[idx])
            if self._current_route_id == rid and not self._usable(route, now):
                self._current_route_id = None
                self._current_since = 0.0
            proxy_log(f"pool route failure {rid} kind={kind} status={status} detail={detail[:160]}")

    def snapshot(self, cfg: dict | None = None) -> dict:
        now = time.monotonic()
        with self._lock:
            states = {}
            routes = pool_routes(cfg or {}) if cfg else []
            route_map = {route_id(route): route for route in routes}
            for rid, state in self._states.items():
                route = route_map.get(rid, {})
                states[rid] = {
                    "label": route_label(route) if route else rid,
                    "priority": route.get("priority"),
                    "blocked": bool(state.get("blocked")),
                    "cooldown_remaining": max(0, int(float(state.get("open_until") or 0.0) - now)),
                    "failures": int(state.get("failures") or 0),
                    "last_status": state.get("last_status"),
                    "last_error": state.get("last_error") or "",
                    "probe_successes": int(state.get("probe_successes") or 0),
                }
            return {
                "current_route": self._current_route_id,
                "states": states,
            }

    def start_monitor(self) -> None:
        with self._lock:
            if self._monitor_started:
                return
            self._monitor_started = True
        thread = threading.Thread(target=self._monitor_loop, name="sub2cli-route-pool-monitor", daemon=True)
        thread.start()

    def _monitor_loop(self) -> None:
        while True:
            try:
                data = load_slots(required=False)
                cfg = (data.get("slots") or {}).get(data.get("current")) or {}
                if cfg.get("mode") == "relay" and cfg.get("protocol") == "pool":
                    self.probe_due_routes(cfg)
            except Exception as exc:
                proxy_log(f"pool monitor error: {type(exc).__name__}: {exc}")
            time.sleep(2)

    def probe_due_routes(self, cfg: dict) -> None:
        routes = pool_routes(cfg)
        if not routes:
            return
        policy = pool_policy(cfg)
        now = time.monotonic()
        due: list[dict] = []
        with self._lock:
            self._sync(routes)
            current = self._current_route_id
            current_route = next((route for route in routes if route_id(route) == current), None)
            if not current_route:
                current_rank = None
            else:
                current_rank = (
                    int(current_route.get("priority", 1000)),
                    int(current_route.get("_order", 0)),
                )
            for route in routes:
                state = self._state(route_id(route))
                if current_rank is not None:
                    route_rank = (
                        int(route.get("priority", 1000)),
                        int(route.get("_order", 0)),
                    )
                    if route_id(route) == current or route_rank >= current_rank:
                        continue
                interval = int(policy["probe_interval_seconds"])
                if now - float(state.get("last_probe") or 0.0) >= interval:
                    state["last_probe"] = now
                    due.append(route)
        for route in due:
            try:
                probe_route(route, timeout=min(10, int(policy["request_timeout_seconds"])))
                self.record_probe_success(route, cfg)
            except UpstreamRouteError as exc:
                self.record_failure(
                    route,
                    cfg,
                    kind=exc.kind,
                    status=exc.status,
                    detail=exc.detail,
                    retry_after=exc.retry_after,
                )


ROUTE_POOL_RUNTIME = RoutePoolRuntime()


def probe_route(route: dict, *, timeout: int = 10) -> None:
    model = str(route.get("model") or "").strip() or DEFAULT_MODEL
    request_route_response_with_openai_retries(
        route,
        {
            "model": model,
            "input": "ping",
            "max_output_tokens": 1,
            "store": False,
        },
        timeout=timeout,
    )


def request_route_response_with_openai_retries(route: dict, responses_body: dict, *, timeout: int) -> tuple[bytes, str]:
    total = 1 + len(OPENAI_TRANSIENT_RETRY_DELAYS)
    last_exc: UpstreamRouteError | None = None
    for attempt in range(total):
        try:
            return request_route_response(route, responses_body, timeout=timeout)
        except UpstreamRouteError as exc:
            if exc.kind != "openai_retryable":
                raise
            last_exc = exc
            if attempt >= len(OPENAI_TRANSIENT_RETRY_DELAYS):
                break
            delay = float(OPENAI_TRANSIENT_RETRY_DELAYS[attempt])
            proxy_log(
                f"pool route openai retry {route_id(route)} "
                f"attempt={attempt + 1}/{total} delay={delay:g}s detail={exc.detail[:160]}"
            )
            if delay > 0:
                time.sleep(delay)
    if last_exc:
        raise last_exc
    return request_route_response(route, responses_body, timeout=timeout)


def fetch_route_models(route: dict, *, timeout: int = 30) -> tuple[bytes, str]:
    endpoint = models_endpoint(str(route.get("base_url") or ""))
    req = urlrequest.Request(endpoint, headers=route_headers(route, accept="application/json"))
    try:
        with fresh_urlopen(req, timeout=timeout) as resp:
            body = resp.read(4 * 1024 * 1024)
            return body, resp.headers.get("Content-Type") or "application/json"
    except urlerror.HTTPError as exc:
        body = exc.read(1024 * 1024)
        raise UpstreamRouteError(
            route=route,
            status=exc.code,
            body=body,
            content_type=exc.headers.get("Content-Type") or "application/json",
            kind=classify_upstream_status(
                exc.code,
                body,
                exc.headers.get("Content-Type") or "application/json",
                route=route,
            ),
            detail=http_error_detail(exc.code, exc.reason, body),
            retry_after=retry_after_seconds(exc.headers),
        ) from exc
    except Exception as exc:
        raise UpstreamRouteError(
            route=route,
            status=None,
            body=b"",
            content_type="application/json",
            kind=relay_route_error_kind(route),
            detail=f"{type(exc).__name__}: {exc}",
        ) from exc


def request_route_response(route: dict, responses_body: dict, *, timeout: int) -> tuple[bytes, str]:
    body = dict(responses_body)
    route_model = str(route.get("model") or "").strip()
    if route_model:
        body["model"] = route_model
    if route_protocol(route) == "chat":
        chat_body = responses_to_chat_request(body)
        endpoint = chat_completions_endpoint(str(route.get("base_url") or ""))
        data = json.dumps(chat_body, ensure_ascii=False).encode("utf-8")
        req = urlrequest.Request(
            endpoint,
            data=data,
            headers=route_headers(
                route,
                accept="text/event-stream" if chat_body.get("stream") else "application/json",
                content_type="application/json",
            ),
            method="POST",
        )
        try:
            with fresh_urlopen(req, timeout=timeout) as resp:
                upstream = resp.read()
                upstream_type = resp.headers.get("Content-Type") or ""
        except urlerror.HTTPError as exc:
            body_bytes = exc.read(1024 * 1024)
            raise UpstreamRouteError(
                route=route,
                status=exc.code,
                body=body_bytes,
                content_type=exc.headers.get("Content-Type") or "application/json",
                kind=classify_upstream_status(
                    exc.code,
                    body_bytes,
                    exc.headers.get("Content-Type") or "application/json",
                    route=route,
                ),
                detail=http_error_detail(exc.code, exc.reason, body_bytes),
                retry_after=retry_after_seconds(exc.headers),
            ) from exc
        except Exception as exc:
            raise UpstreamRouteError(
                route=route,
                status=None,
                body=b"",
                content_type="application/json",
                kind=relay_route_error_kind(route),
                detail=f"{type(exc).__name__}: {exc}",
            ) from exc
        raise_for_upstream_success_error(route, upstream, upstream_type)
        if "text/event-stream" in upstream_type:
            response = chat_sse_to_response_json(upstream)
        else:
            response = chat_completion_to_response(json.loads(upstream.decode("utf-8")))
        if body.get("stream"):
            return response_json_to_sse(response), "text/event-stream"
        return json.dumps(response, ensure_ascii=False).encode("utf-8"), "application/json"

    endpoint = responses_endpoint(str(route.get("base_url") or ""))
    data = json.dumps(body, ensure_ascii=False).encode("utf-8")
    req = urlrequest.Request(
        endpoint,
        data=data,
        headers=route_headers(
            route,
            accept="text/event-stream" if body.get("stream") else "application/json",
            content_type="application/json",
        ),
        method="POST",
    )
    try:
        with fresh_urlopen(req, timeout=timeout) as resp:
            upstream = resp.read()
            upstream_type = resp.headers.get("Content-Type") or "application/json"
    except urlerror.HTTPError as exc:
        body_bytes = exc.read(1024 * 1024)
        raise UpstreamRouteError(
            route=route,
            status=exc.code,
            body=body_bytes,
            content_type=exc.headers.get("Content-Type") or "application/json",
            kind=classify_upstream_status(
                exc.code,
                body_bytes,
                exc.headers.get("Content-Type") or "application/json",
                route=route,
            ),
            detail=http_error_detail(exc.code, exc.reason, body_bytes),
            retry_after=retry_after_seconds(exc.headers),
        ) from exc
    except Exception as exc:
        raise UpstreamRouteError(
            route=route,
            status=None,
            body=b"",
            content_type="application/json",
            kind=relay_route_error_kind(route),
            detail=f"{type(exc).__name__}: {exc}",
        ) from exc
    raise_for_upstream_success_error(route, upstream, upstream_type)
    return upstream, upstream_type


def pool_error_response(attempts: list[str], error: str = "no usable route") -> dict:
    return {
        "error": {
            "message": f"sub2cli route pool unavailable: {error}",
            "type": "sub2cli_route_pool_unavailable",
            "attempts": attempts,
        }
    }


class ResponsesProxyHandler(BaseHTTPRequestHandler):
    server_version = "sub2cli-responses-proxy/0.1"

    def log_message(self, fmt: str, *args: object) -> None:
        return

    def _send(self, status: int, body: bytes, content_type: str = "application/json") -> None:
        self.send_response(status)
        self.send_header("Content-Type", content_type)
        self.send_header("Content-Length", str(len(body)))
        self.end_headers()
        self.wfile.write(body)

    def _send_json(self, status: int, payload: object) -> None:
        self._send(status, json.dumps(payload, ensure_ascii=False).encode("utf-8"))

    def do_GET(self) -> None:
        path = self.path.split("?", 1)[0]
        if path == "/healthz":
            self._send_json(200, {"ok": True})
            return
        if path == "/poolz":
            try:
                cfg = _active_proxy_slot()
                self._send_json(200, {
                    "ok": True,
                    "pid": os.getpid(),
                    "port": PROTOCOL_PROXY_PORT,
                    "started_at": int(PROXY_STARTED_AT),
                    "uptime_seconds": max(0, int(time.time() - PROXY_STARTED_AT)),
                    **ROUTE_POOL_RUNTIME.snapshot(cfg),
                })
            except Exception as exc:
                self._send_json(200, {
                    "ok": False,
                    "pid": os.getpid(),
                    "port": PROTOCOL_PROXY_PORT,
                    "started_at": int(PROXY_STARTED_AT),
                    "uptime_seconds": max(0, int(time.time() - PROXY_STARTED_AT)),
                    "error": str(exc),
                })
            return
        if path not in {"/models", "/v1/models"}:
            self._send_json(404, {"error": {"message": "not found"}})
            return
        try:
            cfg = _active_proxy_slot()
            if cfg.get("protocol") == "pool":
                self._send_pool_models(cfg)
                return
            body, content_type = fetch_route_models(single_route_from_slot(cfg), timeout=30)
            self._send(200, body, content_type)
        except Exception as exc:
            self._send_json(502, {"error": {"message": str(exc)}})

    def do_POST(self) -> None:
        path = self.path.split("?", 1)[0]
        if path not in {"/responses", "/v1/responses", "/responses/compact", "/v1/responses/compact"}:
            self._send_json(404, {"error": {"message": "not found"}})
            return
        try:
            cfg = _active_proxy_slot()
            length = int(self.headers.get("Content-Length") or "0")
            body = self.rfile.read(length)
            responses_body = json.loads(body.decode("utf-8"))
            if cfg.get("protocol") == "pool":
                self._send_pool_response(cfg, responses_body)
                return
            try:
                upstream, content_type = request_route_response_with_openai_retries(
                    single_route_from_slot(cfg),
                    responses_body,
                    timeout=600,
                )
            except UpstreamRouteError as exc:
                self._send(exc.status or 502, exc.body or str(exc).encode("utf-8"), exc.content_type)
                return
            self._send(200, upstream, content_type)
        except Exception as exc:
            payload = {"error": {"message": str(exc), "type": "sub2cli_proxy_error"}}
            if self.headers.get("accept", "").lower().find("text/event-stream") >= 0:
                failed = _sse("response.failed", {"response": {"status": "failed", "error": payload["error"]}}) + "data: [DONE]\n\n"
                self._send(500, failed.encode("utf-8"), "text/event-stream")
            else:
                self._send_json(500, payload)

    def _send_pool_models(self, cfg: dict) -> None:
        attempted: list[str] = []
        excluded: set[str] = set()
        for _ in range(max(1, len(pool_routes(cfg)))):
            route, err = ROUTE_POOL_RUNTIME.choose(cfg, exclude_ids=excluded)
            if not route:
                self._send_json(503, pool_error_response(attempted, err or "no route"))
                return
            rid = route_id(route)
            attempted.append(rid)
            try:
                body, content_type = fetch_route_models(route, timeout=30)
                ROUTE_POOL_RUNTIME.record_success(route)
                self._send(200, body, content_type)
                return
            except UpstreamRouteError as exc:
                ROUTE_POOL_RUNTIME.record_failure(
                    route,
                    cfg,
                    kind=exc.kind,
                    status=exc.status,
                    detail=exc.detail,
                    retry_after=exc.retry_after,
                )
                if exc.kind == "client_error":
                    self._send(exc.status or 502, exc.body or str(exc).encode("utf-8"), exc.content_type)
                    return
                excluded.add(rid)
        self._send_json(503, pool_error_response(attempted))

    def _send_pool_response(self, cfg: dict, responses_body: dict) -> None:
        attempted: list[str] = []
        excluded: set[str] = set()
        policy = pool_policy(cfg)
        for _ in range(max(1, len(pool_routes(cfg)))):
            route, err = ROUTE_POOL_RUNTIME.choose(cfg, exclude_ids=excluded)
            if not route:
                self._send_json(503, pool_error_response(attempted, err or "no route"))
                return
            rid = route_id(route)
            attempted.append(rid)
            try:
                body, content_type = request_route_response_with_openai_retries(
                    route,
                    responses_body,
                    timeout=int(policy["request_timeout_seconds"]),
                )
                ROUTE_POOL_RUNTIME.record_success(route)
                self._send(200, body, content_type)
                return
            except UpstreamRouteError as exc:
                ROUTE_POOL_RUNTIME.record_failure(
                    route,
                    cfg,
                    kind=exc.kind,
                    status=exc.status,
                    detail=exc.detail,
                    retry_after=exc.retry_after,
                )
                if exc.kind == "client_error":
                    self._send(exc.status or 502, exc.body or str(exc).encode("utf-8"), exc.content_type)
                    return
                excluded.add(rid)
        self._send_json(503, pool_error_response(attempted))


def run_responses_proxy(port: int = PROTOCOL_PROXY_PORT) -> int:
    ROUTE_POOL_RUNTIME.start_monitor()
    server = ThreadingHTTPServer(("127.0.0.1", port), ResponsesProxyHandler)
    print(f"sub2cli responses proxy listening on http://127.0.0.1:{port}/v1", flush=True)
    server.serve_forever()
    return 0


def _self_command_prefix() -> list[str]:
    if getattr(sys, "frozen", False):
        return [sys.executable]
    return [sys.executable, str(Path(__file__).resolve())]


def protocol_proxy_healthy(port: int = PROTOCOL_PROXY_PORT) -> bool:
    try:
        with fresh_urlopen(f"http://127.0.0.1:{port}/healthz", timeout=1.5) as resp:
            return resp.status == 200
    except Exception:
        return False


def ensure_protocol_proxy(port: int = PROTOCOL_PROXY_PORT) -> bool:
    if protocol_proxy_healthy(port):
        return False
    PROTOCOL_PROXY_LOG.parent.mkdir(parents=True, exist_ok=True)
    env = {**os.environ, "PYINSTALLER_RESET_ENVIRONMENT": "1"}
    for key in list(env):
        if key.startswith("_PYI_"):
            env.pop(key, None)
    with PROTOCOL_PROXY_LOG.open("ab") as log:
        subprocess.Popen(
            [*_self_command_prefix(), "responses-proxy", "--port", str(port)],
            stdin=subprocess.DEVNULL,
            stdout=log,
            stderr=log,
            close_fds=True,
            start_new_session=True,
            env=env,
        )
    deadline = time.monotonic() + 12.0
    while time.monotonic() < deadline:
        time.sleep(0.2)
        if protocol_proxy_healthy(port):
            return True
    return False


def protocol_proxy_pids(port: int = PROTOCOL_PROXY_PORT) -> list[int]:
    try:
        proc = subprocess.run(
            ["lsof", "-nP", f"-iTCP:{port}", "-sTCP:LISTEN", "-t"],
            stdout=subprocess.PIPE,
            stderr=subprocess.DEVNULL,
            text=True,
            timeout=3,
        )
    except Exception:
        return []
    pids: list[int] = []
    for line in proc.stdout.splitlines():
        try:
            pid = int(line.strip())
        except ValueError:
            continue
        if pid > 0 and pid not in pids:
            pids.append(pid)
    return pids


def process_group_pids_for(pids: list[int]) -> list[int]:
    wanted = {pid for pid in pids if pid > 0}
    if not wanted:
        return []
    try:
        proc = subprocess.run(
            ["ps", "-axo", "pid=,pgid=,command="],
            stdout=subprocess.PIPE,
            stderr=subprocess.DEVNULL,
            text=True,
            timeout=3,
        )
    except Exception:
        return sorted(wanted)
    pid_to_pgid: dict[int, int] = {}
    pid_to_command: dict[int, str] = {}
    for line in proc.stdout.splitlines():
        parts = line.split(None, 2)
        if len(parts) < 2:
            continue
        try:
            pid = int(parts[0])
            pid_to_pgid[pid] = int(parts[1])
            pid_to_command[pid] = parts[2] if len(parts) >= 3 else ""
        except ValueError:
            continue
    groups = {pid_to_pgid[pid] for pid in wanted if pid in pid_to_pgid}
    if not groups:
        return sorted(wanted)
    expanded = {
        pid for pid, pgid in pid_to_pgid.items()
        if pgid in groups and "responses-proxy" in pid_to_command.get(pid, "")
    }
    return sorted(expanded or wanted)


def stop_protocol_proxy(port: int = PROTOCOL_PROXY_PORT, *, timeout: float = 5.0) -> bool:
    pids = protocol_proxy_pids(port)
    if not pids:
        return True
    current = os.getpid()
    for sig in (signal.SIGTERM, signal.SIGKILL):
        targets = [pid for pid in process_group_pids_for(pids) if pid != current]
        for pid in targets:
            if pid == current:
                continue
            try:
                os.kill(pid, sig)
            except ProcessLookupError:
                pass
            except PermissionError:
                proxy_log(f"pool monitor proxy stop permission denied pid={pid}")
        deadline = time.monotonic() + timeout
        while time.monotonic() < deadline:
            remaining = [pid for pid in protocol_proxy_pids(port) if pid != current]
            if not remaining:
                return True
            time.sleep(0.15)
        pids = [pid for pid in protocol_proxy_pids(port) if pid != current]
        if not pids:
            return True
    return not [pid for pid in protocol_proxy_pids(port) if pid != current]


def cmd_restart_proxy(port: int = PROTOCOL_PROXY_PORT) -> int:
    stopped = stop_protocol_proxy(port)
    if not stopped:
        fail(f"本地代理停止失败，请检查端口 {port} 的监听进程")
    started = ensure_protocol_proxy(port)
    if started or protocol_proxy_healthy(port):
        print(f"本地代理已重启: http://127.0.0.1:{port}/v1")
        return 0
    fail(f"本地代理启动失败，请查看 {PROTOCOL_PROXY_LOG}")
    return 1


