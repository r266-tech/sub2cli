# ==================== File lock ====================

class LockBusy(RuntimeError):
    """Another sub2cli-inject process is holding the lock."""


class Sub2cliLock:
    """Advisory exclusive file lock — prevents concurrent ~/.codex mutations.

    Wrap any cmd_switch / cmd_relay / cmd_oauth / cmd_init / cmd_rollback in
    `with Sub2cliLock(): ...`. Raises LockBusy if another process holds it.
    """

    _depth = 0

    def __init__(self, path: Path = LOCK_FILE, *, timeout: float = 0.0) -> None:
        self.path = path
        self.timeout = timeout
        self._fd: int | None = None
        self._nested = False

    def __enter__(self) -> "Sub2cliLock":
        if Sub2cliLock._depth > 0:
            Sub2cliLock._depth += 1
            self._nested = True
            return self
        self.path.parent.mkdir(parents=True, exist_ok=True)
        self._fd = os.open(str(self.path), os.O_CREAT | os.O_WRONLY, 0o600)
        deadline = time.time() + self.timeout if self.timeout > 0 else None
        while True:
            try:
                fcntl.flock(self._fd, fcntl.LOCK_EX | fcntl.LOCK_NB)
                os.ftruncate(self._fd, 0)
                os.write(self._fd, f"pid={os.getpid()} t={int(time.time())}\n".encode())
                Sub2cliLock._depth = 1
                return self
            except OSError as exc:
                if exc.errno not in (errno.EAGAIN, errno.EACCES):
                    os.close(self._fd)
                    self._fd = None
                    raise
                if deadline is None or time.time() >= deadline:
                    os.close(self._fd)
                    self._fd = None
                    raise LockBusy(
                        f"another sub2cli-inject is running (lock: {self.path})"
                    )
                time.sleep(0.1)

    def __exit__(self, *_exc: object) -> None:
        if self._nested:
            Sub2cliLock._depth = max(0, Sub2cliLock._depth - 1)
            return
        Sub2cliLock._depth = 0
        if self._fd is not None:
            try:
                fcntl.flock(self._fd, fcntl.LOCK_UN)
            finally:
                os.close(self._fd)
                self._fd = None


def _fsync_dir(path: Path) -> None:
    """Best-effort fsync of a directory so a rename inside it is durable.

    Some platforms/filesystems reject O_DIRECTORY fsync; ignore those.
    """
    try:
        dir_fd = os.open(str(path), os.O_RDONLY)
    except OSError:
        return
    try:
        os.fsync(dir_fd)
    except OSError:
        pass
    finally:
        os.close(dir_fd)


def durable_write_bytes(path: Path, data: bytes, *, mode: int = 0o600) -> None:
    """Crash-safe credential write: tmp created 0600, fsync'd, atomically renamed,
    then the parent dir is fsync'd so the rename survives power loss.

    This is the single primitive every credential/state writer routes through.
    Creating the tmp with O_EXCL|mode also closes the world-readable window that
    write_bytes()+chmod() would otherwise leave between create and chmod.
    """
    path.parent.mkdir(parents=True, exist_ok=True)
    tmp = path.with_name(f"{path.name}.{os.getpid()}.{time.time_ns()}.tmp")
    fd = os.open(str(tmp), os.O_WRONLY | os.O_CREAT | os.O_EXCL, mode)
    try:
        with os.fdopen(fd, "wb") as fh:
            fh.write(data)
            fh.flush()
            os.fsync(fh.fileno())
        # fdopen took ownership of fd; ensure mode wasn't loosened by umask.
        os.chmod(tmp, mode)
        os.replace(tmp, path)
    except Exception:
        if tmp.exists() or tmp.is_symlink():
            try:
                tmp.unlink()
            except OSError:
                pass
        raise
    _fsync_dir(path.parent)


def atomic_write_json(path: Path, data: dict, *, mode: int = 0o600) -> None:
    durable_write_bytes(
        path,
        (json.dumps(data, indent=2, ensure_ascii=False) + "\n").encode("utf-8"),
        mode=mode,
    )


def atomic_write_text(path: Path, text: str, *, mode: int = 0o600) -> None:
    durable_write_bytes(path, text.encode("utf-8"), mode=mode)


def atomic_write_bytes(path: Path, data: bytes, *, mode: int = 0o600) -> None:
    durable_write_bytes(path, data, mode=mode)


def atomic_symlink(link_path: Path, target: Path) -> None:
    """Replace link_path with a symlink to target. Used for APP_PROFILE.

    AUTH_JSON is no longer symlinked — codex CLI/App atomic-writes auth.json
    when refreshing tokens, which would replace any symlink with a real file
    (cat-and-mouse). Use copy_auth_atomic() instead for auth.json.
    """
    if link_path.exists() and not link_path.is_symlink():
        fail(f"{link_path} is a real file/dir, not a symlink. Run init first or move it aside manually.")
    link_path.parent.mkdir(parents=True, exist_ok=True)
    target.parent.mkdir(parents=True, exist_ok=True)
    tmp = link_path.with_name(f"{link_path.name}.{os.getpid()}.{time.time_ns()}.tmp")
    if tmp.exists() or tmp.is_symlink():
        tmp.unlink()
    tmp.symlink_to(target)
    os.replace(tmp, link_path)


# ==================== auth.json as a real file (no longer symlinked) ====================

def read_auth_bytes() -> bytes | None:
    """Return AUTH_JSON bytes regardless of whether it's a real file or symlink.

    Returns None if AUTH_JSON doesn't exist or can't be read.
    """
    if not AUTH_JSON.exists():
        return None
    try:
        return AUTH_JSON.read_bytes()
    except OSError:
        return None


def copy_auth_atomic(src: Path, *, mode: int = 0o600) -> None:
    """Atomic-write src's content to AUTH_JSON as a real file (replacing any
    existing symlink or file). Used by cmd_switch when changing slots.
    """
    if not src.exists():
        fail(f"slot auth file missing: {src}")
    data = src.read_bytes()
    durable_write_bytes(AUTH_JSON, data, mode=mode)


def flush_auth_to_slot(slot_auth_file: Path, *, mode: int = 0o600) -> bool:
    """Save current AUTH_JSON content back to its slot's auth_file so that
    in-flight OAuth refresh tokens written by codex aren't lost on switch.

    Returns True if a flush was performed (content changed), False if no-op.
    """
    cur = read_auth_bytes()
    if cur is None:
        return False
    slot_auth_file.parent.mkdir(parents=True, exist_ok=True)
    if slot_auth_file.exists():
        try:
            if slot_auth_file.read_bytes() == cur:
                return False
        except OSError:
            pass
    durable_write_bytes(slot_auth_file, cur, mode=mode)
    return True


def auth_content_equals(slot_auth_file: Path) -> bool:
    """Check if AUTH_JSON content matches a slot's auth_file content."""
    if not AUTH_JSON.exists() or not slot_auth_file.exists():
        return False
    try:
        return AUTH_JSON.read_bytes() == slot_auth_file.read_bytes()
    except OSError:
        return False


def symlink_points_to(link_path: Path, target: Path) -> bool:
    if not link_path.is_symlink():
        return False
    try:
        return Path(os.readlink(link_path)).expanduser().resolve(strict=False) == target.resolve(strict=False)
    except OSError:
        return False


def path_present(path: Path) -> bool:
    return path.exists() or path.is_symlink()


def lexical_abs(path: Path) -> Path:
    return Path(os.path.abspath(os.path.expanduser(str(path))))


def path_key(path: Path) -> str:
    return str(lexical_abs(path))


def is_within(path: Path, base: Path) -> bool:
    try:
        lexical_abs(path).relative_to(lexical_abs(base))
        return True
    except ValueError:
        return False


def safe_unlink_file(path: Path) -> bool:
    if not path_present(path):
        return False
    if path.is_dir() and not path.is_symlink():
        fail(f"refuse to unlink directory as file: {path}")
    path.unlink()
    return True


def safe_remove_profile_dir(path: Path) -> bool:
    if not path_present(path):
        return False
    if not is_within(path, APP_SUPPORT):
        fail(f"refuse to remove profile outside Application Support: {path}")
    if not lexical_abs(path).name.startswith("Codex."):
        fail(f"refuse to remove non-slot Codex profile: {path}")
    if path.is_symlink() or path.is_file():
        path.unlink()
        return True
    if path.is_dir():
        shutil.rmtree(path)
        return True
    return False


def toml_quote(value: str) -> str:
    return json.dumps(str(value), ensure_ascii=False)[1:-1]


def normalize_base_url(value: str) -> str:
    base_url = value.strip().rstrip("/")
    if base_url.lower().endswith("/v1"):
        base_url = base_url[:-3].rstrip("/")
    if not base_url.startswith(("http://", "https://")):
        fail(f"base_url must start with http:// or https://: {value!r}")
    return base_url


def slot_from_url(base_url: str) -> str:
    host = urlparse.urlparse(base_url).hostname or ""
    host = host.removeprefix("www.").removeprefix("api.")
    slot = host.split(".")[0] if host else ""
    if not slot:
        fail(f"could not derive a slot name from {base_url!r}; pass --slot")
    return validate_slot(slot)


def validate_slot(slot: str) -> str:
    slot = slot.strip().lower()
    if not re.fullmatch(r"[a-z0-9][a-z0-9_-]{0,30}", slot):
        fail(f"invalid slot {slot!r}; use lowercase a-z, 0-9, _ or -, max 31 chars")
    return slot


def load_slots(required: bool = True) -> dict:
    if not SLOTS_FILE.exists():
        if required:
            fail(f"{SLOTS_FILE} not found. Run: sub2cli-inject init")
        return {"version": 1, "current": None, "app_history_slot": None, "slots": {}}
    try:
        data = json.loads(SLOTS_FILE.read_text())
    except json.JSONDecodeError as exc:
        fail(f"{SLOTS_FILE} is invalid JSON: {exc}")
    data.setdefault("version", 1)
    data.setdefault("slots", {})
    return data


def save_slots(data: dict) -> None:
    atomic_write_json(SLOTS_FILE, data)


def _parse_pid_lines(text: str) -> list[int]:
    pids: list[int] = []
    for line in text.splitlines():
        value = line.strip()
        if not value:
            continue
        try:
            pids.append(int(value))
        except ValueError:
            continue
    return pids


def codex_main_pids() -> list[int]:
    proc = subprocess.run(["pgrep", "-x", "Codex"], capture_output=True, text=True)
    return _parse_pid_lines(proc.stdout)


def codex_app_main_pids() -> list[int]:
    """Find the visible Codex.app main process even when pgrep -x misses it."""
    markers = {
        str(CODEX_APP_BUNDLE / "Contents" / "MacOS" / "Codex"),
        str((CODEX_APP_BUNDLE / "Contents" / "MacOS" / "Codex").resolve(strict=False)),
    }
    proc = subprocess.run(["ps", "-axww", "-o", "pid=,command="], capture_output=True, text=True)
    pids: set[int] = set()
    for line in proc.stdout.splitlines():
        stripped = line.strip()
        if not stripped:
            continue
        parts = stripped.split(maxsplit=1)
        if len(parts) != 2:
            continue
        raw_pid, command = parts
        if not any(marker in command for marker in markers):
            continue
        try:
            pids.add(int(raw_pid))
        except ValueError:
            continue
    return sorted(pid for pid in pids if pid != os.getpid())


def codex_bundle_pids() -> list[int]:
    """Return target Codex.app process ids (main + bundle helpers).

    Match on argv0 being *inside* the bundle, not a bare substring anywhere in
    the command line. This kills the app's own executables (main + Helper procs
    launched from Contents/) but never an unrelated process that merely mentions
    the bundle path in its arguments, e.g. `tail -f …/Contents/MacOS/Codex.log`
    or an editor/build command operating on a file in the bundle.
    """
    pids: set[int] = set(codex_main_pids())
    prefixes = {
        str(CODEX_APP_BUNDLE / "Contents") + os.sep,
        str((CODEX_APP_BUNDLE / "Contents").resolve(strict=False)) + os.sep,
    }
    proc = subprocess.run(["ps", "-axww", "-o", "pid=,command="], capture_output=True, text=True)
    for line in proc.stdout.splitlines():
        stripped = line.strip()
        if not stripped:
            continue
        parts = stripped.split(maxsplit=1)
        if len(parts) != 2:
            continue
        raw_pid, command = parts
        argv0 = command.split()[0] if command.split() else ""
        if not any(argv0.startswith(prefix) for prefix in prefixes):
            continue
        try:
            pids.add(int(raw_pid))
        except ValueError:
            continue
    return sorted(pid for pid in pids if pid != os.getpid())


def codex_running() -> bool:
    return bool(codex_main_pids() or codex_app_main_pids())


def wait_codex_exit(timeout: float) -> bool:
    deadline = time.time() + timeout
    while time.time() < deadline:
        if not codex_running():
            return True
        time.sleep(0.25)
    return not codex_running()


def signal_pids(pids: list[int], sig: signal.Signals) -> None:
    for pid in sorted(set(pids)):
        if pid == os.getpid():
            continue
        try:
            os.kill(pid, sig)
        except ProcessLookupError:
            pass
        except PermissionError:
            pass


def pid_alive(pid: int) -> bool:
    try:
        os.kill(pid, 0)
        return True
    except ProcessLookupError:
        return False
    except PermissionError:
        return True


def codex_cli_app_server_control_pids() -> list[int]:
    """Find the persistent CLI app-server that owns app-server-control.sock.

    Codex App has its own stdio app-server processes. Those should not be
    touched here; the control socket is used by Terminal/SSH Codex sessions and
    can cache the pre-switch auth mode until restarted.
    """
    pids: set[int] = set()
    if CODEX_APP_SERVER_CONTROL_SOCKET.exists():
        try:
            proc = subprocess.run(
                ["lsof", "-t", "-nP", str(CODEX_APP_SERVER_CONTROL_SOCKET)],
                capture_output=True,
                text=True,
                timeout=2,
            )
            pids.update(_parse_pid_lines(proc.stdout))
        except (OSError, subprocess.TimeoutExpired):
            pass
    if pids:
        return sorted(pid for pid in pids if pid != os.getpid())

    proc = subprocess.run(["ps", "-axww", "-o", "pid=,command="], capture_output=True, text=True)
    for line in proc.stdout.splitlines():
        stripped = line.strip()
        if not stripped:
            continue
        parts = stripped.split(maxsplit=1)
        if len(parts) != 2:
            continue
        raw_pid, command = parts
        if " app-server " not in f" {command} ":
            continue
        if "--listen unix://" not in command:
            continue
        if "app-server-broker" in command:
            continue
        try:
            pids.add(int(raw_pid))
        except ValueError:
            continue
    return sorted(pid for pid in pids if pid != os.getpid())


def wait_cli_app_server_exit(pids: list[int], timeout: float) -> bool:
    deadline = time.time() + timeout
    targets = set(pids)
    while time.time() < deadline:
        holders = set(codex_cli_app_server_control_pids())
        alive = {pid for pid in targets if pid_alive(pid)}
        if not holders and not alive:
            return True
        time.sleep(0.2)
    holders = set(codex_cli_app_server_control_pids())
    alive = {pid for pid in targets if pid_alive(pid)}
    return not holders and not alive


def stop_codex_cli_app_server(timeout: float = 4.0) -> bool:
    pids = codex_cli_app_server_control_pids()
    if not pids:
        if CODEX_APP_SERVER_CONTROL_SOCKET.exists():
            try:
                CODEX_APP_SERVER_CONTROL_SOCKET.unlink()
            except OSError:
                pass
        return False
    signal_pids(pids, signal.SIGTERM)
    stopped = wait_cli_app_server_exit(pids, timeout)
    if not stopped:
        signal_pids(pids, signal.SIGKILL)
        stopped = wait_cli_app_server_exit(pids, 2.0)
    if stopped and CODEX_APP_SERVER_CONTROL_SOCKET.exists():
        try:
            CODEX_APP_SERVER_CONTROL_SOCKET.unlink()
        except OSError:
            pass
    return stopped


def quit_codex(timeout: float = 8.0) -> bool:
    if not codex_running():
        return False
    try:
        subprocess.run(
            ["osascript", "-e", 'tell application id "com.openai.codex" to quit'],
            check=False,
            timeout=min(timeout, 4.0),
            capture_output=True,
            text=True,
        )
    except subprocess.TimeoutExpired:
        pass
    if wait_codex_exit(timeout):
        return True
    if FORCE_QUIT_CODEX:
        print("  Codex.app 退出超时，正在强制结束后继续…", file=sys.stderr)
        signal_pids(codex_bundle_pids(), signal.SIGTERM)
        if wait_codex_exit(3.0):
            return True
        signal_pids(codex_bundle_pids(), signal.SIGKILL)
        if wait_codex_exit(3.0):
            return True
    fail("Codex.app 退出超时。请手动退出 Codex App 后重试。")
    return True


def wait_port(host: str, port: int, timeout: float = 8.0) -> bool:
    deadline = time.time() + timeout
    while time.time() < deadline:
        try:
            with socket.create_connection((host, port), timeout=0.5):
                return True
        except OSError:
            time.sleep(0.25)
    return False


def _read_devtools_targets_from_port(port: int) -> list[dict]:
    try:
        with urlrequest.urlopen(f"http://127.0.0.1:{port}/json", timeout=1.0) as resp:
            payload = json.loads(resp.read(2 * 1024 * 1024))
    except Exception:
        return []
    return payload if isinstance(payload, list) else []


def devtools_active_port_paths() -> list[Path]:
    paths = [APP_PROFILE / "DevToolsActivePort"]
    try:
        data = load_slots(required=False)
        for cfg in (data.get("slots") or {}).values():
            raw = str((cfg or {}).get("app_profile_dir") or "").strip()
            if raw:
                paths.append(Path(raw).expanduser() / "DevToolsActivePort")
    except Exception:
        pass
    result: list[Path] = []
    seen: set[str] = set()
    for path in paths:
        key = str(path)
        if key in seen:
            continue
        seen.add(key)
        result.append(path)
    return result


def remove_stale_devtools_active_port_files() -> None:
    for path in devtools_active_port_paths():
        try:
            path.unlink()
        except FileNotFoundError:
            pass
        except OSError:
            pass


def devtools_active_port_candidates() -> list[int]:
    ports: list[int] = []
    for path in devtools_active_port_paths():
        try:
            first = path.read_text(errors="replace").splitlines()[0].strip()
            port = int(first)
        except Exception:
            continue
        if 0 < port < 65536 and port not in ports:
            ports.append(port)
    return ports


def codex_debug_port_candidates() -> list[int]:
    ports = [PREFERRED_CODEX_DEBUG_PORT, *devtools_active_port_candidates()]
    result: list[int] = []
    for port in ports:
        if 0 < int(port) < 65536 and int(port) not in result:
            result.append(int(port))
    return result


def choose_codex_debug_port() -> int:
    preferred = PREFERRED_CODEX_DEBUG_PORT
    if 0 < preferred < 65536:
        try:
            with socket.socket(socket.AF_INET, socket.SOCK_STREAM) as sock:
                sock.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
                sock.bind(("127.0.0.1", preferred))
                return preferred
        except OSError:
            pass
    with socket.socket(socket.AF_INET, socket.SOCK_STREAM) as sock:
        sock.bind(("127.0.0.1", 0))
        return int(sock.getsockname()[1])


def wait_devtools_targets(port: int | None = None, timeout: float = 10.0) -> list[dict]:
    deadline = time.time() + timeout
    while time.time() < deadline:
        targets = read_devtools_targets(port)
        if targets:
            return targets
        time.sleep(0.25)
    return []


def launch_codex() -> bool:
    if ENHANCEMENTS_ENABLED and CODEX_APP_BUNDLE.exists():
        debug_port = choose_codex_debug_port()
        remove_stale_devtools_active_port_files()
        args = [
            f"--remote-debugging-port={debug_port}",
            "--remote-debugging-address=127.0.0.1",
            f"--remote-allow-origins=http://127.0.0.1:{debug_port}",
        ]
        commands: list[list[str]] = [
            ["open", "-W", "-a", str(CODEX_APP_BUNDLE), "--args", *args],
        ]
        for command in commands:
            try:
                subprocess.Popen(
                    command,
                    stdout=subprocess.DEVNULL,
                    stderr=subprocess.DEVNULL,
                    start_new_session=True,
                )
            except OSError:
                continue
            if wait_devtools_targets(debug_port, timeout=12.0):
                inject_codex_app_enhancements(debug_port=debug_port)
                return True
            quit_codex(timeout=4.0)
            remove_stale_devtools_active_port_files()
        print(f"  ⚠️  Codex App 已启动，但调试端口 {debug_port} 未就绪", file=sys.stderr)
        return False
    subprocess.Popen(["open", "-a", "Codex"], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    return False


def find_codex_cli() -> str | None:
    candidates: list[str] = []
    path_hit = shutil.which("codex")
    if path_hit:
        candidates.append(path_hit)
    candidates.extend(os.path.expanduser(p) for p in CODEX_CLI_FALLBACKS)
    for pattern in CODEX_CLI_FALLBACK_GLOBS:
        candidates.extend(sorted(glob.glob(os.path.expanduser(pattern))))
    candidates.append(str(CODEX_APP_BUNDLED_CLI))

    seen: set[str] = set()
    for candidate in candidates:
        real = os.path.realpath(candidate)
        if real in seen:
            continue
        seen.add(real)
        if os.path.isfile(candidate) and os.access(candidate, os.X_OK):
            return candidate
    return None


def launch_codex_native() -> bool:
    if codex_running():
        quit_codex()
    remove_stale_devtools_active_port_files()
    command = ["open", str(CODEX_APP_BUNDLE)] if CODEX_APP_BUNDLE.exists() else ["open", "-a", "Codex"]
    subprocess.Popen(command, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, start_new_session=True)
    return True


def current_slot_config() -> dict | None:
    try:
        data = load_slots(required=False)
    except SystemExit:
        return None
    current = data.get("current")
    slots = data.get("slots") or {}
    if current in slots:
        return slots[current]
    return None


def current_model_catalog(*, refresh: bool = True) -> dict:
    try:
        data = load_slots(required=False)
    except SystemExit:
        data = {"slots": {}}
    current = data.get("current")
    slots = data.get("slots") or {}
    cfg = slots.get(current, {}) if current else {}
    catalog = relay_model_catalog_for_slot(cfg, refresh=refresh)
    models = catalog.get("models") if isinstance(catalog, dict) else None
    if current and cfg.get("mode") == "relay" and isinstance(models, list) and models:
        next_cfg = dict(cfg)
        changed = False
        if next_cfg.get("models") != models:
            next_cfg["models"] = models
            changed = True
        default_model = str(catalog.get("default_model") or catalog.get("model") or "").strip()
        if default_model and next_cfg.get("model_source") != "manual" and next_cfg.get("model") != default_model:
            next_cfg["model"] = default_model
            next_cfg["model_source"] = "auto"
            changed = True
        if changed:
            slots[current] = next_cfg
            data["slots"] = slots
            try:
                save_slots(data)
            except Exception:
                pass
    return catalog


