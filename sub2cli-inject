    return f"{cleaned}/v1/chat/completions"


def _response_id_from_chat(chat_id: str | None) -> str:
    chat_id = (chat_id or "sub2cli_compat").strip() or "sub2cli_compat"
    return chat_id if chat_id.startswith("resp_") else f"resp_{chat_id}"


def _message_content_text(content: object) -> str:
    if isinstance(content, str):
        return content
    parts: list[str] = []
    if isinstance(content, list):
        for item in content:
            if isinstance(item, str):
                parts.append(item)
            elif isinstance(item, dict):
                raw = item.get("text") or item.get("content") or item.get("input")
                if isinstance(raw, str):
                    parts.append(raw)
    elif isinstance(content, dict):
        raw = content.get("text") or content.get("content") or content.get("input")
        if isinstance(raw, str):
            parts.append(raw)
    return "\n".join(part for part in parts if part)


def _append_responses_input(value: object, messages: list[dict]) -> None:
    if isinstance(value, str):
        messages.append({"role": "user", "content": value})
        return
    if not isinstance(value, list):
        return
    for item in value:
        if not isinstance(item, dict):
            continue
        item_type = str(item.get("type") or "")
        if item_type == "function_call_output":
            call_id = str(item.get("call_id") or item.get("id") or "").strip()
            output = item.get("output")
            messages.append({
                "role": "tool",
                "tool_call_id": call_id or "call_compat",
                "content": output if isinstance(output, str) else json.dumps(output, ensure_ascii=False),
            })
            continue
        if item_type == "function_call":
            call_id = str(item.get("call_id") or item.get("id") or "").strip() or "call_compat"
            name = str(item.get("name") or "").strip() or "tool"
            arguments = item.get("arguments")
            if not isinstance(arguments, str):
                arguments = json.dumps(arguments if arguments is not None else {}, ensure_ascii=False)
            messages.append({
                "role": "assistant",
                "content": None,
                "tool_calls": [{
                    "id": call_id,
                    "type": "function",
                    "function": {"name": name, "arguments": arguments},
                }],
            })
            continue
        role = str(item.get("role") or "user").strip() or "user"
        if role == "developer":
            role = "system"
        if role not in {"system", "user", "assistant", "tool"}:
            role = "user"
        text = _message_content_text(item.get("content"))
        if text:
            messages.append({"role": role, "content": text})


def responses_to_chat_request(body: dict) -> dict:
    result: dict = {}
    if body.get("model") is not None:
        result["model"] = body.get("model")
    messages: list[dict] = []
    instructions = _message_content_text(body.get("instructions"))
    if instructions:
        messages.append({"role": "system", "content": instructions})
    _append_responses_input(body.get("input"), messages)
    if not messages:
        messages.append({"role": "user", "content": ""})
    result["messages"] = messages
    if body.get("max_output_tokens") is not None:
        result["max_tokens"] = body.get("max_output_tokens")
    for key in ("max_tokens", "temperature", "top_p", "stream"):
        if body.get(key) is not None:
            result[key] = body.get(key)
    if result.get("stream"):
        result["stream_options"] = {"include_usage": True}

    tools: list[dict] = []
    for tool in body.get("tools") or []:
        if not isinstance(tool, dict):
            continue
        name = str(tool.get("name") or tool.get("function", {}).get("name") or "").strip()
        if not name:
            continue
        params = tool.get("parameters") or tool.get("input_schema") or tool.get("schema") or {}
        if not isinstance(params, dict):
            params = {}
        params.setdefault("type", "object")
        params.setdefault("properties", {})
        fn = {
            "name": name,
            "description": str(tool.get("description") or ""),
            "parameters": params,
        }
        tools.append({"type": "function", "function": fn})
    if tools:
        result["tools"] = tools
        if body.get("parallel_tool_calls") is not None:
            result["parallel_tool_calls"] = body.get("parallel_tool_calls")
    return result


def _usage_to_responses(usage: object) -> dict:
    usage = usage if isinstance(usage, dict) else {}
    prompt = int(usage.get("prompt_tokens") or usage.get("input_tokens") or 0)
    completion = int(usage.get("completion_tokens") or usage.get("output_tokens") or 0)
    total = int(usage.get("total_tokens") or (prompt + completion))
    details = usage.get("completion_tokens_details") if isinstance(usage.get("completion_tokens_details"), dict) else {}
    return {
        "input_tokens": prompt,
        "output_tokens": completion,
        "total_tokens": total,
        "output_tokens_details": {
            "reasoning_tokens": int(details.get("reasoning_tokens") or 0),
        },
    }


def chat_completion_to_response(body: dict) -> dict:
    choices = body.get("choices") if isinstance(body.get("choices"), list) else []
    first = choices[0] if choices and isinstance(choices[0], dict) else {}
    msg = first.get("message") if isinstance(first.get("message"), dict) else {}
    chat_id = str(body.get("id") or "chatcmpl_sub2cli")
    response_id = _response_id_from_chat(chat_id)
    model = str(body.get("model") or msg.get("model") or "")
    output: list[dict] = []
    reasoning = msg.get("reasoning_content")
    if isinstance(reasoning, str) and reasoning:
        output.append({
            "id": f"rs_{chat_id}",
            "type": "reasoning",
            "summary": [{"type": "summary_text", "text": reasoning}],
            "reasoning_content": reasoning,
        })
    content = msg.get("content")
    if isinstance(content, list):
        content = _message_content_text(content)
    if isinstance(content, str) and content:
        output.append({
            "id": f"msg_{chat_id}",
            "type": "message",
            "status": "completed",
            "role": "assistant",
            "content": [{"type": "output_text", "text": content, "annotations": []}],
        })
    for idx, call in enumerate(msg.get("tool_calls") or []):
        if not isinstance(call, dict):
            continue
        fn = call.get("function") if isinstance(call.get("function"), dict) else {}
        output.append({
            "id": f"fc_{idx}_{chat_id}",
            "type": "function_call",
            "status": "completed",
            "call_id": str(call.get("id") or f"call_{idx}"),
            "name": str(fn.get("name") or "tool"),
            "arguments": fn.get("arguments") if isinstance(fn.get("arguments"), str) else "{}",
        })
    return {
        "id": response_id,
        "object": "response",
        "created_at": int(body.get("created") or time.time()),
        "status": "completed",
        "model": model,
        "output": output,
        "usage": _usage_to_responses(body.get("usage")),
    }


def _sse(event: str, data: object) -> str:
    return f"event: {event}\ndata: {json.dumps(data, ensure_ascii=False, separators=(',', ':'))}\n\n"


def response_json_to_sse(response: dict) -> bytes:
    chunks: list[str] = []
    chunks.append(_sse("response.created", {"response": {k: v for k, v in response.items() if k != "output"}}))
    chunks.append(_sse("response.in_progress", {"response": {**response, "status": "in_progress", "output": []}}))
    for output_index, item in enumerate(response.get("output") or []):
        chunks.append(_sse("response.output_item.added", {"output_index": output_index, "item": item}))
        if item.get("type") == "message":
            content = (item.get("content") or [{}])[0]
            text = str(content.get("text") or "")
            chunks.append(_sse("response.content_part.added", {
                "item_id": item.get("id"), "output_index": output_index, "content_index": 0,
                "part": {"type": "output_text", "text": "", "annotations": []},
            }))
            if text:
                chunks.append(_sse("response.output_text.delta", {
                    "item_id": item.get("id"), "output_index": output_index, "content_index": 0,
                    "delta": text,
                }))
            chunks.append(_sse("response.output_text.done", {
                "item_id": item.get("id"), "output_index": output_index, "content_index": 0,
                "text": text,
            }))
            chunks.append(_sse("response.content_part.done", {
                "item_id": item.get("id"), "output_index": output_index, "content_index": 0,
                "part": {"type": "output_text", "text": text, "annotations": []},
            }))
        elif item.get("type") == "function_call":
            args = str(item.get("arguments") or "")
            if args:
                chunks.append(_sse("response.function_call_arguments.delta", {
                    "item_id": item.get("id"), "output_index": output_index, "delta": args,
                }))
            chunks.append(_sse("response.function_call_arguments.done", {
                "item_id": item.get("id"), "output_index": output_index, "arguments": args,
            }))
        chunks.append(_sse("response.output_item.done", {"output_index": output_index, "item": item}))
    chunks.append(_sse("response.completed", {"response": response}))
    chunks.append("data: [DONE]\n\n")
    return "".join(chunks).encode("utf-8")


def chat_sse_to_response_json(raw: bytes) -> dict:
    content = ""
    reasoning = ""
    chat_id = "chatcmpl_sub2cli"
    model = ""
    created = int(time.time())
    usage: dict = {}
    tools: dict[int, dict] = {}
    for raw_line in raw.decode("utf-8", errors="replace").splitlines():
        line = raw_line.strip()
        if not line.startswith("data:"):
            continue
        data = line[5:].strip()
        if not data or data == "[DONE]":
            continue
        try:
            payload = json.loads(data)
        except ValueError:
            continue
        if isinstance(payload.get("error"), dict):
            raise RuntimeError(payload["error"].get("message") or json.dumps(payload["error"], ensure_ascii=False))
        chat_id = str(payload.get("id") or chat_id)
        model = str(payload.get("model") or model)
        created = int(payload.get("created") or created)
        if isinstance(payload.get("usage"), dict):
            usage = payload["usage"]
        choices = payload.get("choices") if isinstance(payload.get("choices"), list) else []
        for choice in choices:
            if not isinstance(choice, dict):
                continue
            delta = choice.get("delta") if isinstance(choice.get("delta"), dict) else {}
            if isinstance(delta.get("content"), str):
                content += delta["content"]
            if isinstance(delta.get("reasoning_content"), str):
                reasoning += delta["reasoning_content"]
            for tc in delta.get("tool_calls") or []:
                if not isinstance(tc, dict):
                    continue
                idx = int(tc.get("index") or 0)
                state = tools.setdefault(idx, {"id": "", "name": "", "arguments": ""})
                if tc.get("id"):
                    state["id"] = str(tc.get("id"))
                fn = tc.get("function") if isinstance(tc.get("function"), dict) else {}
                if fn.get("name"):
                    state["name"] = str(fn.get("name"))
                if isinstance(fn.get("arguments"), str):
                    state["arguments"] += fn["arguments"]
    message: dict = {"role": "assistant", "content": content}
    if reasoning:
        message["reasoning_content"] = reasoning
    if tools:
        message["tool_calls"] = [
            {
                "id": tool.get("id") or f"call_{idx}",
                "type": "function",
                "function": {"name": tool.get("name") or "tool", "arguments": tool.get("arguments") or "{}"},
            }
            for idx, tool in sorted(tools.items())
        ]
    return chat_completion_to_response({
        "id": chat_id,
        "created": created,
        "model": model,
        "choices": [{"message": message, "finish_reason": "tool_calls" if tools else "stop"}],
        "usage": usage,
    })


def _active_chat_proxy_slot() -> dict:
    data = load_slots(required=False)
    slot = data.get("current")
    cfg = (data.get("slots") or {}).get(slot) or {}
    if cfg.get("mode") != "relay" or cfg.get("protocol") != "chat":
        raise RuntimeError("当前渠道不是 chat-completions 自定义 API")
    if not str(cfg.get("base_url") or "").strip() or not str(cfg.get("api_key") or "").strip():
        raise RuntimeError("chat-completions 自定义 API 缺少 base_url 或 api_key")
    return cfg


class ResponsesProxyHandler(BaseHTTPRequestHandler):
    server_version = "sub2cli-responses-proxy/0.1"

    def log_message(self, fmt: str, *args: object) -> None:
        try:
            PROTOCOL_PROXY_LOG.parent.mkdir(parents=True, exist_ok=True)
            with PROTOCOL_PROXY_LOG.open("a", encoding="utf-8") as fh:
                fh.write("[%s] %s\n" % (time.strftime("%Y-%m-%d %H:%M:%S"), fmt % args))
        except OSError:
            pass

    def _send(self, status: int, body: bytes, content_type: str = "application/json") -> None:
        self.send_response(status)
        self.send_header("Content-Type", content_type)
        self.send_header("Content-Length", str(len(body)))
        self.end_headers()
        self.wfile.write(body)

    def _send_json(self, status: int, payload: object) -> None:
        self._send(status, json.dumps(payload, ensure_ascii=False).encode("utf-8"))

    def do_GET(self) -> None:
        path = self.path.split("?", 1)[0]
        if path == "/healthz":
            self._send_json(200, {"ok": True})
            return
        if path not in {"/models", "/v1/models"}:
            self._send_json(404, {"error": {"message": "not found"}})
            return
        try:
            cfg = _active_chat_proxy_slot()
            endpoint = models_endpoint(str(cfg.get("base_url") or ""))
            req = urlrequest.Request(endpoint, headers={
                "Authorization": f"Bearer {cfg.get('api_key')}",
                "Accept": "application/json",
                "User-Agent": "sub2cli-responses-proxy/0.1",
            })
            with urlrequest.urlopen(req, timeout=30) as resp:
                body = resp.read(4 * 1024 * 1024)
                content_type = resp.headers.get("Content-Type") or "application/json"
            self._send(200, body, content_type)
        except Exception as exc:
            self._send_json(502, {"error": {"message": str(exc)}})

    def do_POST(self) -> None:
        path = self.path.split("?", 1)[0]
        if path not in {"/responses", "/v1/responses", "/responses/compact", "/v1/responses/compact"}:
            self._send_json(404, {"error": {"message": "not found"}})
            return
        try:
            cfg = _active_chat_proxy_slot()
            length = int(self.headers.get("Content-Length") or "0")
            body = self.rfile.read(length)
            responses_body = json.loads(body.decode("utf-8"))
            chat_body = responses_to_chat_request(responses_body)
            endpoint = chat_completions_endpoint(str(cfg.get("base_url") or ""))
            req = urlrequest.Request(
                endpoint,
                data=json.dumps(chat_body, ensure_ascii=False).encode("utf-8"),
                headers={
                    "Authorization": f"Bearer {cfg.get('api_key')}",
                    "Content-Type": "application/json",
                    "Accept": "text/event-stream" if chat_body.get("stream") else "application/json",
                    "User-Agent": "sub2cli-responses-proxy/0.1",
                },
                method="POST",
            )
            try:
                with urlrequest.urlopen(req, timeout=600) as resp:
                    upstream = resp.read()
                    upstream_type = resp.headers.get("Content-Type") or ""
            except urlerror.HTTPError as exc:
                err_body = exc.read()[:1024 * 1024]
                self._send(exc.code, err_body or str(exc).encode("utf-8"), exc.headers.get("Content-Type") or "application/json")
                return
            wants_stream = bool(responses_body.get("stream"))
            if "text/event-stream" in upstream_type:
                response = chat_sse_to_response_json(upstream)
            else:
                response = chat_completion_to_response(json.loads(upstream.decode("utf-8")))
            if wants_stream:
                self._send(200, response_json_to_sse(response), "text/event-stream")
            else:
                self._send_json(200, response)
        except Exception as exc:
            payload = {"error": {"message": str(exc), "type": "sub2cli_proxy_error"}}
            if self.headers.get("accept", "").lower().find("text/event-stream") >= 0:
                failed = _sse("response.failed", {"response": {"status": "failed", "error": payload["error"]}}) + "data: [DONE]\n\n"
                self._send(500, failed.encode("utf-8"), "text/event-stream")
            else:
                self._send_json(500, payload)


def run_responses_proxy(port: int = PROTOCOL_PROXY_PORT) -> int:
    server = ThreadingHTTPServer(("127.0.0.1", port), ResponsesProxyHandler)
    print(f"sub2cli responses proxy listening on http://127.0.0.1:{port}/v1", flush=True)
    server.serve_forever()
    return 0


def _self_command_prefix() -> list[str]:
    if getattr(sys, "frozen", False):
        return [sys.executable]
    return [sys.executable, str(Path(__file__).resolve())]


def protocol_proxy_healthy(port: int = PROTOCOL_PROXY_PORT) -> bool:
    try:
        with urlrequest.urlopen(f"http://127.0.0.1:{port}/healthz", timeout=0.8) as resp:
            return resp.status == 200
    except Exception:
        return False


def ensure_protocol_proxy(port: int = PROTOCOL_PROXY_PORT) -> bool:
    if protocol_proxy_healthy(port):
        return False
    PROTOCOL_PROXY_LOG.parent.mkdir(parents=True, exist_ok=True)
    env = {**os.environ, "PYINSTALLER_RESET_ENVIRONMENT": "1"}
    for key in list(env):
        if key.startswith("_PYI_"):
            env.pop(key, None)
    with PROTOCOL_PROXY_LOG.open("ab") as log:
        subprocess.Popen(
            [*_self_command_prefix(), "responses-proxy", "--port", str(port)],
            stdin=subprocess.DEVNULL,
            stdout=log,
            stderr=log,
            close_fds=True,
            start_new_session=True,
            env=env,
        )
    for _ in range(30):
        time.sleep(0.1)
        if protocol_proxy_healthy(port):
            return True
    return False


def load_models_json(path: str | None) -> list[str]:
    if not path:
        return []
    try:
        payload = json.loads(Path(path).read_text())
    except (OSError, ValueError, TypeError) as exc:
        fail(f"--models-json 读取失败: {exc}")
    models = parse_models_payload(payload)
    if not models:
        fail("--models-json 未包含可用模型")
    return models


def relay_model_catalog_for_slot(cfg: dict, *, refresh: bool = False) -> dict:
    mode = cfg.get("mode", "oauth")
    raw_model = str(cfg.get("model") or "").strip()
    if mode != "relay":
        configured_model = raw_model or DEFAULT_MODEL
        return {
            "mode": "oauth",
            "status": "oauth",
            "model": configured_model,
            "default_model": configured_model,
            "model_provider": OAUTH_PROVIDER,
            "provider_name": "OpenAI",
            "base_url": "",
            "models": [configured_model],
            "message": "official Codex account",
        }
    base_url = str(cfg.get("base_url") or "").strip().rstrip("/")
    api_key = str(cfg.get("api_key") or "").strip()
    stored_models = [m for m in cfg.get("models", []) if isinstance(m, str) and m.strip()]
    models = []
    error: str | None = None
    if refresh or not stored_models:
        models, error = fetch_relay_models(base_url, api_key)
    models = merge_model_lists(stored_models, models)
    if not models:
        models = stored_models
    manual_model = bool(raw_model and cfg.get("model_source") == "manual")
    configured_model = raw_model if manual_model else best_default_model(models, raw_model or DEFAULT_MODEL)
    if manual_model and raw_model not in models:
        models.insert(0, raw_model)
    return {
        "mode": "relay",
        "status": "ok" if models else "failed",
        "model": configured_model,
        "default_model": configured_model if configured_model in models else best_default_model(models, configured_model),
        "model_provider": RELAY_PROVIDER,
        "provider_name": cfg.get("display_name") or RELAY_PROVIDER,
        "base_url": base_url,
        "models": models,
        "message": error or "",
    }


def slot_config_model(cfg: dict, *, refresh: bool = False) -> str:
    raw_model = str(cfg.get("model") or "").strip()
    if cfg.get("mode") != "relay":
        return raw_model or DEFAULT_MODEL
    if raw_model and cfg.get("model_source") == "manual":
        return raw_model
    catalog = relay_model_catalog_for_slot(cfg, refresh=refresh)
    return str(catalog.get("default_model") or catalog.get("model") or raw_model or DEFAULT_MODEL)


def write_apikey_auth(path: Path, api_key: str) -> bool:
