def split_toml_head(text: str) -> tuple[str, str]:
    match = re.search(r"(?m)^\s*\[", text)
    if not match:
        return text, ""
    return text[: match.start()], text[match.start() :]


def set_top_level_config(text: str, updates: dict[str, str | bool | None]) -> str:
    head, tail = split_toml_head(text)
    keys = "|".join(re.escape(key) for key in updates)
    if keys:
        head = re.sub(rf'(?m)^\s*({keys})\s*=.*(?:\n)?', "", head)

    def render_value(value: str | bool | None) -> str | None:
        if value is None:
            return None
        if isinstance(value, bool):
            return "true" if value else "false"
        return f'"{toml_quote(value)}"'

    block = "".join(
        f"{key} = {rendered}\n"
        for key, value in updates.items()
        if (rendered := render_value(value)) is not None
    )
    return block + head.lstrip("\n") + tail


def strip_relay_provider_block(text: str) -> str:
    return re.sub(
        rf"(?ms)^\s*\[model_providers\.{re.escape(RELAY_PROVIDER)}\]\s*\n.*?(?=^\s*\[|\Z)",
        "",
        text,
        flags=re.IGNORECASE,
    ).rstrip() + "\n"


