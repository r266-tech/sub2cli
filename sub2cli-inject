def relay_model_catalog_for_slot(cfg: dict, *, refresh: bool = False) -> dict:
    mode = cfg.get("mode", "oauth")
    raw_model = str(cfg.get("model") or "").strip()
    if mode != "relay":
        configured_model = raw_model or DEFAULT_MODEL
        return {
            "mode": "oauth",
            "status": "oauth",
            "model": configured_model,
            "default_model": configured_model,
            "model_provider": OAUTH_PROVIDER,
            "provider_name": "OpenAI",
            "base_url": "",
            "models": [configured_model],
            "message": "official Codex account",
        }
    if cfg.get("protocol") == "pool":
        models = merge_model_lists(
            [str(route.get("model") or "").strip() for route in pool_routes(cfg) if str(route.get("model") or "").strip()],
            cfg.get("models", []) if isinstance(cfg.get("models"), list) else [],
        )
        configured_model = raw_model or (models[0] if models else DEFAULT_MODEL)
        return {
            "mode": "relay",
            "status": "ok" if pool_routes(cfg) else "failed",
            "model": configured_model,
            "default_model": configured_model,
            "model_provider": RELAY_PROVIDER,
            "provider_name": cfg.get("display_name") or RELAY_PROVIDER,
            "base_url": PROTOCOL_PROXY_BASE_URL,
            "models": models or [configured_model],
            "message": f"route pool ({len(pool_routes(cfg))} routes)",
        }
    base_url = str(cfg.get("base_url") or "").strip().rstrip("/")
    api_key = str(cfg.get("api_key") or "").strip()
    stored_models = [m for m in cfg.get("models", []) if isinstance(m, str) and m.strip()]
    models = []
    error: str | None = None
    if refresh or not stored_models:
        models, error = fetch_relay_models(base_url, api_key)
    models = merge_model_lists(stored_models, models)
    if not models:
        models = stored_models
    manual_model = bool(raw_model and cfg.get("model_source") == "manual")
    configured_model = raw_model if manual_model else best_default_model(models, raw_model or DEFAULT_MODEL)
    if manual_model and raw_model not in models:
        models.insert(0, raw_model)
    return {
        "mode": "relay",
        "status": "ok" if models else "failed",
        "model": configured_model,
        "default_model": configured_model if configured_model in models else best_default_model(models, configured_model),
        "model_provider": RELAY_PROVIDER,
        "provider_name": cfg.get("display_name") or RELAY_PROVIDER,
        "base_url": base_url,
        "models": models,
        "message": error or "",
    }


def slot_config_model(cfg: dict, *, refresh: bool = False) -> str:
    raw_model = str(cfg.get("model") or "").strip()
    if cfg.get("mode") != "relay":
        return raw_model or DEFAULT_MODEL
    if raw_model and cfg.get("model_source") == "manual":
        return raw_model
    catalog = relay_model_catalog_for_slot(cfg, refresh=refresh)
    return str(catalog.get("default_model") or catalog.get("model") or raw_model or DEFAULT_MODEL)


