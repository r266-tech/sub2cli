#!/usr/bin/env python3
"""sub2cli-redeem — 兑换 Sub2API 系列网关 (codex2api.com / 自部署实例 等) 卡密。

Modes:
    sub2cli-redeem <CODE> [...]              sequential (--parallel 1)
    sub2cli-redeem --parallel N <CODE> [...] fixed concurrency N
    sub2cli-redeem --auto <CODE> [...]       AIMD adaptive concurrency
    sub2cli-redeem -                         read codes from stdin

Common flags:
    --shuffle           random order (default: input order)
    --no-dedupe         ignore state file, retry all codes
    --state PATH        state file (default $XDG_STATE_HOME/sub2cli/redeem.jsonl)
    --max-retries N     per-code retry budget for transient 429 (default 3)
    --circuit-breaker N abort after N consecutive 4xx terminal fails (default 3)
    --gap S             base inter-batch gap seconds (default 4)
    --auto-cap N        cap for adaptive concurrency (default 6)
    --auto-start N      starting concurrency for --auto (default 2)
    --allow-non-hex     accept codes that aren't 32-hex
    --dry-run           print plan, do not call API

Auth:
    Reads `auth_token` from Edge CDP at $EDGE_CDP_HOST:$EDGE_CDP_PORT
    (default 127.0.0.1:9222). Override entirely with env SUB2CLI_TOKEN.

Safety rails:
    - HTTP 429 (含 "too many failed attempts" 消息) 视为暂态限流, AIMD 自动退避后
      重试; 不再当作硬锁立即中止整次跑.
    - Circuit breaker: after N consecutive 4xx terminal failures (already-used,
      invalid, not-found codes), abort. Prevents bulk-failing a batch of bad
      codes from spinning forever. Bypass with --circuit-breaker 0.
    - Rejects codes that don't match [a-fA-F0-9]{16,} to avoid fake-code probing
      (404s count as failed attempts). Bypass with --allow-non-hex.
    - Dedupe via state file skips codes with prior terminal result (200 OR any
      of {400, 404, 409, 410}). 429 不入 dedupe, 总会重试.
"""
from __future__ import annotations

import argparse
import json
import os
import random
import re
import sys
import threading
import time
import urllib.request
from concurrent.futures import ThreadPoolExecutor, as_completed
from datetime import datetime, timezone

import requests
import websocket  # type: ignore[import-not-found]


CDP_HOST = os.environ.get("EDGE_CDP_HOST", "127.0.0.1")
CDP_PORT = int(os.environ.get("EDGE_CDP_PORT", "9222"))
SITE = "www.codex2api.com"
API = f"https://{SITE}/api/v1/redeem"
DEFAULT_STATE = os.path.join(
    os.environ.get("XDG_STATE_HOME") or os.path.expanduser("~/.local/state"),
    "sub2cli",
    "redeem.jsonl",
)
LOCK_PATTERN = re.compile(r"too many failed attempts", re.IGNORECASE)
HEX_CODE_PATTERN = re.compile(r"^[a-fA-F0-9]{16,}$")

_state_lock = threading.Lock()
_print_lock = threading.Lock()
_run_id = datetime.now(timezone.utc).strftime("%Y%m%dT%H%M%SZ")


def vprint(msg: str, *, err: bool = True) -> None:
    out = sys.stderr if err else sys.stdout
    with _print_lock:
        print(msg, file=out, flush=True)


def get_token() -> str:
    if t := os.environ.get("SUB2CLI_TOKEN") or os.environ.get("CODEX2API_TOKEN"):
        return t
    try:
        tabs = json.load(
            urllib.request.urlopen(f"http://{CDP_HOST}:{CDP_PORT}/json", timeout=3)
        )
    except Exception as exc:
        sys.exit(f"[token] Edge CDP unreachable at {CDP_HOST}:{CDP_PORT} ({exc})")
    target = next(
        (t for t in tabs if t.get("type") == "page" and SITE in t.get("url", "")),
        None,
    )
    if not target:
        sys.exit(
            f"[token] no {SITE} tab open in Edge — log in there first "
            f"(or set SUB2CLI_TOKEN env)"
        )
    try:
        ws = websocket.create_connection(
            target["webSocketDebuggerUrl"], timeout=5, suppress_origin=True
        )
        ws.send(
            json.dumps(
                {
                    "id": 1,
                    "method": "Runtime.evaluate",
                    "params": {
                        "expression": "localStorage.getItem('auth_token')",
                        "returnByValue": True,
                    },
                }
            )
        )
        val = json.loads(ws.recv())["result"]["result"]["value"]
        ws.close()
    except Exception as exc:
        sys.exit(f"[token] CDP evaluate failed: {exc}")
    if not val:
        sys.exit("[token] auth_token missing from localStorage (logged out?)")
    return val


TERMINAL_FAIL_STATUSES = {400, 404, 409, 410}


def load_done(state_path: str) -> dict[str, int]:
    """Return {code: prior_status} for codes with terminal results — i.e.
    successful (200) or definitively bad (4xx that aren't 429 rate-limit).
    Skipped on subsequent runs; 429-failed codes are NOT deduped (会重试).
    """
    done: dict[str, int] = {}
    if not os.path.exists(state_path):
        return done
    with open(state_path) as f:
        for line in f:
            try:
                r = json.loads(line)
            except json.JSONDecodeError:
                continue
            st = r.get("status")
            code = r.get("code")
            if not code:
                continue
            if st == 200 or st in TERMINAL_FAIL_STATUSES:
                done[code] = st
    return done


def append_state(state_path: str, rec: dict) -> None:
    rec.setdefault("ts", datetime.now(timezone.utc).isoformat(timespec="seconds"))
    rec.setdefault("run_id", _run_id)
    os.makedirs(os.path.dirname(state_path), exist_ok=True)
    with _state_lock, open(state_path, "a") as f:
        f.write(json.dumps(rec, ensure_ascii=False) + "\n")


def collect_codes(argv: list[str], allow_non_hex: bool) -> list[str]:
    raw: list[str] = []
    for a in argv:
        if a == "-":
            raw.extend(re.findall(r"\S+", sys.stdin.read()))
        else:
            raw.append(a.strip())
    seen: set[str] = set()
    out: list[str] = []
    skipped_invalid = 0
    for c in raw:
        if not c or c in seen:
            continue
        if not allow_non_hex and not HEX_CODE_PATTERN.match(c):
            skipped_invalid += 1
            continue
        seen.add(c)
        out.append(c)
    if skipped_invalid:
        vprint(
            f"[input] {skipped_invalid} non-hex codes rejected "
            f"(use --allow-non-hex to bypass)"
        )
    return out


def call_once(token: str, code: str) -> dict:
    t0 = time.perf_counter()
    try:
        r = requests.post(
            API,
            headers={
                "Authorization": f"Bearer {token}",
                "Content-Type": "application/json",
                "Accept": "application/json",
                "Origin": f"https://{SITE}",
                "Referer": f"https://{SITE}/redeem",
            },
            json={"code": code},
            timeout=30,
        )
        try:
            body = r.json()
        except ValueError:
            body = {"raw": r.text[:200]}
        status = r.status_code
    except requests.RequestException as exc:
        body, status = {"exc": str(exc)}, -1
    dt_ms = int((time.perf_counter() - t0) * 1000)
    detail = body.get("detail") or body.get("message") or body.get("exc") or ""
    return {
        "code": code,
        "status": status,
        "detail": detail,
        "reason": body.get("reason"),
        "type": body.get("type"),
        "value": body.get("value"),
        "new_balance": body.get("new_balance"),
        "new_concurrency": body.get("new_concurrency"),
        "group_name": body.get("group_name"),
        "validity_days": body.get("validity_days"),
        "latency_ms": dt_ms,
    }


def is_lock_response(rec: dict) -> bool:
    return rec["status"] == 429 and bool(LOCK_PATTERN.search(rec.get("detail") or ""))


def fmt(rec: dict) -> str:
    short = rec["code"][:10] + "…"
    if rec["status"] == 200:
        bits = []
        t, v = rec.get("type"), rec.get("value")
        if t == "balance" and v is not None:
            bits.append(f"+${v:.2f}")
        elif t == "concurrency" and v is not None:
            bits.append(f"+{v} req")
        elif t == "subscription":
            bits.append(f"sub {rec.get('validity_days')}d {rec.get('group_name','')}".strip())
        if (nb := rec.get("new_balance")) is not None:
            bits.append(f"bal=${nb:.2f}")
        if (nc := rec.get("new_concurrency")) is not None:
            bits.append(f"conc={nc}")
        bits.append(f"{rec['latency_ms']}ms")
        return f"OK  [{short}]  " + "  ".join(bits)
    return (
        f"ERR [{short}] HTTP {rec['status']}: {rec.get('detail') or '(no detail)'} "
        f"({rec['latency_ms']}ms)"
    )


def run_burst(token: str, codes: list[str]) -> list[dict]:
    n = len(codes)
    with ThreadPoolExecutor(max_workers=max(1, n)) as pool:
        futs = [pool.submit(call_once, token, c) for c in codes]
        return [f.result() for f in as_completed(futs)]


def main() -> int:
    p = argparse.ArgumentParser(add_help=False)
    p.add_argument("--parallel", type=int, default=1)
    p.add_argument("--auto", action="store_true")
    p.add_argument("--auto-cap", type=int, default=6)
    p.add_argument("--auto-start", type=int, default=2)
    p.add_argument("--shuffle", action="store_true")
    p.add_argument("--no-dedupe", action="store_true")
    p.add_argument("--state", default=DEFAULT_STATE)
    p.add_argument("--max-retries", type=int, default=3)
    p.add_argument(
        "--circuit-breaker",
        type=int,
        default=3,
        help="abort after N consecutive 4xx terminal failures (0=disabled)",
    )
    p.add_argument("--gap", type=float, default=4.0, help="inter-batch gap seconds")
    p.add_argument("--allow-non-hex", action="store_true")
    p.add_argument("--dry-run", action="store_true")
    p.add_argument("-h", "--help", action="store_true")
    args, rest = p.parse_known_args()

    if args.help or not rest:
        print(__doc__.strip(), file=sys.stderr)
        return 2

    codes = collect_codes(rest, args.allow_non_hex)
    if not codes:
        vprint("[input] no valid codes parsed")
        return 2

    done = {} if args.no_dedupe else load_done(args.state)
    pending: list[str] = [c for c in codes if c not in done]
    skipped = len(codes) - len(pending)
    if skipped:
        from collections import Counter

        skip_breakdown = Counter(done[c] for c in codes if c in done)
        vprint(f"[dedupe] skipped breakdown: {dict(skip_breakdown)}")
    if args.shuffle:
        random.shuffle(pending)

    mode = "auto" if args.auto else f"parallel={args.parallel}"
    vprint(
        f"[plan] run={_run_id} mode={mode} input={len(codes)} skipped={skipped} "
        f"pending={len(pending)} state={args.state}"
    )
    if args.dry_run:
        for c in pending:
            print(f"PLAN {c}")
        return 0
    if not pending:
        vprint("[plan] nothing to do")
        return 0

    token = get_token()
    vprint(f"[token] len={len(token)}")

    successes = 0
    failures: list[dict] = []
    aborted = False
    consecutive_terminal_4xx = 0

    def handle_result(rec: dict) -> bool:
        """Return False to abort the run."""
        nonlocal successes, aborted, consecutive_terminal_4xx
        append_state(args.state, rec)
        vprint(fmt(rec))
        if rec["status"] == 200:
            successes += 1
            consecutive_terminal_4xx = 0
            return True
        # 429 (含 "too many failed attempts") = 暂态限流, 不当作终结; 走 AIMD/parallel 的重试通道
        failures.append(rec)
        if rec["status"] in TERMINAL_FAIL_STATUSES:
            consecutive_terminal_4xx += 1
            if (
                args.circuit_breaker > 0
                and consecutive_terminal_4xx >= args.circuit_breaker
            ):
                vprint(
                    f"[abort] circuit breaker tripped: {consecutive_terminal_4xx} "
                    f"consecutive 4xx terminal failures (limit={args.circuit_breaker}). "
                    f"Likely these codes are all consumed/invalid. Abort to avoid "
                    f"tripping REDEEM_RATE_LIMITED. Bypass with --circuit-breaker 0."
                )
                aborted = True
                return False
        return True

    if args.auto:
        return run_auto(args, token, pending, handle_result, lambda: aborted)

    if args.parallel <= 1:
        return run_sequential(args, token, pending, handle_result, lambda: aborted)

    return run_fixed_parallel(args, token, pending, handle_result, lambda: aborted)


def run_sequential(args, token, pending, handle, is_aborted) -> int:
    for code in pending:
        rec = call_once(token, code)
        if not handle(rec):
            break
        if pending.index(code) < len(pending) - 1:
            time.sleep(0.2)  # tiny jitter
    return print_summary(args.state, is_aborted())


def run_fixed_parallel(args, token, pending, handle, is_aborted) -> int:
    """Fixed concurrency: --parallel N. Retries transient 429 up to max-retries."""
    queue_remaining = list(pending)
    attempt_count: dict[str, int] = {c: 0 for c in queue_remaining}

    while queue_remaining:
        if is_aborted():
            break
        batch = queue_remaining[: args.parallel]
        queue_remaining = queue_remaining[args.parallel :]
        recs = run_burst(token, batch)
        requeue = []
        for r in recs:
            if not handle(r):
                return print_summary(args.state, True)
            if r["status"] == 429:
                attempt_count[r["code"]] += 1
                if attempt_count[r["code"]] < args.max_retries:
                    requeue.append(r["code"])
        if requeue:
            vprint(f"[retry] {len(requeue)} codes hit transient 429, requeued")
            queue_remaining.extend(requeue)
            time.sleep(args.gap * 2)
        elif queue_remaining:
            time.sleep(args.gap)
    return print_summary(args.state, is_aborted())


def run_auto(args, token, pending, handle, is_aborted) -> int:
    """AIMD adaptive concurrency.

    - Starts at --auto-start; capped at --auto-cap.
    - All-200 batch → concurrency += 1 (up to cap).
    - Any 429 in batch → concurrency = max(1, concurrency // 2), longer gap.
    - 终结性 4xx (400/404/409/410) 达到 circuit_breaker → abort via handle().
    """
    queue_remaining = list(pending)
    attempt_count: dict[str, int] = {c: 0 for c in queue_remaining}
    concurrency = max(1, min(args.auto_start, args.auto_cap))
    gap = args.gap

    while queue_remaining:
        if is_aborted():
            break
        n = min(concurrency, len(queue_remaining))
        batch = queue_remaining[:n]
        queue_remaining = queue_remaining[n:]
        recs = run_burst(token, batch)
        ok = 0
        transient_429 = 0
        requeue: list[str] = []
        for r in recs:
            if not handle(r):
                return print_summary(args.state, True)
            if r["status"] == 200:
                ok += 1
            elif r["status"] == 429:
                transient_429 += 1
                attempt_count[r["code"]] += 1
                if attempt_count[r["code"]] < args.max_retries:
                    requeue.append(r["code"])
        if transient_429:
            new_c = max(1, concurrency // 2)
            new_gap = min(gap * 1.7, 60)
            vprint(
                f"[aimd] 429 in batch ({transient_429}/{n}); "
                f"concurrency {concurrency}→{new_c} gap {gap:.1f}→{new_gap:.1f}s"
            )
            concurrency = new_c
            gap = new_gap
            queue_remaining.extend(requeue)
            time.sleep(gap)
        elif ok == n and concurrency < args.auto_cap:
            new_c = min(concurrency + 1, args.auto_cap)
            new_gap = max(args.gap, gap * 0.9)
            if new_c != concurrency or new_gap != gap:
                vprint(
                    f"[aimd] clean batch; concurrency {concurrency}→{new_c} "
                    f"gap {gap:.1f}→{new_gap:.1f}s"
                )
            concurrency = new_c
            gap = new_gap
            if queue_remaining:
                time.sleep(gap)
        elif queue_remaining:
            time.sleep(gap)
    return print_summary(args.state, is_aborted())


def print_summary(state_path: str, aborted: bool) -> int:
    # Tally everything from this run only
    run_recs: list[dict] = []
    if os.path.exists(state_path):
        with open(state_path) as f:
            for line in f:
                try:
                    r = json.loads(line)
                except json.JSONDecodeError:
                    continue
                if r.get("run_id") == _run_id:
                    run_recs.append(r)
    ok = [r for r in run_recs if r.get("status") == 200]
    fail = [r for r in run_recs if r.get("status") != 200]
    bal_delta = sum(
        r["value"] for r in ok if r.get("type") == "balance" and r.get("value")
    )
    conc_delta = sum(
        r["value"] for r in ok if r.get("type") == "concurrency" and r.get("value")
    )
    last_bal = next(
        (r["new_balance"] for r in reversed(run_recs) if r.get("new_balance") is not None),
        None,
    )
    last_conc = next(
        (
            r["new_concurrency"]
            for r in reversed(run_recs)
            if r.get("new_concurrency") is not None
        ),
        None,
    )
    bal_str = f"${last_bal:.2f}" if isinstance(last_bal, (int, float)) else "n/a"
    conc_str = str(last_conc) if last_conc is not None else "n/a"
    tag = "[ABORTED] " if aborted else ""
    vprint(
        f"\n{tag}[summary] ok={len(ok)} fail={len(fail)}  "
        f"+${bal_delta:.2f}  +{conc_delta} req  "
        f"balance={bal_str}  concurrency={conc_str}"
    )
    if fail:
        from collections import Counter

        c = Counter((r.get("status"), (r.get("detail") or "")[:60]) for r in fail)
        vprint("[summary] failures:")
        for (st, det), n in c.most_common():
            vprint(f"  x{n}  HTTP {st}  {det}")
    return 0 if not fail and not aborted else 1


if __name__ == "__main__":
    sys.exit(main())
