#!/usr/bin/env python3
"""sub2cli — Sub2API 系列网关订阅 → Codex CLI 配置控制台。

把任意 Sub2API 兼容网关 (codex2api.com / 其他自部署实例 等) 里的 key+url，
一条命令配置到本机 Codex CLI / Codex App 用。

用法:
    sub2cli                # 进入 REPL
    sub2cli --help

REPL 菜单:
    刷新 / 中转 / url / 分组 / 名称 / 兑换历史 / 配置 codex / 退出

鉴权: 从 Edge CDP (127.0.0.1:9222) 实时读 localStorage.auth_token；
      也支持 SUB2CLI_TOKEN 环境变量覆盖。
"""
from __future__ import annotations

