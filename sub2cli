# ==================== Sub2Context ====================

class TokenError(RuntimeError):
    """CDP 不可达 / 没找到登录 tab / localStorage 空时抛."""


def _normalize_domain(value: str) -> str:
    value = value.strip().rstrip("/")
    if not value:
        return value
    if not re.match(r"^https?://", value):
        value = "https://" + value
    return value


def _api_base_for_domain(domain: str) -> str:
    """Preserve scheme, port, and optional path prefix for self-hosted relays."""
    return _normalize_domain(domain).rstrip("/") + "/api/v1"


class Sub2Context:
    """单个 relay 的运行时上下文 — domain / token / 路径 一对一封装。

    取代旧版的 module-level SITE / DOMAIN / API_BASE 全局，让 GUI 和 JSON-RPC
    模式能并发持有多个 relay 而不互相污染。
    """

    def __init__(
        self,
        domain: str,
        *,
        token: str | None = None,
        config_path: str | None = None,
        cdp_host: str | None = None,
        cdp_port: int | None = None,
    ) -> None:
        domain = _normalize_domain(domain)
        parsed = urlparse(domain)
        host = parsed.netloc or domain.replace("https://", "").replace("http://", "")
        self.domain = domain
        self.site = host
        self.api_base = _api_base_for_domain(domain)
        self._token = token
        self.config_path = config_path or default_config_path()
        self.cdp_host = cdp_host or DEFAULT_CDP_HOST
        self.cdp_port = cdp_port or DEFAULT_CDP_PORT
        self._session = requests.Session()

    # ---- token plumbing ----

    @property
    def token(self) -> str:
        if self._token is None:
            self._token = self._fetch_token_from_cdp()
        return self._token

    def has_token(self) -> bool:
        return self._token is not None

    def set_token(self, token: str) -> None:
        self._token = token

    def clear_token(self) -> None:
        self._token = None

    def _fetch_token_from_cdp(self) -> str:
        if t := os.environ.get("SUB2CLI_TOKEN"):
            return t
        try:
            tabs = json.load(
                urllib.request.urlopen(
                    f"http://{self.cdp_host}:{self.cdp_port}/json", timeout=3
                )
            )
        except Exception as exc:  # noqa: BLE001
            raise TokenError(
                f"Edge CDP unreachable at {self.cdp_host}:{self.cdp_port} ({exc})"
            ) from exc
        target = next(
            (t for t in tabs if t.get("type") == "page" and self.site in t.get("url", "")),
            None,
        )
        if not target:
            raise TokenError(
                f"no {self.site} tab open in Edge — log in there first "
                f"(or set SUB2CLI_TOKEN env)"
            )
        try:
            ws = websocket.create_connection(
                target["webSocketDebuggerUrl"], timeout=5, suppress_origin=True
            )
            ws.send(
                json.dumps(
                    {
                        "id": 1,
                        "method": "Runtime.evaluate",
                        "params": {
                            "expression": "localStorage.getItem('auth_token')",
                            "returnByValue": True,
                        },
                    }
                )
            )
            val = json.loads(ws.recv())["result"]["result"]["value"]
            ws.close()
        except Exception as exc:  # noqa: BLE001
            raise TokenError(f"CDP evaluate failed: {exc}") from exc
        if not val:
            raise TokenError("auth_token missing from localStorage (logged out?)")
        return val

    def _headers(self) -> dict:
        return {"Authorization": f"Bearer {self.token}", "Accept": "application/json"}

    # ---- API methods ----

    def fetch_user(self) -> dict | None:
        try:
            r = self._session.get(f"{self.api_base}/auth/me", headers=self._headers(), timeout=8)
            if r.status_code == 200:
                return r.json().get("data", {})
        except requests.RequestException:
            pass
        return None

    def fetch_keys(self) -> list[dict]:
        try:
            r = self._session.get(f"{self.api_base}/keys", headers=self._headers(), timeout=8)
            if r.status_code == 200:
                return (r.json().get("data") or {}).get("items", []) or []
        except requests.RequestException:
            pass
        return []

    def fetch_settings(self) -> dict | None:
        try:
            r = self._session.get(
                f"{self.api_base}/settings/public", headers=self._headers(), timeout=8
            )
            if r.status_code == 200:
                return r.json().get("data", {})
        except requests.RequestException:
            pass
        return None

    def fetch_groups(self) -> list[dict]:
        try:
            r = self._session.get(
                f"{self.api_base}/groups/available", headers=self._headers(), timeout=10
            )
            if r.status_code == 200:
                return r.json().get("data", []) or []
        except requests.RequestException:
            pass
        return []

    def fetch_subscriptions(self) -> list[dict]:
        try:
            r = self._session.get(
                f"{self.api_base}/subscriptions", headers=self._headers(), timeout=8
            )
            if r.status_code == 200:
                data = r.json().get("data") or []
                if isinstance(data, list):
                    return data
                return data.get("items", []) or []
        except (requests.RequestException, ValueError, AttributeError):
            pass
        return []

    def fetch_history(self, limit: int = 10) -> list[dict]:
        try:
            r = self._session.get(
                f"{self.api_base}/redeem/history", headers=self._headers(), timeout=8
            )
            if r.status_code == 200:
                return (r.json().get("data") or [])[:limit]
        except requests.RequestException:
            pass
        return []

    def create_key(self, name: str = "sub2cli") -> dict | None:
        try:
            r = self._session.post(
                f"{self.api_base}/keys",
                headers={**self._headers(), "Content-Type": "application/json"},
                json={"name": name},
                timeout=10,
            )
            if r.status_code in (200, 201):
                body = r.json() if r.content else {}
                return body.get("data") if isinstance(body, dict) else None
        except requests.RequestException:
            pass
        return None

    def update_key_group(self, key_id: int, group_id: int) -> tuple[bool, str]:
        try:
            r = self._session.put(
                f"{self.api_base}/keys/{key_id}",
                headers={**self._headers(), "Content-Type": "application/json"},
                json={"group_id": group_id},
                timeout=10,
            )
            try:
                body = r.json()
            except ValueError:
                body = {"raw": r.text[:200]}
            if r.status_code == 200 and body.get("code") == 0:
                return True, ""
            return False, body.get("message") or body.get("detail") or f"HTTP {r.status_code}"
        except requests.RequestException as exc:
            return False, f"{type(exc).__name__}: {exc}"

    def settings_reachable_anonymous(self) -> tuple[bool, str]:
        """探测 domain 是否像 Sub2API 实例 (不带 token, settings/public 公开端点)."""
        try:
            r = requests.get(f"{self.api_base}/settings/public", timeout=8)
            if r.status_code == 200 and "data" in r.json():
                return True, ""
            return False, f"HTTP {r.status_code}"
        except (requests.RequestException, ValueError) as exc:
            return False, f"{type(exc).__name__}: {exc}"


# ==================== 无状态的 OpenAI-兼容探测 ====================

def test_chat(base_url: str, api_key: str, model: str = "gpt-5.5") -> dict:
    url = base_url.rstrip("/") + "/chat/completions"
    headers = {
        "Authorization": f"Bearer {api_key}",
        "Content-Type": "application/json",
        "Accept": "application/json",
    }
    payload = {
        "model": model,
        "messages": [{"role": "user", "content": "hi"}],
        "max_tokens": 1,
        "stream": False,
    }
    t0 = time.perf_counter()
    try:
        r = requests.post(url, headers=headers, json=payload, timeout=30)
        dt = int((time.perf_counter() - t0) * 1000)
        try:
            body = r.json()
        except ValueError:
            body = {"raw": r.text[:200]}
        if r.status_code == 200:
            return {"ok": True, "status": 200, "latency_ms": dt, "summary": "ok"}
        det = body.get("error", {}).get("message") or body.get("message") or body.get("detail") or r.text[:80]
        return {"ok": False, "status": r.status_code, "latency_ms": dt, "summary": str(det)[:100]}
    except requests.RequestException as exc:
        return {
            "ok": False, "status": -1,
            "latency_ms": int((time.perf_counter() - t0) * 1000),
            "summary": f"{type(exc).__name__}: {exc}",
        }


def test_image(base_url: str, api_key: str, model: str = "gpt-image-2") -> dict:
    url = base_url.rstrip("/") + "/images/generations"
    headers = {
