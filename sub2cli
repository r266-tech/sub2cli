# ==================== 默认值 ====================

def default_config_path() -> str:
    return os.path.join(
        os.environ.get("XDG_CONFIG_HOME") or os.path.expanduser("~/.config"),
        "sub2cli",
        "config.json",
    )


DEFAULT_CDP_HOST = os.environ.get("EDGE_CDP_HOST", "127.0.0.1")
DEFAULT_CDP_PORT = int(os.environ.get("EDGE_CDP_PORT", "9222"))
DEFAULT_DOMAIN = "https://www.codex2api.com"

# 持久化到 config["relays"][domain] 下的字段
RELAY_FIELDS = (
    "default_key_id",
    "default_key_name",
    "default_endpoint_name",
    "default_endpoint_url",
)


