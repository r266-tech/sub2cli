def color(s: str, c: str) -> str:
    if not sys.stdout.isatty():
        return s
    return f"{c}{s}{C_RESET}"


# ==================== 配置 ====================

RELAY_FIELDS = (
    "default_key_id",
    "default_key_name",
    "default_endpoint_name",
    "default_endpoint_url",
)


def load_config() -> dict | None:
    if not os.path.exists(CONFIG_PATH):
        return None
    try:
        with open(CONFIG_PATH) as f:
            cfg = json.load(f)
    except (OSError, json.JSONDecodeError):
        return None
    # 迁移：旧版无 relays 字段 → 把当前 domain 的设置打包成第一个 relay
    if "relays" not in cfg and cfg.get("domain"):
        cfg["relays"] = {cfg["domain"]: {f: cfg.get(f) for f in RELAY_FIELDS}}
    return cfg


def save_config(cfg: dict) -> None:
    # 自动把当前 top-level default_* 同步进 relays[domain]
    domain = cfg.get("domain", "")
    if domain:
        relays = cfg.setdefault("relays", {})
        relays[domain] = {f: cfg.get(f) for f in RELAY_FIELDS}
    os.makedirs(CONFIG_DIR, exist_ok=True)
    with open(CONFIG_PATH, "w") as f:
        json.dump(cfg, f, indent=2, ensure_ascii=False)
    os.chmod(CONFIG_PATH, 0o600)


def apply_domain(domain: str) -> None:
    """根据 domain 更新全局 + c2a lib 的 SITE/API。"""
    global DOMAIN, API_BASE
    host = urlparse(domain).hostname or domain.replace("https://", "").replace("http://", "").rstrip("/")
    DOMAIN = f"https://{host}"
    API_BASE = f"https://{host}/api/v1"
    c2a.SITE = host
    c2a.API = f"https://{host}/api/v1/redeem"


# ==================== API 调用 ====================

def _auth_headers(token: str) -> dict:
    return {"Authorization": f"Bearer {token}", "Accept": "application/json"}


def fetch_user(token: str) -> dict | None:
    try:
        r = requests.get(f"{API_BASE}/auth/me", headers=_auth_headers(token), timeout=8)
        if r.status_code == 200:
            return r.json().get("data", {})
    except requests.RequestException:
        pass
    return None


def fetch_keys(token: str) -> list[dict]:
    try:
        r = requests.get(f"{API_BASE}/keys", headers=_auth_headers(token), timeout=8)
        if r.status_code == 200:
            return (r.json().get("data") or {}).get("items", []) or []
    except requests.RequestException:
        pass
    return []


def fetch_settings(token: str) -> dict | None:
    try:
        r = requests.get(
            f"{API_BASE}/settings/public", headers=_auth_headers(token), timeout=8
        )
        if r.status_code == 200:
            return r.json().get("data", {})
    except requests.RequestException:
        pass
    return None


def fetch_groups(token: str) -> list[dict]:
    try:
        r = requests.get(
            f"{API_BASE}/groups/available", headers=_auth_headers(token), timeout=10
        )
        if r.status_code == 200:
            return r.json().get("data", []) or []
    except requests.RequestException:
        pass
    return []


def fetch_history(token: str, limit: int = 10) -> list[dict]:
    try:
        r = requests.get(
            f"{API_BASE}/redeem/history", headers=_auth_headers(token), timeout=8
        )
        if r.status_code == 200:
            return (r.json().get("data") or [])[:limit]
    except requests.RequestException:
        pass
    return []


def create_key(token: str, name: str = "sub2cli") -> dict | None:
    """POST /api/v1/keys with {name}. Server auto-fills group_id/quota defaults."""
    try:
        r = requests.post(
            f"{API_BASE}/keys",
            headers={**_auth_headers(token), "Content-Type": "application/json"},
            json={"name": name},
            timeout=10,
        )
        if r.status_code in (200, 201):
            body = r.json() if r.content else {}
            return body.get("data") if isinstance(body, dict) else None
    except requests.RequestException:
        pass
    return None


def update_key_group(token: str, key_id: int, group_id: int) -> tuple[bool, str]:
    """PUT /api/v1/keys/{id} with {group_id}. Returns (ok, detail)."""
    try:
        r = requests.put(
            f"{API_BASE}/keys/{key_id}",
            headers={**_auth_headers(token), "Content-Type": "application/json"},
            json={"group_id": group_id},
            timeout=10,
        )
        try:
            body = r.json()
        except ValueError:
            body = {"raw": r.text[:200]}
        if r.status_code == 200 and body.get("code") == 0:
            return True, ""
        return False, body.get("message") or body.get("detail") or f"HTTP {r.status_code}"
    except requests.RequestException as exc:
        return False, f"{type(exc).__name__}: {exc}"


def test_chat(base_url: str, api_key: str, model: str = "gpt-5.5") -> dict:
    """POST /v1/chat/completions, tiny. Returns probe-result dict."""
    url = base_url.rstrip("/") + "/chat/completions"
    headers = {
        "Authorization": f"Bearer {api_key}",
        "Content-Type": "application/json",
        "Accept": "application/json",
    }
    payload = {
        "model": model,
        "messages": [{"role": "user", "content": "hi"}],
        "max_tokens": 1,
        "stream": False,
    }
    t0 = time.perf_counter()
    try:
        r = requests.post(url, headers=headers, json=payload, timeout=30)
        dt = int((time.perf_counter() - t0) * 1000)
        try:
            body = r.json()
        except ValueError:
            body = {"raw": r.text[:200]}
        if r.status_code == 200:
            content = (
                body.get("choices", [{}])[0].get("message", {}).get("content", "")
            )
            return {"ok": True, "status": 200, "latency_ms": dt, "summary": f"ok"}
        det = body.get("error", {}).get("message") or body.get("message") or body.get("detail") or r.text[:80]
        return {"ok": False, "status": r.status_code, "latency_ms": dt, "summary": str(det)[:100]}
    except requests.RequestException as exc:
        return {"ok": False, "status": -1, "latency_ms": int((time.perf_counter()-t0)*1000),
                "summary": f"{type(exc).__name__}: {exc}"}


def test_image(base_url: str, api_key: str, model: str = "gpt-image-2") -> dict:
    """POST /v1/images/generations, tiny."""
    url = base_url.rstrip("/") + "/images/generations"
