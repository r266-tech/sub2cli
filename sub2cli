        return {"ok": False, "status": r.status_code, "latency_ms": dt, "summary": str(det)[:120]}
    except requests.RequestException as exc:
        return {"ok": False, "status": -1, "latency_ms": int((time.perf_counter()-t0)*1000),
                "summary": f"{type(exc).__name__}: {exc}"}


def probe_endpoint(base_url: str, api_key: str | None = None) -> dict:
    """探测 OpenAI 兼容端点 /models。200=通+有 key，401=可达需鉴权，其他=有问题。"""
    url = base_url.rstrip("/") + "/models"
    headers = {"Accept": "application/json"}
    if api_key:
        headers["Authorization"] = f"Bearer {api_key}"
    t0 = time.perf_counter()
    try:
        r = requests.get(url, headers=headers, timeout=8)
        dt = int((time.perf_counter() - t0) * 1000)
        if r.status_code == 200:
            try:
                n = len(r.json().get("data", []))
            except ValueError:
                n = "?"
            return {"status": 200, "latency_ms": dt, "ok": True, "summary": f"{n} 个模型"}
        if r.status_code == 401:
            return {"status": 401, "latency_ms": dt, "ok": True, "summary": "可达（需鉴权）"}
        return {"status": r.status_code, "latency_ms": dt, "ok": False, "summary": r.text[:60]}
    except requests.RequestException as exc:
        dt = int((time.perf_counter() - t0) * 1000)
        return {
            "status": -1, "latency_ms": dt, "ok": False,
            "summary": f"{type(exc).__name__}: {str(exc)[:60]}",
        }


# ==================== 工具 ====================

def mask_key(k: str) -> str:
    if not k:
        return "?"
    if len(k) <= 12:
        return k
    return f"{k[:8]}...{k[-4:]}"


def find_key_by_name(keys: list[dict], name: str) -> dict | None:
    for k in keys:
        if k.get("name") == name:
            return k
    return None


def find_key_by_id(keys: list[dict], kid) -> dict | None:
    for k in keys:
        if k.get("id") == kid:
            return k
    return None


def find_endpoint(endpoints: list[dict], name: str) -> dict | None:
    for e in endpoints:
        if e.get("name") == name:
            return e
    return None


def normalize_v1(url: str) -> str:
    """与 web UI 一致：先剥掉尾部 /v1 和斜杠，再统一补上 /v1。"""
    if not url:
        return url
    s = url.rstrip("/")
    if s.endswith("/v1"):
        s = s[:-3].rstrip("/")
    return s + "/v1"


def collect_endpoints(settings: dict) -> list[dict]:
    eps: list[dict] = []
    base = settings.get("api_base_url") or ""
    if base:
        eps.append({
            "name": "默认", "endpoint": normalize_v1(base), "description": "默认线路"
        })
    for c in settings.get("custom_endpoints") or []:
        eps.append({
            "name": c.get("name", "?"),
            "endpoint": normalize_v1(c.get("endpoint", "")),
            "description": c.get("description", ""),
        })
    if not eps:
        # 中转 /settings/public 没给 url 时, 退到域名本身 (e.g. https://relay.example.com/v1)
        host = getattr(c2a, "SITE", "") or ""
        if host:
            eps.append({
                "name": "默认",
                "endpoint": normalize_v1(f"https://{host}"),
                "description": "域名 fallback",
            })
    return eps


def auto_pick_key(keys: list[dict]) -> dict | None:
    """直接取第一个；无 key 时返回 None（调用方负责自动创建）。"""
    return keys[0] if keys else None


def auto_pick_endpoint(eps: list[dict]) -> dict | None:
    """探所有端点，选延迟最低的 OK 那个；都失败则返第一个；无端点返回 None。"""
    if not eps:
        return None
    if len(eps) == 1:
        return eps[0]
    best = None
    best_lat = float("inf")
    for ep in eps:
        r = probe_endpoint(ep.get("endpoint", ""))
        if r["ok"] and r["latency_ms"] < best_lat:
            best_lat = r["latency_ms"]
            best = ep
    return best or eps[0]


def ensure_defaults(cfg: dict, token: str, *, verbose: bool = False) -> tuple[dict, dict | None, dict | None]:
    """读 keys/endpoints；若 cfg 里的默认值缺失/失效，自动填一个并 save。
    keys 为空时自动建一个名为 sub2cli 的 key。
    返回 (cfg, default_key dict | None, default_ep dict | None)。"""
    keys = fetch_keys(token)
    if not keys:
        if verbose:
            print(color("  · 该中转尚未创建任何 key，自动建一个 sub2cli …", C_DIM))
        new_key = create_key(token, name="sub2cli")
        if new_key:
            if verbose:
                print(color(f"    ✓ 已创建 key: {new_key.get('name')} (id={new_key.get('id')})", C_GREEN))
            keys = fetch_keys(token)
        else:
            if verbose:
                print(color("    ✗ 自动创建 key 失败 (POST /keys 没成功)", C_YELLOW))

    settings = fetch_settings(token) or {}
    eps = collect_endpoints(settings)

    dk_name = cfg.get("default_key_name", "")
    default_key = find_key_by_name(keys, dk_name) if dk_name else None
    if not default_key:
        default_key = auto_pick_key(keys)
        if default_key:
            cfg["default_key_id"] = default_key.get("id")
            cfg["default_key_name"] = default_key.get("name")
            if verbose:
                print(color(f"  · 自动选默认 key: {default_key.get('name')}", C_DIM))

    de_name = cfg.get("default_endpoint_name", "")
    default_ep = find_endpoint(eps, de_name) if de_name else None
    if not default_ep:
        default_ep = auto_pick_endpoint(eps)
        if default_ep:
            cfg["default_endpoint_name"] = default_ep.get("name")
            cfg["default_endpoint_url"] = default_ep.get("endpoint")
            if verbose:
                print(color(
                    f"  · 自动选默认线路: {default_ep.get('name')} "
                    f"({default_ep.get('endpoint')})", C_DIM))

    save_config(cfg)
    return cfg, default_key, default_ep


def parse_codes(text: str) -> list[str]:
    found = re.findall(r"\b[a-fA-F0-9]{16,}\b", text)
    seen: set[str] = set()
    out: list[str] = []
    for c in found:
        if c not in seen:
            seen.add(c)
            out.append(c)
    return out


def read_input(prompt: str) -> str | None:
    """读一行，再 200ms 内 drain 任何粘进来的后续行。EOF 返回 None。"""
    try:
        first = input(prompt)
    except EOFError:
        return None
    chunks = [first]
    deadline = time.time() + 0.2
    while True:
        remaining = deadline - time.time()
        if remaining <= 0:
            break
        r, _, _ = select.select([sys.stdin], [], [], remaining)
        if not r:
            break
        line = sys.stdin.readline()
        if not line:
            break
        chunks.append(line.rstrip("\n"))
        deadline = time.time() + 0.1
    return "\n".join(chunks)


def ask_choice(prompt: str, n: int, default: int | None = None) -> int | None:
    """让用户从 1..n 里选一个；回车=default；空回车且无 default 返回 None。"""
    hint = f" [{default}]" if default else ""
    while True:
        try:
            raw = input(f"{prompt}{hint}: ").strip()
        except (EOFError, KeyboardInterrupt):
            return None
        if not raw:
            return default
        try:
            v = int(raw)
            if 1 <= v <= n:
                return v
        except ValueError:
            pass
        print(color(f"  请输入 1..{n} 之间的整数", C_YELLOW))


# ==================== TUI 菜单（基于 termios，参考 codex-provider-macos）====================

def clear_screen() -> None:
    if not sys.stdout.isatty():
        return
    sys.stdout.write("\033[2J\033[H")
    sys.stdout.flush()


def read_key() -> str:
    """阻塞读一个键。返回: up / down / enter / quit / back / 或单字符串。"""
    if not sys.stdin.isatty():
        return "quit"
    fd = sys.stdin.fileno()
    old = termios.tcgetattr(fd)
    try:
        tty.setraw(fd)
        ch = os.read(fd, 1)
        if ch == b"\x1b":
            key = ch
            while select.select([sys.stdin], [], [], 0.02)[0]:
                key += os.read(fd, 1)
            if key in (b"\x1b[A", b"\x1b[D"):
                return "up"
            if key in (b"\x1b[B", b"\x1b[C"):
                return "down"
            return "back"
        if ch in (b"\r", b"\n"):
            return "enter"
        if ch in (b"q", b"Q", b"\x03"):
            return "quit"
        if ch in (b"b", b"B", b"\x7f"):
            return "back"
    finally:
        termios.tcsetattr(fd, termios.TCSADRAIN, old)
    return ""


def pause(msg: str = "按任意键返回") -> None:
    print(color(f"\n  {msg}…", C_DIM), end="", flush=True)
    read_key()
    print()


def select_menu(
    options: list[tuple[str, str]],
    *,
    banner_fn=None,
    title: str | None = None,
    subtitle: str | None = None,
    initial: int = 0,
) -> str:
    """箭头上下选菜单。options=[(label, value)]，返回 value 或 'quit'。"""
    if not options:
        return "quit"
    if not (sys.stdin.isatty() and sys.stdout.isatty()):
        # 非交互场景退化为数字输入
        if banner_fn:
            banner_fn()
        if title:
            print(title)
        for idx, (label, _) in enumerate(options, 1):
            print(f"  {idx}. {label}")
        try:
            raw = input("> ").strip()
            return options[int(raw) - 1][1]
        except (EOFError, ValueError, IndexError, KeyboardInterrupt):
            return "quit"

    selected = max(0, min(initial, len(options) - 1))
    while True:
        clear_screen()
        if banner_fn:
            banner_fn()
        if title:
            print(color(title, C_BOLD))
        if subtitle:
            print(color(subtitle, C_DIM))
        if title or subtitle:
            print()
        for idx, (label, _) in enumerate(options):
            marker = color("▶", C_CYAN) if idx == selected else " "
            line_color = C_BOLD + C_CYAN if idx == selected else C_RESET
            print(f"  {marker} {color(f'{idx + 1}. {label}', line_color)}")
        key = read_key()
        if key == "up":
            selected = (selected - 1) % len(options)
        elif key == "down":
            selected = (selected + 1) % len(options)
        elif key == "enter":
            return options[selected][1]
        elif key == "quit":
            return "quit"


