def cmd_endpoints(ctx: Sub2Context, cfg: dict) -> dict:
    settings = ctx.fetch_settings()
    if not settings:
        print(color("  （无法读 settings/public）", C_RED))
        return cfg
    eps = collect_endpoints(settings, fallback_site=ctx.domain)
    if not eps:
        print(color("  （无端点配置）", C_YELLOW))
        return cfg
    keys = ctx.fetch_keys()
    sample_key = next((k.get("key") for k in keys if k.get("status") == "active"), None)
    cur_name = cfg.get("default_endpoint_name")

    print(color(f"可用端点 (n={len(eps)}):", C_BOLD))
    results: list[dict] = []
    for i, ep in enumerate(eps, 1):
        name = ep.get("name", "?")
        url = ep.get("endpoint", "")
        desc = ep.get("description", "")
        cur = color(" ★当前", C_GREEN) if name == cur_name else ""
        r = probe_endpoint(url)
        r2 = probe_endpoint(url, api_key=sample_key) if sample_key else None
        results.append({"ep": ep, "noauth": r, "auth": r2})
        tag = color("OK ", C_GREEN) if r["ok"] else color("ERR", C_RED)
        line = (f"  [{i}] {tag} {color(name, C_CYAN):<14} {color(url, C_DIM)}"
                f"  {r['latency_ms']}ms{cur}")
        print(line)
        if desc:
            print(color(f"        {desc}", C_DIM))
        if r2:
            tag2 = color("OK ", C_GREEN) if r2["ok"] else color("ERR", C_RED)
            print(f"        {tag2} 带 auth  {r2['latency_ms']}ms  {color(r2['summary'], C_DIM)}")

    auto_idx = len(eps) + 1
    print(f"  [{auto_idx}] {color('自动选择 (最快的可用端点)', C_CYAN)}")

    pick = ask_choice("\n选择并测试（回车跳过）", auto_idx, default=None)
    if pick is None:
        return cfg

    if pick == auto_idx:
        ok_results = [r for r in results if r["noauth"]["ok"]]
        if not ok_results:
            print(color("  没有可达的端点", C_RED))
            return cfg
        best = min(ok_results, key=lambda r: r["noauth"]["latency_ms"])
        chosen = best["ep"]
        print(color(
            f"  自动选: {chosen.get('name')} "
            f"({best['noauth']['latency_ms']}ms)", C_GREEN))
    else:
        chosen = eps[pick - 1]

    cfg["default_endpoint_name"] = chosen.get("name")
    cfg["default_endpoint_url"] = chosen.get("endpoint")
    save_config(cfg, ctx.config_path)
    print(color(f"  ✓ 默认端点 → {chosen.get('name')}  ({chosen.get('endpoint')})", C_GREEN))
    print()
    return cfg


def _fmt_test_cell(r: dict | None, width: int = 14) -> str:
    if r is None:
        return color(f"{'—':<{width}}", C_DIM)
    if r.get("running"):
        return color(f"{'⏳ 测试中…':<{width-2}}", C_YELLOW)
    if r.get("ok"):
        s = f"✓ {r['latency_ms']}ms"
        return color(f"{s:<{width}}", C_GREEN)
    s = f"✗ {r.get('status','?')}"
    return color(f"{s:<{width}}", C_RED)


def cmd_groups(ctx: Sub2Context, cfg: dict) -> dict:
    """列分组 → 选 (含「自动选择」) → 切默认 key 到该分组 → 跑 gpt-5.5 + gpt-image-2，
    表格行动态刷新。自动模式按倍率低到高跑，找到两个都通的就停。"""
    groups = ctx.fetch_groups()
    if not groups:
        print(color("  （无可用分组）", C_YELLOW))
        return cfg
    keys = ctx.fetch_keys()
    keys_by_group: dict[int, list[dict]] = {}
    for k in keys:
        gid = k.get("group_id")
        if gid is not None:
            keys_by_group.setdefault(gid, []).append(k)

    ep_url = cfg.get("default_endpoint_url") or normalize_v1(ctx.domain)
    default_key_name = cfg.get("default_key_name", "")
    default_key = find_key_by_name(keys, default_key_name)
    if not default_key:
        print(color("  未设置默认 key — 无法测试。先去『名称』设一个。", C_YELLOW))
        return cfg

    sorted_groups = sorted(
        groups, key=lambda x: x.get("rate_multiplier") or 99999
    )
    results: dict[int, dict] = {}
    in_progress_gid: int | None = None

    def render() -> None:
        clear_screen()
        print(color("分组测试", C_BOLD + C_CYAN))
        print(color(f"  端点: {ep_url}  ·  默认 key: {default_key_name}", C_DIM))
        print()
        print(color(
            "   #  倍率   分组                              gpt-5.5         image",
            C_DIM,
        ))
        for i, g in enumerate(sorted_groups, 1):
            gid = g.get("id")
            name = (g.get("name") or "?")[:30]
            rate = g.get("rate_multiplier")
            rate_s = f"{rate}x" if rate is not None else "?"
            r = results.get(gid)
            chat_cell = _fmt_test_cell(r.get("chat") if r else None)
            img_cell = _fmt_test_cell(r.get("image") if r else None)
            star = ""
            for k in keys_by_group.get(gid, []):
                if k.get("name") == default_key_name:
                    star = color(" ★", C_GREEN)
                    break
            arrow = color(" ◀ 测试中", C_YELLOW) if gid == in_progress_gid else ""
            print(
                f"  [{i:>2}] {rate_s:>5}  {name:<30}{star}  "
                f"{chat_cell}  {img_cell}{arrow}"
            )
        auto_idx = len(sorted_groups) + 1
        print(f"  [{auto_idx:>2}] {color('自动选择 (倍率低→高，两个都通就停)', C_CYAN)}")
        print(color("\n  ★ = 默认 key 当前所在分组", C_DIM))

    render()
    auto_idx = len(sorted_groups) + 1
    pick = ask_choice("\n选择并测试（回车跳过）", auto_idx, default=None)
    if pick is None:
        return cfg

    auto_mode = (pick == auto_idx)
    targets = sorted_groups if auto_mode else [sorted_groups[pick - 1]]

    final_chosen = None
    for g in targets:
        gid = g.get("id")
        cur_gid = default_key.get("group_id")
        if cur_gid != gid:
            in_progress_gid = gid
            results[gid] = {"chat": {"running": True}, "image": {"running": True}}
            render()
            ok, err = ctx.update_key_group(default_key["id"], gid)
            if not ok:
                results[gid] = {
                    "chat": {"ok": False, "status": "切换失败", "summary": err},
                    "image": {"ok": False, "status": "切换失败", "summary": err},
                }
                render()
                if not auto_mode:
                    break
                continue
            keys = ctx.fetch_keys()
            default_key = find_key_by_name(keys, default_key_name)
            keys_by_group = {}
            for k in keys:
                kgid = k.get("group_id")
                if kgid is not None:
                    keys_by_group.setdefault(kgid, []).append(k)
        in_progress_gid = gid
        api_key = default_key.get("key", "")

        results.setdefault(gid, {})
        results[gid]["chat"] = {"running": True}
        results[gid]["image"] = {"running": True}
        render()
        r_chat = test_chat(ep_url, api_key, model="gpt-5.5")
        results[gid]["chat"] = r_chat
        render()
        r_img = test_image(ep_url, api_key, model="gpt-image-2")
        results[gid]["image"] = r_img
        in_progress_gid = None
        render()

        if auto_mode and r_chat.get("ok") and r_img.get("ok"):
            final_chosen = g
            break

    if auto_mode:
        if final_chosen:
            print(color(
                f"\n  ✓ 自动选定: 「{final_chosen.get('name')}」 ({final_chosen.get('rate_multiplier')}x)"
                f"  — 默认 key 现已在此分组",
                C_GREEN,
            ))
        else:
            print(color("\n  ✗ 没有一个分组两项测试都通过", C_RED))
    else:
        g = targets[0]
        print(color(f"\n  默认 key 现在分组「{g.get('name')}」", C_DIM))
    return cfg


def cmd_key(ctx: Sub2Context, cfg: dict, arg: str | None) -> dict:
    """测试 + 选择 key (按 key 维度，因为 key↔分组 1:1)。"""
    keys = ctx.fetch_keys()
    if not keys:
        print(color("  没有可用 key", C_YELLOW))
        return cfg
    if arg:
        match = find_key_by_name(keys, arg)
        if not match:
            print(color(f"  未找到 key: {arg}", C_RED))
            return cfg
        cfg["default_key_name"] = match.get("name")
        cfg["default_key_id"] = match.get("id")
        save_config(cfg, ctx.config_path)
        print(color(f"  ✓ 默认 key → {match['name']}", C_GREEN))
        return cfg

    ep_url = cfg.get("default_endpoint_url") or normalize_v1(ctx.domain)
    print(color(f"测试每把 key (GET {ep_url}/models):", C_BOLD))
    cur_idx = 1
    results: list[tuple[dict, dict]] = []
    for i, k in enumerate(keys, 1):
        g = k.get("group") or {}
        gname = g.get("name", "?")
        rate = g.get("rate_multiplier")
        rate_s = f"{rate}x" if rate is not None else "?"
        is_cur = k.get("name") == cfg.get("default_key_name")
        if is_cur:
            cur_idx = i
        status = k.get("status", "?")
        if status == "active":
            r = probe_endpoint(ep_url, api_key=k.get("key"))
            results.append((k, r))
            if r["ok"] and r["status"] == 200:
                probe_s = color(f"✓ {r['latency_ms']}ms · {r['summary']}", C_GREEN)
            else:
                probe_s = color(f"✗ HTTP {r['status']}", C_RED)
        else:
            results.append((k, {"ok": False}))
            probe_s = color("(已停用)", C_DIM)
        cur_mark = color(" ★当前", C_GREEN) if is_cur else ""
        print(
            f"  [{i}] {color(k.get('name','?'), C_CYAN):<14} "
            f"{mask_key(k.get('key',''))}  "
            f"分组: {gname} ({rate_s}){cur_mark}"
        )
        print(f"      {probe_s}")
    pick = ask_choice("选择新默认", len(keys), default=cur_idx)
    if pick is None:
        print()
        return cfg
    k = keys[pick - 1]
    cfg["default_key_name"] = k.get("name")
    cfg["default_key_id"] = k.get("id")
    save_config(cfg, ctx.config_path)
    print(color(f"  ✓ 默认 → {k['name']}（分组 {(k.get('group') or {}).get('name','?')}）", C_GREEN))
    print()
    return cfg


