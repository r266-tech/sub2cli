        print(color(f"  当前 url:    {cur_url}", C_DIM))
        print(color(f"  当前 apikey: {cur_apikey}", C_DIM))
        print()

    pick = select_menu(sub_options, banner_fn=sub_banner, initial=0)
    clear_screen()
    if pick == "quit":
        print(color("  已取消", C_DIM))
        return

    if pick == "current":
        keys = fetch_keys(token)
        k = find_key_by_name(keys, cfg.get("default_key_name", "")) if cfg.get("default_key_name") else None
        if not k:
            print(color("  未设置默认 key，先去 [名称] 选一个，或选 '使用新的 url + apikey'", C_YELLOW))
            return
        url = cfg.get("default_endpoint_url") or ""
        api_key = k.get("key", "")
        if not url or not api_key:
            print(color("  缺少 url 或 api key", C_RED))
            return
        g = k.get("group") or {}
        label = (
            f"key={k.get('name')} · 分组 {g.get('name','?')} "
            f"({g.get('rate_multiplier')}x) · 线路 {cfg.get('default_endpoint_name','?')}"
        )
        _run_inject(inject_bin, url, api_key, label)
        return

    # pick == "new"
    print(color("输入新的 url 和 apikey (空回车取消):", C_BOLD))
    try:
        new_url = (read_input("  url   > ") or "").strip()
    except KeyboardInterrupt:
        print()
        return
    if not new_url:
        print(color("  已取消", C_DIM))
        return
    if not re.match(r"^https?://", new_url):
        new_url = "https://" + new_url
    new_url = new_url.rstrip("/")
    try:
        new_key = (read_input("  apikey> ") or "").strip()
    except KeyboardInterrupt:
        print()
        return
    if not new_key:
        print(color("  已取消", C_DIM))
        return
    _run_inject(inject_bin, new_url, new_key, "手动输入")


def cmd_select_relay(state: dict) -> dict:
    """列已保存中转 + 新建。切完自动 apply_domain、重新拿 token、补默认。"""
    cfg = state["cfg"]
    relays = cfg.setdefault("relays", {})
    domain_list = list(relays.keys())
    current = cfg.get("domain", "")

    print(color("已保存的中转:", C_BOLD))
    for i, d in enumerate(domain_list, 1):
        r = relays.get(d, {})
        mark = color(" ★当前", C_GREEN) if d == current else ""
        print(
            f"  [{i}] {color(d, C_CYAN)}  "
            f"key={r.get('default_key_name','?')}  "
            f"线路={r.get('default_endpoint_name','?')}{mark}"
        )
    add_idx = len(domain_list) + 1
    print(f"  [{add_idx}] {color('+ 新建中转', C_GREEN)}")

    default_pick = (domain_list.index(current) + 1) if current in domain_list else add_idx
    pick = ask_choice("选择", add_idx, default=default_pick)
    if pick is None:
        return state

    if pick == add_idx:
        # 新建：仅问域名 + 验证 + 拿 token + 自动补默认
        try:
            raw = input("  新中转域名 (https://...): ").strip()
        except (EOFError, KeyboardInterrupt):
            print()
            return state
        if not raw:
            print(color("  已取消", C_DIM))
            return state
        if not re.match(r"^https?://", raw):
            raw = "https://" + raw
        raw = raw.rstrip("/")
        # 临时切换 c2a SITE 来验证
        old_site = SITE
        apply_domain(raw)
        try:
            r = requests.get(f"{API_BASE}/settings/public", timeout=8)
            if r.status_code != 200 or "data" not in r.json():
                print(color(f"  ✗ {raw} 不像 Sub2API 实例 (HTTP {r.status_code})", C_RED))
                apply_domain(f"https://{old_site}")
                return state
        except requests.RequestException as exc:
            print(color(f"  ✗ 不可达: {exc}", C_RED))
            apply_domain(f"https://{old_site}")
            return state
        print(color(f"  ✓ {raw} 正常", C_GREEN))
        target_domain = raw
        relays[target_domain] = {f: None for f in RELAY_FIELDS}
    else:
        target_domain = domain_list[pick - 1]
        apply_domain(target_domain)

    # 切换 cfg 到目标 relay
    cfg["domain"] = target_domain
    relay = relays.get(target_domain, {})
    for f in RELAY_FIELDS:
        cfg[f] = relay.get(f)

    # 拿 token（可能需要在浏览器先登录新域名）
    token = None
    while not token:
        try:
            token = get_token()
        except SystemExit as exc:
            print(color(f"  ✗ {exc}", C_YELLOW))
            print(color(
                f"  请在 Edge 打开 {target_domain} 并登录，按回车重试 (Ctrl-C 取消)",
                C_YELLOW))
            try:
                input()
            except (EOFError, KeyboardInterrupt):
                print()
                # 回滚
                apply_domain(state["cfg"]["domain"])
                return state
    state["token"] = token

    user = fetch_user(token)
    if not user:
        print(color("  ✗ /auth/me 失败，token 可能无效", C_RED))
        apply_domain(state["cfg"]["domain"])
        return state
    state["user"] = user

    cfg, dk, de = ensure_defaults(cfg, token, verbose=True)
    state["cfg"] = cfg
    state["default_key"] = dk
    state["default_ep"] = de
    print(color(f"  ✓ 切到 {target_domain}", C_GREEN))
    return state


def cmd_reveal(token: str, cfg: dict) -> None:
    keys = fetch_keys(token)
    k = find_key_by_name(keys, cfg.get("default_key_name", "")) if cfg.get("default_key_name") else None
    if not k:
        print(color("  未设置默认 key", C_YELLOW))
        return
    print(f"  {color(k.get('name','?'), C_CYAN)}: {k.get('key','')}")


# ==================== Setup 向导 ====================

def run_wizard() -> dict:
    print(color("sub2cli — 首次启动配置", C_BOLD + C_CYAN))
    print()

    # 1. 域名
    print(color("[1/5] 中转站域名", C_BOLD))
    default_domain = "https://www.codex2api.com"
    while True:
        try:
            raw = input(f"  输入域名 (默认 {default_domain}): ").strip()
        except (EOFError, KeyboardInterrupt):
            print()
            sys.exit(0)
        raw = raw or default_domain
        if not re.match(r"^https?://", raw):
            raw = "https://" + raw
        raw = raw.rstrip("/")
        apply_domain(raw)
        print(color(f"  正在验证 {API_BASE}/settings/public ...", C_DIM))
        try:
            r = requests.get(f"{API_BASE}/settings/public", timeout=8)
            if r.status_code == 200 and "data" in r.json():
                print(color(f"  ✓ {API_BASE} 正常", C_GREEN))
                domain = raw
                break
            print(color(f"  ✗ HTTP {r.status_code}", C_RED))
        except requests.RequestException as exc:
            print(color(f"  ✗ 不可达: {exc}", C_RED))

    # 2. 浏览器拿 token
    print()
    print(color("[2/5] 读取浏览器登录信息", C_BOLD))
    print(color(f"  正在从 Edge CDP 读取 {urlparse(domain).hostname} 的 auth_token ...", C_DIM))
    token = None
    while not token:
        try:
            token = get_token()
        except SystemExit as exc:
            print(color(f"  ✗ {exc}", C_YELLOW))
            print(color(
                f"  请在 Edge 中打开 {domain} 并登录，然后按回车重试 (Ctrl-C 退出)", C_YELLOW))
            try:
                input()
            except (EOFError, KeyboardInterrupt):
                print()
                sys.exit(0)
    print(color(f"  ✓ 拿到 token ({len(token)} 字符)", C_GREEN))

    # 3. 账号
    print()
    print(color("[3/5] 账号信息", C_BOLD))
    user = fetch_user(token)
    if not user:
        print(color("  ✗ /auth/me 失败", C_RED))
        sys.exit(1)
    bal = user.get("balance", 0)
    conc = user.get("concurrency", 0)
    print(f"  邮箱: {color(user.get('email','?'), C_CYAN)}   "
          f"余额: {color(f'${bal:.4f}', C_GREEN)}   并发: {color(str(conc), C_GREEN)}")

    # 4. 选 key
    print()
    print(color("[4/5] 选择默认 API Key", C_BOLD))
    keys = fetch_keys(token)
    if not keys:
        print(color("  该账号还没有任何 API key，自动创建 sub2cli …", C_DIM))
        new_key = create_key(token, name="sub2cli")
        if not new_key:
            print(color("  ✗ POST /keys 失败，请在网页 UI 手动建一个再重跑", C_RED))
            sys.exit(1)
        print(color(f"  ✓ 已创建: {new_key.get('name')} (id={new_key.get('id')})", C_GREEN))
        keys = fetch_keys(token)
        if not keys:
            print(color("  ✗ 创建后仍未读到 keys，请检查网页 UI", C_RED))
            sys.exit(1)
    for i, k in enumerate(keys, 1):
        g = k.get("group") or {}
        rate = g.get("rate_multiplier")
        rate_s = f"{rate}x" if rate is not None else "?"
        print(
            f"  [{i}] {color(k.get('name','?'), C_CYAN):<14} "
            f"{mask_key(k.get('key',''))}  "
            f"分组: {g.get('name','?')} ({rate_s})"
        )
    pick = ask_choice("  选择默认", len(keys), default=1)
    if pick is None:
        sys.exit(0)
    default_key = keys[pick - 1]

    # 5. 选端点
    print()
    print(color("[5/5] 选择默认端点", C_BOLD))
    settings = fetch_settings(token) or {}
    eps = collect_endpoints(settings)
    if not eps:
        print(color("  ✗ 无端点配置", C_RED))
        sys.exit(1)
    for i, ep in enumerate(eps, 1):
        print(
            f"  [{i}] {color(ep.get('name','?'), C_CYAN):<14} "
            f"{ep.get('endpoint','?')}  "
            f"{color(ep.get('description',''), C_DIM)}"
        )
    pick = ask_choice("  选择默认", len(eps), default=1)
    if pick is None:
        sys.exit(0)
    default_ep = eps[pick - 1]

    cfg = {
        "domain": domain,
        "default_key_id": default_key.get("id"),
        "default_key_name": default_key.get("name"),
        "default_endpoint_name": default_ep.get("name"),
        "default_endpoint_url": default_ep.get("endpoint"),
    }
    save_config(cfg)
    print()
    print(color(f"✓ 已保存到 {CONFIG_PATH}", C_GREEN))
    print()
    return cfg


# ==================== 主循环 ====================

def main() -> int:
    if "--help" in sys.argv or "-h" in sys.argv:
        print(__doc__.strip())
        return 0

    cfg = load_config()
    if not cfg:
        cfg = run_wizard()

    apply_domain(cfg["domain"])

    try:
        token = get_token()
    except SystemExit as exc:
        print(color(str(exc), C_RED))
        return 1

    user = fetch_user(token)
    if not user:
        print(color("拉取账号信息失败，token 可能失效。请重新登录后再试。", C_RED))
        return 1

    cfg, default_key, default_ep = ensure_defaults(cfg, token, verbose=False)

    # ==== TUI 菜单主循环 ====
    state = {
        "cfg": cfg, "token": token, "user": user,
        "default_key": default_key, "default_ep": default_ep,
    }

    def banner_fn():
        print_banner(state["cfg"], state["user"], state["default_key"], state["default_ep"])

    def refresh_default_key():
        ks = fetch_keys(state["token"])
        state["default_key"] = find_key_by_name(ks, state["cfg"].get("default_key_name", ""))

    def refresh_default_ep():
        s = fetch_settings(state["token"]) or {}
        eps = collect_endpoints(s)
        state["default_ep"] = find_endpoint(eps, state["cfg"].get("default_endpoint_name", ""))

    options: list[tuple[str, str]] = [
        ("刷新", "refresh"),
        ("中转", "relay"),
        ("url", "ep"),
        ("分组", "groups"),
        ("名称", "key"),
        ("兑换历史", "history"),
        ("注入 codex", "inject"),
        ("退出", "quit"),
    ]
    last_idx = 0

    while True:
        choice = select_menu(options, banner_fn=banner_fn, initial=last_idx)
        if choice == "quit":
            clear_screen()
            print(color("bye", C_DIM))
            return 0

        last_idx = next((i for i, (_, v) in enumerate(options) if v == choice), 0)
        clear_screen()
        banner_fn()
        print()

        if choice == "refresh":
            new_user = fetch_user(state["token"])
            if new_user:
                state["user"] = new_user
            state["cfg"], state["default_key"], state["default_ep"] = ensure_defaults(
                state["cfg"], state["token"], verbose=False
            )
            print(color("  ✓ 已刷新", C_GREEN))
            pause()
            continue

        if choice == "relay":
            state = cmd_select_relay(state)
            pause()
            continue

        if choice == "ep":
            state["cfg"] = cmd_endpoints(state["token"], state["cfg"])
            refresh_default_ep()
            pause()

        elif choice == "groups":
            state["cfg"] = cmd_groups(state["token"], state["cfg"])
            refresh_default_key()  # 切 group 后默认 key 的 group_id 变了
            pause()

        elif choice == "key":
            state["cfg"] = cmd_key(state["token"], state["cfg"], None)
            refresh_default_key()
            pause()

        elif choice == "history":
            print(color("最近兑换历史:", C_BOLD))
            print_history(fetch_history(state["token"], 10))
            pause()

        elif choice == "inject":
            cmd_inject_codex(state["token"], state["cfg"])
            pause()

        elif choice == "reveal":
            cmd_reveal(state["token"], state["cfg"])
            pause()

        elif choice == "setup":
            state["cfg"] = run_wizard()
            apply_domain(state["cfg"]["domain"])
            state["token"] = get_token()
            state["user"] = fetch_user(state["token"])
            refresh_default_key()
            refresh_default_ep()
            pause("配置已更新")


if __name__ == "__main__":
    sys.exit(main())
