def print_banner(cfg: dict, user: dict, default_key: dict | None, default_ep: dict | None) -> None:
    host = urlparse(cfg["domain"]).hostname or "?"
    print(color("sub2cli", C_BOLD + C_CYAN) + color(f" — {host} 控制台", C_DIM))
    print(color("  域名:    ", C_DIM) + cfg["domain"])
    email = user.get("email", "?")
    status = user.get("status", "?")
    print(color("  账号:    ", C_DIM) + f"{email}  ·  状态: {color(status, C_GREEN if status=='active' else C_YELLOW)}")
    bal = user.get("balance")
    bal_s = f"${bal:.4f}" if isinstance(bal, (int, float)) else "?"
    conc = user.get("concurrency", "?")
    print(
        color("  余额:    ", C_DIM) + color(bal_s, C_GREEN)
        + color("   并发: ", C_DIM) + color(str(conc), C_GREEN)
    )
    if default_key:
        g = default_key.get("group") or {}
        gname = g.get("name", "?")
        rate = g.get("rate_multiplier")
        rate_s = f"{rate}x" if rate is not None else "?"
        print(
            color("  名称:    ", C_DIM) + color(default_key.get("name", "?"), C_CYAN)
            + color(f"  ·  分组 {gname} ({rate_s})", C_DIM)
        )
        print(color("  apikey:  ", C_DIM) + default_key.get("key", ""))
        if default_ep:
            ep_name = default_ep.get("name", "?")
            ep_suffix = f"  ({ep_name})" if ep_name and ep_name != "默认" else ""
            print(
                color("  url:     ", C_DIM)
                + default_ep.get("endpoint", "?")
                + color(ep_suffix, C_DIM)
            )
    else:
        print(color("  默认:    ", C_DIM) + color("(未配置，运行 setup)", C_YELLOW))
    print()


