def _resolve_inject_bin() -> str | None:
    here = os.path.dirname(os.path.abspath(__file__))
    candidates = [
        os.path.join(here, "sub2cli-inject"),
        os.path.expanduser("~/.local/bin/sub2cli-inject"),
        os.path.expanduser("~/.local/bin/codex-provider"),  # 兼容已装 codex-provider 的用户
        shutil.which("sub2cli-inject"),
        shutil.which("codex-provider"),
    ]
    return next((p for p in candidates if p and os.path.isfile(p) and os.access(p, os.X_OK)), None)


def _inject_subprocess_env() -> dict[str, str]:
    env = os.environ.copy()
    env["PYINSTALLER_RESET_ENVIRONMENT"] = "1"
    for key in list(env):
        if key.startswith("_PYI_"):
            env.pop(key, None)
    return env


def _run_inject(inject_bin: str, url: str, api_key: str, source_label: str) -> None:
    print(color("配置 codex:", C_BOLD))
    print(f"  url:     {url}")
    print(f"  apikey:  {mask_key(api_key)}")
    print(f"  来源:    {source_label}")
    print(color(f"  调用:    {inject_bin} add-api <url> --api-key-stdin", C_DIM))
    print()
    try:
        proc = subprocess.run(
            [inject_bin, "add-api", url, "--api-key-stdin"],
            input=api_key,
            text=True,
            env=_inject_subprocess_env(),
            timeout=300,
        )
        rc = proc.returncode
    except (OSError, subprocess.TimeoutExpired) as exc:
        print(color(f"  调用配置器失败: {exc}", C_RED))
        return
    if rc == 0:
        print(color("  ✓ 配置完成", C_GREEN))
    else:
        print(color(f"  ✗ 配置器返回非零 (rc={rc})", C_RED))


def cmd_inject_codex(ctx: Sub2Context, cfg: dict) -> None:
    """配置到 Codex CLI / Codex App: 用当前配置 或 临时输入新的 url+apikey."""
    inject_bin = _resolve_inject_bin()
    if not inject_bin:
        here = os.path.dirname(os.path.abspath(__file__))
        print(color("  缺少配置器脚本 sub2cli-inject (应跟 sub2cli 同目录):", C_RED))
        print(color(f"    预期位置: {os.path.join(here, 'sub2cli-inject')}", C_DIM))
        return

    sub_options: list[tuple[str, str]] = [
        ("使用当前配置", "current"),
        ("使用新的 url + apikey", "new"),
    ]

    cur_apikey = "(空)"
    if cfg.get("default_key_name"):
        _keys = ctx.fetch_keys()
        _k = find_key_by_name(_keys, cfg["default_key_name"])
        if _k and _k.get("key"):
            cur_apikey = mask_key(_k["key"])

    def sub_banner() -> None:
        print(color("配置 codex — 选择来源", C_BOLD + C_CYAN))
        cur_url = cfg.get("default_endpoint_url") or "(空)"
        print(color(f"  当前 url:    {cur_url}", C_DIM))
        print(color(f"  当前 apikey: {cur_apikey}", C_DIM))
        print()

    pick = select_menu(sub_options, banner_fn=sub_banner, initial=0)
    clear_screen()
    if pick == "quit":
        print(color("  已取消", C_DIM))
        return

    if pick == "current":
        keys = ctx.fetch_keys()
        k = find_key_by_name(keys, cfg.get("default_key_name", "")) if cfg.get("default_key_name") else None
        if not k:
            print(color("  未设置默认 key，先去 [名称] 选一个，或选 '使用新的 url + apikey'", C_YELLOW))
            return
        url = cfg.get("default_endpoint_url") or ""
        api_key = k.get("key", "")
        if not url or not api_key:
            print(color("  缺少 url 或 api key", C_RED))
            return
        g = k.get("group") or {}
        label = (
            f"key={k.get('name')} · 分组 {g.get('name','?')} "
            f"({g.get('rate_multiplier')}x) · 线路 {cfg.get('default_endpoint_name','?')}"
        )
        _run_inject(inject_bin, url, api_key, label)
        return

    print(color("输入新的 url 和 apikey (空回车取消):", C_BOLD))
    try:
        new_url = (read_input("  url   > ") or "").strip()
    except KeyboardInterrupt:
        print()
        return
    if not new_url:
        print(color("  已取消", C_DIM))
        return
    if not re.match(r"^https?://", new_url):
        new_url = "https://" + new_url
    new_url = new_url.rstrip("/")
    try:
        new_key = (read_input("  apikey> ") or "").strip()
    except KeyboardInterrupt:
        print()
        return
    if not new_key:
        print(color("  已取消", C_DIM))
        return
    _run_inject(inject_bin, new_url, new_key, "手动输入")


def cmd_select_relay(state: dict) -> dict:
    """列已保存中转 + 新建。切完创建新的 Sub2Context, 重新拿 token, 补默认。"""
    cfg = state["cfg"]
    cur_ctx: Sub2Context = state["ctx"]
    relays = cfg.setdefault("relays", {})
    domain_list = list(relays.keys())
    current = cfg.get("domain", "")

    print(color("已保存的中转:", C_BOLD))
    for i, d in enumerate(domain_list, 1):
        r = relays.get(d, {})
        mark = color(" ★当前", C_GREEN) if d == current else ""
        print(
            f"  [{i}] {color(d, C_CYAN)}  "
            f"key={r.get('default_key_name','?')}  "
            f"线路={r.get('default_endpoint_name','?')}{mark}"
        )
    add_idx = len(domain_list) + 1
    print(f"  [{add_idx}] {color('+ 新建中转', C_GREEN)}")

    default_pick = (domain_list.index(current) + 1) if current in domain_list else add_idx
    pick = ask_choice("选择", add_idx, default=default_pick)
    if pick is None:
        return state

    if pick == add_idx:
        try:
            raw = input("  新中转域名 (https://...): ").strip()
        except (EOFError, KeyboardInterrupt):
            print()
            return state
        if not raw:
            print(color("  已取消", C_DIM))
            return state
        raw = _normalize_domain(raw)
        probe_ctx = Sub2Context(
            raw, config_path=cur_ctx.config_path,
            cdp_host=cur_ctx.cdp_host, cdp_port=cur_ctx.cdp_port,
        )
        ok, why = probe_ctx.settings_reachable_anonymous()
        if not ok:
            print(color(f"  ✗ {raw} 不像 Sub2API 实例 ({why})", C_RED))
            return state
        print(color(f"  ✓ {raw} 正常", C_GREEN))
        target_domain = raw
        relays[target_domain] = {f: None for f in RELAY_FIELDS}
    else:
        target_domain = domain_list[pick - 1]

    # 给 target_domain 建新 ctx
    new_ctx = Sub2Context(
        target_domain, config_path=cur_ctx.config_path,
        cdp_host=cur_ctx.cdp_host, cdp_port=cur_ctx.cdp_port,
    )

    cfg["domain"] = target_domain
    relay = relays.get(target_domain, {})
    for f in RELAY_FIELDS:
        cfg[f] = relay.get(f)

    while True:
        try:
            _ = new_ctx.token
            break
        except TokenError as exc:
            print(color(f"  ✗ {exc}", C_YELLOW))
            print(color(
                f"  请在 Edge 打开 {target_domain} 并登录，按回车重试 (Ctrl-C 取消)",
                C_YELLOW))
            try:
                input()
            except (EOFError, KeyboardInterrupt):
                print()
                return state

    user = new_ctx.fetch_user()
    if not user:
        print(color("  ✗ /auth/me 失败，token 可能无效", C_RED))
        return state

    state["ctx"] = new_ctx
    state["user"] = user
    cfg, dk, de = ensure_defaults(new_ctx, cfg, verbose=True)
    state["cfg"] = cfg
    state["default_key"] = dk
    state["default_ep"] = de
    print(color(f"  ✓ 切到 {target_domain}", C_GREEN))
    return state


def cmd_reveal(ctx: Sub2Context, cfg: dict) -> None:
    keys = ctx.fetch_keys()
    k = find_key_by_name(keys, cfg.get("default_key_name", "")) if cfg.get("default_key_name") else None
    if not k:
        print(color("  未设置默认 key", C_YELLOW))
        return
    print(f"  {color(k.get('name','?'), C_CYAN)}: {k.get('key','')}")


# ==================== Setup 向导 ====================

def run_wizard(
    config_path: str, cdp_host: str, cdp_port: int
) -> tuple[Sub2Context, dict]:
    print(color("sub2cli — 首次启动配置", C_BOLD + C_CYAN))
    print()

    # 1. 域名
    print(color("[1/5] 中转站域名", C_BOLD))
    while True:
        try:
            raw = input(f"  输入域名 (默认 {DEFAULT_DOMAIN}): ").strip()
        except (EOFError, KeyboardInterrupt):
            print()
            sys.exit(0)
        raw = raw or DEFAULT_DOMAIN
        raw = _normalize_domain(raw)
        probe_ctx = Sub2Context(
            raw, config_path=config_path, cdp_host=cdp_host, cdp_port=cdp_port
        )
        print(color(f"  正在验证 {probe_ctx.api_base}/settings/public ...", C_DIM))
        ok, why = probe_ctx.settings_reachable_anonymous()
        if ok:
            print(color(f"  ✓ {probe_ctx.api_base} 正常", C_GREEN))
            ctx = probe_ctx
            break
        print(color(f"  ✗ {why}", C_RED))

    # 2. token
    print()
    print(color("[2/5] 读取浏览器登录信息", C_BOLD))
    print(color(f"  正在从 Edge CDP 读取 {ctx.site} 的 auth_token ...", C_DIM))
    while True:
        try:
            _ = ctx.token
            break
        except TokenError as exc:
            print(color(f"  ✗ {exc}", C_YELLOW))
            print(color(
                f"  请在 Edge 中打开 {ctx.domain} 并登录，然后按回车重试 (Ctrl-C 退出)",
                C_YELLOW))
            try:
                input()
            except (EOFError, KeyboardInterrupt):
                print()
                sys.exit(0)
    print(color(f"  ✓ 拿到 token ({len(ctx.token)} 字符)", C_GREEN))

    # 3. 账号
    print()
    print(color("[3/5] 账号信息", C_BOLD))
    user = ctx.fetch_user()
    if not user:
        print(color("  ✗ /auth/me 失败", C_RED))
        sys.exit(1)
    bal = user.get("balance", 0)
    conc = user.get("concurrency", 0)
    print(f"  邮箱: {color(user.get('email','?'), C_CYAN)}   "
          f"余额: {color(f'${bal:.4f}', C_GREEN)}   并发: {color(str(conc), C_GREEN)}")

    # 4. 选 key
    print()
    print(color("[4/5] 选择默认 API Key", C_BOLD))
    keys = ctx.fetch_keys()
    if not keys:
        print(color("  该账号还没有任何 API key，自动创建 sub2cli …", C_DIM))
        new_key = ctx.create_key(name="sub2cli")
        if not new_key:
            print(color("  ✗ POST /keys 失败，请在网页 UI 手动建一个再重跑", C_RED))
            sys.exit(1)
        print(color(f"  ✓ 已创建: {new_key.get('name')} (id={new_key.get('id')})", C_GREEN))
        keys = ctx.fetch_keys()
        if not keys:
            print(color("  ✗ 创建后仍未读到 keys，请检查网页 UI", C_RED))
            sys.exit(1)
    for i, k in enumerate(keys, 1):
        g = k.get("group") or {}
        rate = g.get("rate_multiplier")
        rate_s = f"{rate}x" if rate is not None else "?"
        print(
            f"  [{i}] {color(k.get('name','?'), C_CYAN):<14} "
            f"{mask_key(k.get('key',''))}  "
            f"分组: {g.get('name','?')} ({rate_s})"
        )
    pick = ask_choice("  选择默认", len(keys), default=1)
    if pick is None:
        sys.exit(0)
    default_key = keys[pick - 1]

    # 5. 选端点
    print()
    print(color("[5/5] 选择默认端点", C_BOLD))
    settings = ctx.fetch_settings() or {}
    eps = collect_endpoints(settings, fallback_site=ctx.domain)
    if not eps:
        print(color("  ✗ 无端点配置", C_RED))
        sys.exit(1)
    for i, ep in enumerate(eps, 1):
        print(
            f"  [{i}] {color(ep.get('name','?'), C_CYAN):<14} "
            f"{ep.get('endpoint','?')}  "
            f"{color(ep.get('description',''), C_DIM)}"
        )
    pick = ask_choice("  选择默认", len(eps), default=1)
    if pick is None:
        sys.exit(0)
    default_ep = eps[pick - 1]

    cfg = {
        "domain": ctx.domain,
        "default_key_id": default_key.get("id"),
        "default_key_name": default_key.get("name"),
        "default_endpoint_name": default_ep.get("name"),
        "default_endpoint_url": default_ep.get("endpoint"),
    }
    save_config(cfg, ctx.config_path)
    print()
    print(color(f"✓ 已保存到 {ctx.config_path}", C_GREEN))
    print()
    return ctx, cfg


# ==================== 主循环 ====================

def main() -> int:
    if "--help" in sys.argv or "-h" in sys.argv:
        print(__doc__.strip())
        return 0

    config_path = default_config_path()
    cdp_host = DEFAULT_CDP_HOST
    cdp_port = DEFAULT_CDP_PORT

    cfg = load_config(config_path)
    if not cfg:
        ctx, cfg = run_wizard(config_path, cdp_host, cdp_port)
    else:
        ctx = Sub2Context(
            cfg["domain"], config_path=config_path,
            cdp_host=cdp_host, cdp_port=cdp_port,
        )

    try:
        _ = ctx.token
    except TokenError as exc:
        print(color(str(exc), C_RED))
        return 1

    user = ctx.fetch_user()
    if not user:
        print(color("拉取账号信息失败，token 可能失效。请重新登录后再试。", C_RED))
        return 1

    cfg, default_key, default_ep = ensure_defaults(ctx, cfg, verbose=False)

    state = {
        "ctx": ctx, "cfg": cfg, "user": user,
        "default_key": default_key, "default_ep": default_ep,
    }

    def banner_fn():
        print_banner(state["ctx"], state["user"], state["default_key"], state["default_ep"])

    def refresh_default_key():
        ks = state["ctx"].fetch_keys()
        state["default_key"] = find_key_by_name(ks, state["cfg"].get("default_key_name", ""))

    def refresh_default_ep():
        s = state["ctx"].fetch_settings() or {}
        eps = collect_endpoints(s, fallback_site=state["ctx"].domain)
        state["default_ep"] = find_endpoint(eps, state["cfg"].get("default_endpoint_name", ""))

    options: list[tuple[str, str]] = [
        ("刷新", "refresh"),
        ("中转", "relay"),
        ("url", "ep"),
        ("分组", "groups"),
        ("名称", "key"),
        ("兑换历史", "history"),
        ("配置 codex", "inject"),
        ("退出", "quit"),
    ]
    last_idx = 0

    while True:
        choice = select_menu(options, banner_fn=banner_fn, initial=last_idx)
        if choice == "quit":
            clear_screen()
            print(color("bye", C_DIM))
            return 0

        last_idx = next((i for i, (_, v) in enumerate(options) if v == choice), 0)
        clear_screen()
        banner_fn()
        print()

        if choice == "refresh":
            new_user = state["ctx"].fetch_user()
            if new_user:
                state["user"] = new_user
            state["cfg"], state["default_key"], state["default_ep"] = ensure_defaults(
                state["ctx"], state["cfg"], verbose=False
            )
            print(color("  ✓ 已刷新", C_GREEN))
            pause()
            continue

        if choice == "relay":
            state = cmd_select_relay(state)
            pause()
            continue

        if choice == "ep":
            state["cfg"] = cmd_endpoints(state["ctx"], state["cfg"])
            refresh_default_ep()
            pause()

        elif choice == "groups":
            state["cfg"] = cmd_groups(state["ctx"], state["cfg"])
            refresh_default_key()  # 切 group 后默认 key 的 group_id 变了
            pause()

        elif choice == "key":
            state["cfg"] = cmd_key(state["ctx"], state["cfg"], None)
            refresh_default_key()
            pause()

        elif choice == "history":
            print(color("最近兑换历史:", C_BOLD))
            print_history(state["ctx"].fetch_history(10))
            pause()

        elif choice == "inject":
            cmd_inject_codex(state["ctx"], state["cfg"])
            pause()

        elif choice == "reveal":
            cmd_reveal(state["ctx"], state["cfg"])
            pause()

        elif choice == "setup":
            state["ctx"], state["cfg"] = run_wizard(
                state["ctx"].config_path,
                state["ctx"].cdp_host,
                state["ctx"].cdp_port,
            )
            state["user"] = state["ctx"].fetch_user()
            refresh_default_key()
            refresh_default_ep()
            pause("配置已更新")


if __name__ == "__main__":
    sys.exit(main())
