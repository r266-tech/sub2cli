    print()


def print_history(rows: list[dict]) -> None:
    if not rows:
        print(color("  （无）", C_DIM))
        return
    for r in rows:
        ts = (r.get("used_at") or "")[:19].replace("T", " ")
        t = r.get("type") or "?"
        v = r.get("value")
        code = (r.get("code") or "")[:10] + "…"
        if t == "balance":
            v_s = f"+${v:.2f}" if isinstance(v, (int, float)) else "?"
        elif t == "concurrency":
            v_s = f"+{v} 请求" if v is not None else "?"
        elif t == "subscription":
            v_s = f"订阅 {r.get('validity_days')}天"
        else:
            v_s = str(v)
        print(f"  {color(ts, C_DIM)}  {color(t, C_BLUE):<14}  {v_s:<14}  {color(code, C_DIM)}")


def print_record(rec: dict) -> None:
    short = rec["code"][:10] + "…"
    if rec["status"] == 200:
        bits = []
        t, v = rec.get("type"), rec.get("value")
        if t == "balance" and v is not None:
            bits.append(color(f"+${v:.2f}", C_GREEN))
        elif t == "concurrency" and v is not None:
            bits.append(color(f"+{v} 请求", C_GREEN))
        elif t == "subscription":
            bits.append(color(f"订阅 {rec.get('validity_days')}天", C_GREEN))
        if (nb := rec.get("new_balance")) is not None:
            bits.append(color(f"余额=${nb:.2f}", C_DIM))
        if (nc := rec.get("new_concurrency")) is not None:
            bits.append(color(f"并发={nc}", C_DIM))
        bits.append(color(f"{rec['latency_ms']}ms", C_DIM))
        print(f"  {color('OK ', C_GREEN)} [{short}]  " + "  ".join(bits))
    else:
        det = rec.get("detail") or "(无详情)"
        print(
            f"  {color('ERR', C_RED)} [{short}] HTTP {rec['status']}: "
            f"{det[:80]}  {color(str(rec['latency_ms'])+'ms', C_DIM)}"
        )


