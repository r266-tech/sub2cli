def _resolve_inject_bin() -> str | None:
    here = os.path.dirname(os.path.abspath(__file__))
    candidates = [
        os.path.join(here, "sub2cli-inject"),
        os.path.join(here, "sub2cli-inject.cmd"),
        os.path.expanduser("~/.local/bin/sub2cli-inject"),
        os.path.expanduser("~/.local/bin/codex-provider"),  # 兼容已装 codex-provider 的用户
        shutil.which("sub2cli-inject"),
        shutil.which("codex-provider"),
    ]
    return next((p for p in candidates if p and os.path.isfile(p) and (os.name == "nt" or os.access(p, os.X_OK))), None)


def _run_inject(inject_bin: str, url: str, api_key: str, source_label: str) -> None:
    print(color("注入 codex:", C_BOLD))
    print(f"  url:     {url}")
    print(f"  apikey:  {api_key}")
    print(f"  来源:    {source_label}")
    print(color(f"  调用:    {inject_bin} add-api <url> <key>", C_DIM))
    print()
    try:
        rc = subprocess.call([sys.executable, inject_bin, "add-api", url, api_key])
    except OSError as exc:
        print(color(f"  调用注入器失败: {exc}", C_RED))
        return
    if rc == 0:
        print(color("  ✓ 注入完成", C_GREEN))
    else:
        print(color(f"  ✗ 注入器返回非零 (rc={rc})", C_RED))


def cmd_inject_codex(token: str, cfg: dict) -> None:
    """注入到 Codex CLI / Codex App: 用当前配置 或 临时输入新的 url+apikey."""
    inject_bin = _resolve_inject_bin()
    if not inject_bin:
        here = os.path.dirname(os.path.abspath(__file__))
        print(color("  缺少注入器脚本 sub2cli-inject (应跟 sub2cli 同目录):", C_RED))
        print(color(f"    预期位置: {os.path.join(here, 'sub2cli-inject')}", C_DIM))
        return

    sub_options: list[tuple[str, str]] = [
        ("使用当前配置", "current"),
        ("使用新的 url + apikey", "new"),
    ]

    # 提前抓一次 keys, 把当前默认 key 的完整 apikey 拿出来显在 banner; 不在 banner_fn
    # 里调 fetch_keys 是因为 select_menu 每次按键都会重渲染 banner.
