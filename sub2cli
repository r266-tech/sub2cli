        if is_cur:
            cur_idx = i
        status = k.get("status", "?")
        st_col = C_GREEN if status == "active" else C_YELLOW
        # 探测
        if status == "active":
            r = probe_endpoint(ep_url, api_key=k.get("key"))
            results.append((k, r))
            if r["ok"] and r["status"] == 200:
                probe_s = color(f"✓ {r['latency_ms']}ms · {r['summary']}", C_GREEN)
